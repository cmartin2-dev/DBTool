<UserControl x:Class="DBTool.Controls.CustomControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="0*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Label Content="Database" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
            <RadioButton x:Name="rdoMSSQL" Grid.Row="0" Grid.Column="1" Content="MS SQL" FontSize="15" Margin="5" HorizontalAlignment="Left" Checked="rdoMSSQL_Checked"/>
            <RadioButton x:Name="rdoPostgre" Grid.Row="0" Grid.Column="2" Content="Postgre SQL" FontSize="15" Margin="5" HorizontalAlignment="Left" Checked="rdoPostgre_Checked"/>
            <Label Content="Server" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
            <ComboBox x:Name="cmbServer" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Width="200" HorizontalAlignment="Left" Margin="5" SelectionChanged="cmbServer_SelectionChanged"/>
            <Label Content="Database Name" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
            <ComboBox x:Name="cmbDatabase" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Width="200" HorizontalAlignment="Left" Margin="5"/>
        </Grid>
        <local:TxtQueryControl x:Name="txtQueryControl" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Margin="5" Execute="txtQueryControl_Execute"/>
        <GridSplitter Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" HorizontalAlignment="Stretch"
VerticalAlignment="Stretch"
                Height="2" Margin="5"
Background="DarkGray"
ResizeDirection="Rows"
ShowsPreview="True">
        </GridSplitter>
        <local:ListViewResultControl x:Name="lstResult" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5"/>
    </Grid>

</UserControl>
