<UserControl x:Class="DBTool.Controls.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="8,8,8,16">
            <Label Content="Dashboard" Style="{StaticResource headerLabel}"/>
            <TextBlock Text="Welcome to DBTool — your database management workspace."
                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                       FontFamily="{StaticResource AppFont}" Margin="5,0,0,0"/>
        </StackPanel>

        <!-- Quick Access Cards -->
        <WrapPanel Grid.Row="1" Margin="8,0" Orientation="Horizontal">
            <Border Style="{StaticResource grayBorders}" Width="220" Height="120" Padding="16">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="&#x1F30D;" FontSize="28" Margin="0,0,0,8"/>
                    <TextBlock Text="Environment" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                    <TextBlock Text="Manage environments" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource grayBorders}" Width="220" Height="120" Padding="16">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="&#x1F5E3;" FontSize="28" Margin="0,0,0,8"/>
                    <TextBlock Text="Translation" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                    <TextBlock Text="Locale management" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource grayBorders}" Width="220" Height="120" Padding="16">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="&#x1F5C4;" FontSize="28" Margin="0,0,0,8"/>
                    <TextBlock Text="Database" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                    <TextBlock Text="ERD and object checker" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource grayBorders}" Width="220" Height="120" Padding="16">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="&#x2699;" FontSize="28" Margin="0,0,0,8"/>
                    <TextBlock Text="Settings" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                    <TextBlock Text="Configure your workspace" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"/>
                </StackPanel>
            </Border>
        </WrapPanel>
    </Grid>
</UserControl>
