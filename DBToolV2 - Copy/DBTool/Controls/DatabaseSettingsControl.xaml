<UserControl x:Class="DBTool.Controls.DatabaseSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid ShowGridLines="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Admin" Style="{StaticResource headerLabel}"/>
            <StackPanel Grid.Row="1" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Row="0" Name="rdoAuthentication" Content="🔑" ToolTip="Authentication" Checked="rdoDBSettings_Checked"/>
                    <RadioButton Grid.Row="1" Name="rdoScript" Content="📜" ToolTip="Script" Checked="rdoDBSettings_Checked"/>
                    <RadioButton Grid.Row="2" Name="rdoImageMigration" Content="🔄" ToolTip="Image Migration" Checked="rdoDBSettings_Checked"/>
                    <RadioButton Grid.Row="3" Name="rdoDataMapping" Content="🔗" ToolTip="Data Mapping" Checked="rdoDBSettings_Checked"/>
                </Grid>
            </StackPanel>
            <DockPanel Grid.Column="1" Grid.Row="1" Grid.RowSpan="4" Grid.ColumnSpan="2">
                <Border Style="{StaticResource grayBorders}">
                    <DockPanel>
                        <local:AuthenticationSettingsControl x:Name="authenticationSettingsControl" DockPanel.Dock="Top"/>
                        <local:ScriptPathSettingsControl x:Name="ScriptPathSettingsControl"/>
                    </DockPanel>
                </Border>
            </DockPanel>

        </Grid>
</UserControl>


