<UserControl x:Class="DBTool.Controls.EnvironmentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:local2="clr-namespace:DBTool"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.CommandBindings>
        <CommandBinding Command="{x:Static local:EnvironmentControl.CreateTabCommand}"
                        Executed="CreateTabCommand_Executed" />
    </UserControl.CommandBindings>
    
    <!--<ScrollViewer HorizontalScrollBarVisibility="Auto"
 VerticalScrollBarVisibility="Auto" KeyDown="ScrollViewer_KeyDown" >-->
        <Grid x:Name="MainGrid" ShowGridLines="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" LastChildFill="True">
                <Grid DockPanel.Dock="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <GroupBox Grid.Row="0" Grid.Column="0" VerticalAlignment="Stretch">
                        <Grid>
                            <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="209*"/>
                                <ColumnDefinition Width="21*"/>
                            </Grid.ColumnDefinitions>
                        <Label Content="Environments" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource headerLabel}"/>

                        <Label Content="Regions" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource commonLabel}"/>
                        <ComboBox x:Name="cmbRegion" Grid.Row="1"  Grid.Column="0" Grid.ColumnSpan="3" SelectionChanged="cmbRegion_SelectionChanged" Margin="0,31,0,0" Grid.RowSpan="2" />
                            <Label Content="Environments" Grid.Row="3" Visibility="Hidden"  Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource commonLabel}" Margin="0,25,0,31" Grid.RowSpan="3"/>
                        <local:ListViewResultControl x:Name="lstResult" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="5"
                                                         SelectionChangedExecute="lstViewEnvironment_SelectionChanged" UnCheckbox_Checked="HeaderCheckBox_Unchecked" Checkbox_Checked="HeaderCheckBox_Checked"/>
                        <!--<ListView x:Name="lstViewEnvironment" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="5,5,5,5"
                                      SelectionMode="Single" 
                                      MaxHeight="1200"
                                      SelectionChanged="lstViewEnvironment_SelectionChanged"/>
                            <Label x:Name="lblProgress" Content="Status : Idle" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" 
                                   Margin="5,0,5,0"/>-->
                        </Grid>
                    </GroupBox>

                </Grid>
            </DockPanel>
            <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"  HorizontalAlignment="Left"
                  VerticalAlignment="Stretch"
                  Background="DarkGray"
                          Width="2"
                  ShowsPreview="True">

            </GridSplitter>
            <TabControl x:Name="tabMainControl" Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" SelectionChanged="TabControl_SelectionChanged" PreviewKeyDown="tabMainControl_PreviewKeyDown">
                <TabItem Header="Query" x:Name="QueryTab" VerticalAlignment="Stretch" Style="{StaticResource BaseTabItem}" >
                    <TabControl x:Name="MainTabQueryControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></TabControl>
                </TabItem>
                <TabItem Header="Query per Schema" x:Name="QueryPerSchemaTab"  VerticalAlignment="Stretch"  Style="{StaticResource BaseTabItem}">
                <local:QueryPerSchemaControl x:Name="queryPerSchemaControl"/>

            </TabItem>
                <TabItem Header="Feature Toggle" x:Name="FeaureToggleTab"  VerticalAlignment="Stretch"  Style="{StaticResource BaseTabItem}">
                <local:FeatureToggleControl x:Name="featureToggleControl"/>

            </TabItem>
                <TabItem Header="Drop Version" x:Name="DropVersionTab"  VerticalAlignment="Stretch"  Style="{StaticResource BaseTabItem}">
                <local:DropVersionControl x:Name="dropVersionControl"/>

            </TabItem>
            <TabItem Header="Extract Table" x:Name="ExtractTableTab"  VerticalAlignment="Stretch"  Style="{StaticResource BaseTabItem}">
                <local:ExtractTableControl x:Name="extractTableControl"/>


            </TabItem>
            <TabItem Header="Custom" x:Name="CustomCSTab"  VerticalAlignment="Stretch" Visibility="Hidden"  Style="{StaticResource BaseTabItem}">
                <local:CustomControl x:Name="customControl"/>

            </TabItem>
        </TabControl>

        </Grid>

    <!--</ScrollViewer>-->
</UserControl>
