<UserControl x:Class="DBTool.Controls.EnvironmentServerSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="Environment Server" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource headerLabel}"/>
        <DockPanel Grid.Column="0" Grid.Row="1" Grid.RowSpan="2">
            <StackPanel DockPanel.Dock="Left" Margin="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="450"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="lstViewServer"  Grid.Row="0" Grid.Column="0" 
                              SelectionMode="Single" Height="800" SelectionChanged="lstViewServer_SelectionChanged"></ListView>

                </Grid>
            </StackPanel>
        </DockPanel>
        <StackPanel  Grid.Column="2" Grid.Row="1"  Width="auto">
            <Grid ShowGridLines="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="71*"/>
                    <ColumnDefinition Width="845*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Label Content="➕" Name="btnAdd" ToolTip="Add" Grid.Row="0" Grid.Column="1" Style="{StaticResource labelButton}" MouseDown="btnAdd_MouseDown" Margin="5,5,5,5"/>
                <Label Content="📋" Name="btnCopy" ToolTip="Copy" Grid.Row="0" Grid.Column="2" Style="{StaticResource labelButton}" MouseDown="btnCopy_MouseDown" Margin="5,5,5,5"/>
                <!--<Label Content="🔄" Name="btnUpdate" ToolTip="Update" Grid.Row="0" Grid.Column="3" Style="{StaticResource labelButton}" />-->
                <Label Content="🗑️" Name="btnDelete" ToolTip="Delete" Grid.Row="0" Grid.Column="3" Style="{StaticResource labelButton}" MouseDown="btnDelete_MouseDown" Margin="5,5,5,5"/>
                <Label Content="⛔" Name="btnCancel" ToolTip="Cancel" Grid.Row="0" Grid.Column="4" Style="{StaticResource labelButton}" MouseDown="btnCancel_MouseDown" Margin="5,5,5,5"/>

            </Grid>
            <StackPanel Margin="0,50,0,0" x:Name="stackPanelDetails">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="900"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Label Content="Id" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtId" Text="{Binding Id}" IsReadOnly="True" Grid.Row="0" Grid.Column="1" Width="50" HorizontalAlignment="Left" Margin="5"/>

                    <Label Content="Server" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtServer" Text="{Binding ServerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Grid.Row="1" Grid.Column="1" Margin="5" Style="{StaticResource TextboxValidation}"/>

                    
                    <Label Content="Headers" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <DataGrid ItemsSource="{Binding Databases}" Grid.Column="1" Grid.Row="2" MinHeight="100"
                           SelectionMode="Single"  Margin="5" AutoGenerateColumns="False" CanUserAddRows="True"
                           HeadersVisibility="Column"
       RowHeaderWidth="0"
       SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Database Name" Binding="{Binding  DatabaseName}"/>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}"/>
                            <DataGridTextColumn Header="Password" Binding="{Binding Password}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </StackPanel>
        </StackPanel>



    </Grid>
</UserControl>
