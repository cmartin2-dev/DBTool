<UserControl x:Class="DBTool.Controls.EnvironmentSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:commons="clr-namespace:DBTool.Commons"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Environment" Style="{StaticResource headerLabel}"/>
        <StackPanel Grid.Row="1" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <RadioButton Grid.Row="0" Name="rdoRegion" Content="📍" ToolTip="Regions" Checked="rdoMain_Checked"/>
                <RadioButton Grid.Row="1" Name="rdoTenant" Content="👥" ToolTip="Tenants" Checked="rdoMain_Checked"/>
                <RadioButton Grid.Row="2" Name="rdoServer" Content="🗄️" ToolTip="Environment Server" Checked="rdoMain_Checked"/>
            </Grid>
        </StackPanel>
        <DockPanel Grid.Column="1" Grid.Row="1" Grid.RowSpan="4">
            <Border Style="{StaticResource grayBorders}">
                <DockPanel>
                    <local:RegionSettingsControl x:Name="regionSettingsControl"/>
                    <local:TenantsSettingsControl x:Name="tenantsSettingsControl"/>
                    <local:EnvironmentServerSettingsControl x:Name="environmentServerSettingsControl"/>
                </DockPanel>
            </Border>
        </DockPanel>


    </Grid>
</UserControl>
