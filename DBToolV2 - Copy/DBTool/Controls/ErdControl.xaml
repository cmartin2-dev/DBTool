<UserControl x:Class="DBTool.Controls.ErdControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button x:Name="btnLoadDLL" Content="Load" Style="{StaticResource RoundButton}"
                Click="btnLoadDLL_Click"
                Margin="5" HorizontalAlignment="Left"/>
        <local:ListViewResultControl x:Name="lstEntityResults" Grid.Row="1" Grid.Column="0" Margin="5" SelectionChangedExecute="lstEntityResults_SelectionChangedExecute"/>
        <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"  HorizontalAlignment="Left"
                  VerticalAlignment="Stretch"
                  Background="DarkGray"
                          Width="2"
                  ShowsPreview="True">
        </GridSplitter>
        <TabControl Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" Margin="5">
            <TabItem Header="Object Checker" Style="{StaticResource BaseTabItem}">
                <local:ObjectCheckerControl x:Name="objectCheckerControl"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
