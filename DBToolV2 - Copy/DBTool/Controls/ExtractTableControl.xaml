<UserControl x:Class="DBTool.Controls.ExtractTableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Style="{StaticResource commonLabel}" Grid.Row="0" Grid.Column="0">
            <TextBlock Text="{Binding tenantId}"/>
        </Label>
        <DockPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Margin="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button x:Name="btnFetchSchema" Content="Fetch Schema" Grid.Row="0" Grid.Column="0" Style="{StaticResource RoundButton}" Margin="5" Click="btnFetchSchema_ClickAsync"/>
                <local:ListViewResultControl x:Name="lstViewSchema" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" SelectionChangedExecute="lstViewSchema_SelectionChangedExecute"/>
            </Grid>
           
        </DockPanel>
        <GridSplitter Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Stretch"
VerticalAlignment="Stretch"
                Height="2" Margin="5"
Background="DarkGray"
ResizeDirection="Rows"
ShowsPreview="True"/>
        
        

        <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Button x:Name="btnGetTable" Content="Get Tables" Grid.Column="0" Grid.Row="0" Margin="5" Style="{StaticResource RoundButton}" Click="btnGetTable_Click" HorizontalAlignment="Left"/>
            </Grid>
            <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Label Content="Records per file (Max 5000)" Grid.Row="0" Grid.Column="0" Margin="5"/>
                <TextBox x:Name="txtMaxRecord" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Width="50"
TextChanged="txtMaxRecord_TextChanged"
PreviewTextInput="txtMaxRecord_PreviewTextInput" PreviewKeyDown="txtMaxRecord_PreviewKeyDown" Height="25" Margin="5"/>
                <Button x:Name="btnExtractTable" Grid.Row="0" Grid.Column="3"  Content="Extract Table" 
                        Style="{StaticResource RoundButton}"
                        Click="btnExtractTable_Click"
                        Margin="5" HorizontalAlignment="Right"/>

            </Grid>
            <local:ListViewResultControl x:Name="tabResult" Grid.Row="1" Grid.ColumnSpan="2" Grid.Column="0" Margin="5" Checkbox_Checked="HeaderCheckBox_Checked" UnCheckbox_Checked="HeaderCheckBox_Unchecked">

            </local:ListViewResultControl>


        </Grid>
       
    </Grid>
</UserControl>
