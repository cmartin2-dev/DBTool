<UserControl x:Class="DBTool.Controls.FeatureToggleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label x:Name="lblTenantName" Grid.Column="0" Grid.Row="0" Style="{StaticResource commonLabel}"  Margin="5">
            <TextBlock Text="{Binding tenantId}"/>
        </Label>
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="580"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button x:Name="btnGetToggle" Content="Get Feature Toggle" Grid.Column="0" Grid.Row="0"
             Style="{StaticResource RoundButton}" Margin="5"
             Click="btnGetToggle_Click"/>
            <local:ListViewResultControl x:Name="lstResult" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" SelectionChangedExecute="lstResult_SelectionChangedExecute"/>
            <GridSplitter Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"  HorizontalAlignment="Left"
   VerticalAlignment="Stretch"
   Background="DarkGray"
           Width="2"
   ShowsPreview="True"/>
            <Grid Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <GroupBox Header="Details" Grid.Row="0" Grid.Column="0" x:Name="grpDetail">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Button x:Name="btnSave" Grid.Column="1" Grid.Row="0" Content="Save"
                         Click="btnSave_Click"
                         Style="{StaticResource RoundButton}" Margin="5" HorizontalAlignment="Right"/>
                        <Label Content="Id" Grid.Row="2" Grid.Column="0"/>
                        <Label Content="Key" Grid.Row="3" Grid.Column="0"/>
                        <Label Content="Display Name" Grid.Row="4" Grid.Column="0"/>
                        <Label Content="Enabled" Grid.Row="5" Grid.Column="0"/>
                        <Label Content="Visible" Grid.Row="6" Grid.Column="0"/>
                        <Label Content="Description" Grid.Row="7" Grid.Column="0"/>
                        <Label Content="Version" Grid.Row="8" Grid.Column="0"/>
                        <Label Content="Expiry Date" Grid.Row="9" Grid.Column="0"/>

                        <Label Content="Format (MM/dd/yyyy)" FontSize="8" FontStyle="Italic" Grid.Row="10" Grid.Column="1"/>

                        <TextBox x:Name="txtId" Grid.Row="2" Text="{Binding APPFEATUREID}" Grid.Column="1" Width="50" HorizontalAlignment="Left" Margin="5" IsReadOnly="True"/>
                        <TextBox x:Name="txtKey" Grid.Row="3" Grid.Column="1" Text="{Binding KEY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  HorizontalAlignment="Stretch" Margin="5"/>
                        <TextBox x:Name="txtDisplayName" Grid.Row="4" Grid.Column="1" Text="{Binding DISPLAYNAME, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" Margin="5"/>
                        <CheckBox x:Name="chkEnabled" Grid.Row="5" Grid.Column="1" IsChecked="{Binding ENABLED, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="5"/>
                        <CheckBox x:Name="chkVisible" Grid.Row="6" Grid.Column="1" IsChecked="{Binding VISIBLE, UpdateSourceTrigger=PropertyChanged}"  HorizontalAlignment="Left" Margin="5"/>
                        <TextBox x:Name="txtDescription" Grid.Row="7" Grid.Column="1" Text="{Binding DESCRIPTION, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" Margin="5"/>
                        <TextBox x:Name="txtVersion" Grid.Row="8" Grid.Column="1" Text="{Binding VERSION, UpdateSourceTrigger=PropertyChanged}"  HorizontalAlignment="Stretch" Margin="5"/>
                        <TextBox x:Name="txtExpiryDate" Grid.Row="9" Grid.Column="1" Text="{Binding EXPIRYDATE, StringFormat='{}{0:MM/dd/yyyy}', UpdateSourceTrigger=PropertyChanged}"  HorizontalAlignment="Stretch" Margin="5"/>

                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

    </Grid>

   
</UserControl>
