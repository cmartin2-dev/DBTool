<UserControl x:Class="DBTool.Controls.ListViewResultControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="800">

    <!-- ListView -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Label x:Name="lblTotalCount" Content="Total Count : 0" Grid.Column="0" Grid.Row="0"/>
        <!--<ListView x:Name="lstResult" Grid.Row="1" Grid.Column="0" SelectionChanged="lstResult_SelectionChanged"
       VirtualizingPanel.IsVirtualizing="True"
       VirtualizingPanel.VirtualizationMode="Recycling"
       ScrollViewer.CanContentScroll="True" SelectionMode="Single"
               />-->
        <DockPanel  Grid.Row="1" Grid.Column="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="txtSearch" Grid.Row="0" Grid.Column="0" Style="{StaticResource WatermarkTextBox1}" TextChanged="txtSearch_TextChanged"/>
                <DataGrid Grid.Column="0" Grid.Row="1" x:Name="dataGrid1" AutoGenerateColumns="False"
          EnableRowVirtualization="True"
          EnableColumnVirtualization="True"
          VirtualizingPanel.VirtualizationMode="Recycling"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          SelectionMode="Extended"
                          CellEditEnding="dataGrid1_CellEditEnding"
          SelectionChanged="dataGrid1_SelectionChanged">

                </DataGrid>
            </Grid>
        </DockPanel>
        
        
        <local:LoadingControl x:Name="loadingControl" Grid.Row="1" Grid.Column="0"/>

        <Label x:Name="lblProgress" Content="Status : Idle" Grid.Row="3" Grid.Column="0" Margin="5,0,5,0"/>


    </Grid>
</UserControl>
