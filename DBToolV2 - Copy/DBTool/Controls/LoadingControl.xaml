<UserControl x:Class="DBTool.Controls.LoadingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:converters="clr-namespace:DBTool.Commons"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <!-- Loading Overlay -->
        <Grid Background="#40000000" x:Name="loadingborder" Visibility="Collapsed">
            <Border Background="White" CornerRadius="12" Padding="32,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="240">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Loading..." FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource AppFont}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Margin="0,12,0,0" Width="180"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Error Overlay -->
        <Grid Background="#40000000" x:Name="Errorborder" Visibility="Collapsed">
            <Border Background="White" CornerRadius="12" Padding="32,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="280" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1,4,1,1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#x26A0;" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Label Content="Error" x:Name="txtErrorName"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="16" FontWeight="SemiBold"
                           FontFamily="{StaticResource AppFont}"
                           HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtErrorDetail"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               FontFamily="{StaticResource AppFont}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="400"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Done Overlay -->
        <Grid Background="#40000000" x:Name="Doneborder" Visibility="Collapsed">
            <Border Background="White" CornerRadius="12" Padding="32,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="240" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1,4,1,1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#x2705;" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Done" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}"
                               FontFamily="{StaticResource AppFont}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtRowsAffected"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               FontFamily="{StaticResource AppFont}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
