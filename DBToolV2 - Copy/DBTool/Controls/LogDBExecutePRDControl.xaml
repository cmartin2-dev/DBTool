<UserControl x:Class="DBTool.Controls.LogDBExecutePRDControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="Query Log" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource headerLabel}"/>

        <Button x:Name="btnGetLog" Grid.Column="0" Grid.Row="1" Content="Get Query Log"
                Click="btnGetLog_Click"
                Style="{StaticResource RoundButton}" Margin="5"/>
        <local:ListViewResultControl x:Name="lstDBExecResult" Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2"  Margin="5" SelectionChangedExecute="lstDBExecResult_SelectionChangedExecute"/>
        <GridSplitter Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"  HorizontalAlignment="Left"
       VerticalAlignment="Stretch"
       Background="DarkGray"
               Width="2"
       ShowsPreview="True">

        </GridSplitter>
        <Button x:Name="btnGenerateLogFile" Style="{StaticResource RoundButton}" Content="Generate Log File"
                Margin="5"
                Grid.Row="1" Grid.Column="2" Width="150"
                HorizontalAlignment="Left"
                Click="btnGenerateLogFile_Click"/>
        <DockPanel Grid.Row="2" Grid.Column="2" Margin="5">
        <TextBox x:Name="txtScript" Grid.Row="2" Grid.Column="2" Margin="5" IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>
        </DockPanel>
    </Grid>
</UserControl>
