<Window x:Class="DBTool.Controls.LogQueryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="400" Title="Query Log" WindowStartupLocation="CenterScreen" SizeToContent="Height">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="JIRA Ticket" Grid.Row="0" Grid.Column="0" Margin="5" Style="{StaticResource commonLabel}"/>
        <TextBox x:Name="txtJiraTicket" Grid.Row="0" Text="{Binding JIRATicket, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="5"/>

        <Label Content="Description of Script" Grid.Row="1" Grid.Column="0" Margin="5" Style="{StaticResource commonLabel}"/>
        <TextBox x:Name="txtDescriptionOfScript" Grid.Row="1" Grid.Column="1" Height="150"
                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                 TextWrapping="Wrap" Text="{Binding DescriptionOfScript, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5"/>

        <Label Content="Release Version" Grid.Row="2" Grid.Column="0" Margin="5" Style="{StaticResource commonLabel}"/>
        <TextBox x:Name="txtReleaseVersion" Grid.Row="2" Grid.Column="1"
                  Text="{Binding ReleaseVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5"/>

        <Label Content="Date Executed" Grid.Row="3" Grid.Column="0" Margin="5" Style="{StaticResource commonLabel}"/>
        <TextBox x:Name="txtDateExecuted" Grid.Row="3" Grid.Column="1"
                 Text="{Binding DateExecuted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5" />

        <Label Content="Tenant Id" Grid.Row="4" Grid.Column="0" Margin="5" Style="{StaticResource commonLabel}"/>
        <TextBox x:Name="txtTenantId" Grid.Row="4" Grid.Column="1"                 
                 Text="{Binding TenantId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5"/>

        <Label Content="Schema Version" Grid.Row="5" Grid.Column="0" Margin="5" Style="{StaticResource commonLabel}"/>
        <TextBox x:Name="txtSchemaVersion" Grid.Row="5" Grid.Column="1"
                 Text="{Binding SchemaVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5"/>

        <Label Content="Script" Grid.Row="6" Grid.Column="0" Margin="5" Style="{StaticResource commonLabel}"/>
        <TextBox x:Name="txtScript" Grid.Row="6" Grid.Column="1" Margin="5"
                 Height="150" VerticalContentAlignment="Top"
                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" IsReadOnly="True"
                 Text="{Binding Script, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 />

        <Button x:Name="btnSave" Content="Save" Grid.Row="7" Grid.Column="1" Margin="5" Click="btnSave_Click"
                Style="{StaticResource RoundButton}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
    </Grid>
</Window>
