<UserControl x:Class="DBTool.Controls.ObjectCheckerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button x:Name="btnCheckDuplicate" Grid.Column="0" Grid.Row="0" Content="Check Duplicate Column" Style="{StaticResource RoundButton}" 
                Click="btnCheckDuplicate_Click"
                HorizontalAlignment="Left" Margin="5,10,0,0"/>
        <Button x:Name="btnRefresh" Grid.Column="1" Grid.Row="0" Content="Refresh" Style="{StaticResource RoundButton}" 
                Click="btnRefresh_Click"
                HorizontalAlignment="Left" Margin="5,10,0,0"/>
        <local:ListViewResultControl x:Name="lstObjecResult" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Margin="5"/>
    </Grid>
</UserControl>
