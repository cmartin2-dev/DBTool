<UserControl x:Class="DBTool.Controls.QueryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:common="clr-namespace:DBTool.Commons"
             mc:Ignorable="d" 
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             d:DesignHeight="800" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label  Style="{StaticResource commonLabel}" Grid.Row="0" Grid.Column="0">
            <TextBlock Text="{Binding tenantId}"/>
        </Label>
        <local:TxtQueryControl x:Name="txtQueryControl" Grid.Row="1" Grid.Column="0" Execute="txtQueryControl_Execute"/>
        <GridSplitter Grid.Row="2" Grid.Column="0" HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
                      Height="2" Margin="5"
      Background="DarkGray"
      ResizeDirection="Rows"
      ShowsPreview="True">
        </GridSplitter>
        <DockPanel Grid.Row="3" Grid.Column="0" LastChildFill="True">
            <TabControl x:Name="tabQueryResultControl">
            </TabControl>
        </DockPanel>

    </Grid>
</UserControl>
