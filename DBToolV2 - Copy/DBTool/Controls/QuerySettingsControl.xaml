<UserControl x:Class="DBTool.Controls.QuerySettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Query" Style="{StaticResource headerLabel}"/>
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="450"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <ListView x:Name="lstViewQuery" Height="800" ItemsSource="{Binding Queries}" SelectionMode="Single" SelectionChanged="lstViewQuery_SelectionChanged"></ListView>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Width="auto" Margin="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Label Content="➕" Name="btnAdd" ToolTip="Add" Grid.Row="0" Grid.Column="1" Style="{StaticResource labelButton}" MouseDown="btnAdd_MouseDown" Margin="5,5,5,5"/>
                        <Label Content="📋" Name="btnCopy" ToolTip="Copy" Grid.Row="0" Grid.Column="2" Style="{StaticResource labelButton}" MouseDown="btnCopy_MouseDown" Margin="5,5,5,5"/>
                        <!--<Label Content="🔄" Name="btnUpdate" ToolTip="Update" Grid.Row="0" Grid.Column="3" Style="{StaticResource labelButton}" />-->
                        <Label Content="🗑️" Name="btnDelete" ToolTip="Delete" Grid.Row="0" Grid.Column="3" Style="{StaticResource labelButton}" MouseDown="btnDelete_MouseDown" Margin="5,5,5,5"/>
                        <Label Content="⛔" Name="btnCancel" ToolTip="Cancel" Grid.Row="0" Grid.Column="4" Style="{StaticResource labelButton}" MouseDown="btnCancel_MouseDown" Margin="5,5,5,5"/>

                    </Grid>
                    <StackPanel Margin="0,50,0,0" x:Name="stackPanelDetails">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="900"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="234.705"/>
                                <RowDefinition Height="100.295"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="Name" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5,5,5,5"/>
                            <TextBox x:Name="txtName" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{StaticResource TextboxValidation}" Grid.Row="0" Grid.Column="1" Margin="5,5,5,5"/>

                            <Label Content="Description" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5,5,5,5"/>
                            <TextBox x:Name="txtDescription" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="5,5,5,5"/>

                            <Label Content="Query" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5,5,5,5" Grid.RowSpan="2"/>
                            <TextBox x:Name="txtQuery" Grid.Row="2" Text="{Binding QueryString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Column="1" Margin="5,5,5,5" AcceptsReturn="True" Grid.RowSpan="2" VerticalContentAlignment="Top"/>

                            <Label Content="Is Private" Grid.Row="4" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5,5,5,5"/>
                            <CheckBox x:Name="chkIsPrivate" Grid.Row="4" Grid.Column="1" IsChecked="{Binding IsPrivate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Margin="5,14,0,5" />
                            
                            <Label Content="Is User" Grid.Row="5" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5,5,5,5"/>
                            <CheckBox x:Name="chkIsUser" Grid.Row="5" Grid.Column="1" IsChecked="{Binding IsUser,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Margin="5,14,0,5" />

                        </Grid>
                    </StackPanel>
                </StackPanel>

            </Grid>
        </StackPanel>

    </Grid>
</UserControl>
