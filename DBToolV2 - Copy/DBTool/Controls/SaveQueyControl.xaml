<Window x:Class="DBTool.Controls.SaveQueyControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DBTool.Controls"
        mc:Ignorable="d"
        Title="Save Query" Height="150" Width="400" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="10,10,10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Label + Input -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 0">
            <Label Content="Name:" VerticalAlignment="Center" Width="80" Style="{StaticResource commonLabel}"/>
            <TextBox x:Name="txtName" Width="250"/>
        </StackPanel>


        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Grid.Row="1"  VerticalAlignment="Center"
                    HorizontalAlignment="Right" Margin="0 10 0 20">
            <Button Content="Save" Width="80" Margin="0 0 10 0" 
                    IsDefault="True" Click="Save_Click" Style="{StaticResource RoundButton}"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Style="{StaticResource RoundButton}"/>
        </StackPanel>
    </Grid>
</Window>
