<UserControl x:Class="DBTool.Controls.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" d:Height="800" d:Width="800"    
             >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="850"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Settings" Style="{StaticResource headerLabel}"/>
                <Button Name="btnSave" Content="Save" Grid.Row="0" Grid.Column="2" Margin="5" HorizontalAlignment="Right" Style="{StaticResource RoundButton}" Click="btnSave_Click" />
               <!--buttons-->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Top">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <RadioButton Name="rdoDatabaseSettings" Grid.Row="0" Grid.Column="0" Content="🧑‍💻" ToolTip="Admin" Checked="rdoSettings_Checked"/>
                        <RadioButton Name="rdoEnvironmentSettings" Grid.Row="1" Grid.Column="0" Content="🌍" ToolTip="Environment"  Checked="rdoSettings_Checked"/>
                        <RadioButton Name="rdoQuerySettings"  Grid.Row="2" Grid.Column="0" Content="📝"  ToolTip="Query"  Checked="rdoSettings_Checked"/>
                        <RadioButton Name="rdoDataGrowthSettings"  Grid.Row="3" Grid.Column="0" Content="📈"  ToolTip="Data Growth"   Checked="rdoSettings_Checked" Visibility="Collapsed"/>
                        <RadioButton Name="rdoLanguageSettings"  Grid.Row="4" Grid.Column="0" Content="🌐" ToolTip="Language / Locale"  Checked="rdoSettings_Checked"/>
                        <!--<RadioButton Name="rdoLocaleSettings"  Grid.Row="5" Grid.Column="0" Content="🗺" ToolTip="Locale"  Checked="rdoSettings_Checked"/>-->
                      
                        <RadioButton Name="rdoAboutSettings"  Grid.Row="6" VerticalAlignment="Bottom" Grid.Column="0" Content="🛈" ToolTip="About"  Checked="rdoSettings_Checked"/>


                        
                    </Grid>
                </StackPanel>
                <!--right side-->
                <DockPanel Grid.Column="1" Grid.ColumnSpan="4" Grid.Row="1" Grid.RowSpan="3">

                    <Border Style="{StaticResource grayBorders}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <local:DatabaseSettingsControl x:Name="databaseSettingsControl" Grid.Row="0" Visibility="Visible"/>
                            <local:EnvironmentSettingsControl x:Name="environmentSettingsControl" Grid.Row="0" Visibility="Visible"/>
                            <local:QuerySettingsControl x:Name="querySettingsControl" Grid.Row="0" Visibility="Visible"/>
                            <local:AboutSettingsControl x:Name="aboutSettingsControl" Grid.Row="0" Visibility="Visible"/>
                             <local:LanguageSettingsControl x:Name="languageSettingsControl" Grid.Row="0" Visibility="Visible"/>
                        </Grid>
                    </Border>

                </DockPanel>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
