<UserControl x:Class="DBTool.Controls.TenantsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" PreviewKeyDown="ScrollViewer_PreviewKeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="Tenants" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource headerLabel}"/>
        <DockPanel Grid.Column="0" Grid.Row="1" Grid.RowSpan="2">
            <StackPanel DockPanel.Dock="Left" Margin="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="450"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="lstViewTenants" Grid.Row="0" Grid.Column="0" SelectionMode="Single" Height="800" SelectionChanged="lstViewTenants_SelectionChanged"></ListView>

                </Grid>
            </StackPanel>
        </DockPanel>
        <StackPanel  Grid.Column="2" Grid.Row="1"  Width="auto">
            <Grid ShowGridLines="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Label Content="➕" Name="btnAdd" ToolTip="Add" Grid.Row="0" Grid.Column="1" Style="{StaticResource labelButton}" MouseDown="btnAdd_MouseDown"/>
                <Label Content="📋" Name="btnCopy" ToolTip="Copy" Grid.Row="0" Grid.Column="2" Style="{StaticResource labelButton}" MouseDown="btnCopy_MouseDown"/>
                <!--<Label Content="🔄" Name="btnUpdate" ToolTip="Update" Grid.Row="0" Grid.Column="3" Style="{StaticResource labelButton}" />-->
                <Label Content="🗑️" Name="btnDelete" ToolTip="Delete" Grid.Row="0" Grid.Column="3" Style="{StaticResource labelButton}" MouseDown="btnDelete_MouseDown"/>
                <Label Content="⛔" Name="btnCancel" ToolTip="Cancel" Grid.Row="0" Grid.Column="4" Style="{StaticResource labelButton}" MouseDown="btnCancel_MouseDown"/>

            </Grid>
            <StackPanel Margin="0,50,0,0" x:Name="stackPanelDetails">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="900"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Label Content="Id" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtId" Text="{Binding Id}" IsReadOnly="True"  Grid.Row="0" Grid.Column="1" Width="50" HorizontalAlignment="Left" Margin="5"/>

                    <Label Content="Tenant Name" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtTenantName" Text="{Binding TenantName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{StaticResource TextboxValidation}" Grid.Row="1" Grid.Column="1" Margin="5"/>

                    <Label x:Name="lblEndpoint" Content="Endpoint" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"  Visibility="Collapsed"/>
                    <TextBox x:Name="txtEndpoint" Grid.Row="2"  Visibility="Collapsed" Text="{Binding EndPoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="5"/>

                    <Label Content="Client Id" Grid.Row="3" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtClientId" Grid.Row="3" Text="{Binding ClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="5"/>

                    <Label Content="Client Secret" Grid.Row="4" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtClientSecret" Grid.Row="4" Text="{Binding ClientSecret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="5"/>

                    <Label Content="Resource" Grid.Row="5" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtResouce" Grid.Row="5" Text="{Binding Resource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="5"/>

                    <Label Content="Token URL" Grid.Row="6" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtTokenURL" Grid.Row="6" Text="{Binding TokenUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="5"/>

                    <Label Content="Username" Grid.Row="7" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtUsername" Grid.Row="7" Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="5"/>

                    <Label Content="Password" Grid.Row="8" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtPassword" Grid.Row="8"  Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Margin="5"/>

                    <Label Content="OAuth1" Grid.Row="9" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>

                    <CheckBox x:Name="rdoOAuth1" Grid.Row="9" Grid.Column="1" IsChecked="{Binding  isOAuth1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5" VerticalAlignment="Center"/>

                    <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" DataContext="{Binding SQLDBInfo}">
                        <GroupBox Header="SQL Database Info">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="Server" Style="{StaticResource commonLabel}" Margin="5"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtServer" Text="{Binding Server,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Username" Style="{StaticResource commonLabel}" Margin="5"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtServerUsername" Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                                
                                <Label Grid.Row="2" Grid.Column="0" Content="Password" Style="{StaticResource commonLabel}" Margin="5"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtServerPassword" Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

                                <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="Windows Authentication" HorizontalAlignment="Right" IsChecked="{Binding IsWindowsAuthentication, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </StackPanel>
     



    </Grid>
    </ScrollViewer>
</UserControl>
