<UserControl x:Class="DBTool.Controls.TranslationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="MainGrid" ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" LastChildFill="True">
            <Grid DockPanel.Dock="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <GroupBox Grid.Row="0" Grid.Column="0" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="200"/>
                            <RowDefinition Height="200"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="209*"/>
                            <ColumnDefinition Width="21*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Translation" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource headerLabel}"/>

                        <Label Content="Regions" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource commonLabel}"/>
                        <ComboBox x:Name="cmbRegion" Grid.Row="1"  Grid.Column="0" Grid.ColumnSpan="3" SelectionChanged="cmbRegion_SelectionChanged" Margin="0,31,0,0" Grid.RowSpan="2" />
                        <Label Content="Environments" Grid.Row="3" Visibility="Hidden"  Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource commonLabel}" Margin="0,25,0,31" Grid.RowSpan="3"/>
                        <local:ListViewResultControl x:Name="lstResult" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="5"
                                                    SelectionChangedExecute="lstViewEnvironment_SelectionChanged"/>
                        <local:ListViewResultControl x:Name="lstSchema" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"/>
                        <GroupBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Header="Options">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="chkRemoveMnemonic" Grid.Row="0" Grid.Column="0" Content="Remove mnemonic" Margin="5" Style="{StaticResource customCheckboxLabel}"/>
                                <CheckBox x:Name="chkRemoveExcludedKeys" Grid.Row="1" Grid.Column="0" Content="Remove excluded keys"  Margin="5" Style="{StaticResource customCheckboxLabel}"/>
                                <CheckBox x:Name="chkNewUpdatedLocaleOnly" Grid.Row="2" Grid.Column="0" Content="New / Updated locales only" Margin="5" Style="{StaticResource customCheckboxLabel}"/>
                                <CheckBox x:Name="chkIncludedLength" Grid.Row="3" Grid.Column="0" Content="Include length" Margin="5" Style="{StaticResource customCheckboxLabel}"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox  Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3" Header="Languages">

                            <local:ListViewResultControl x:Name="lstLanguage" Checkbox_Checked="HeaderCheckBox_Checked" UnCheckbox_Checked="HeaderCheckBox_Unchecked"/>
                        </GroupBox>
                        

                    </Grid>
                </GroupBox>

            </Grid>
        </DockPanel>
        <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"  HorizontalAlignment="Left"
             VerticalAlignment="Stretch"
             Background="DarkGray"
                     Width="2"
             ShowsPreview="True">

        </GridSplitter>
        <TabControl Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3">
            <TabItem Header="Extract Locale" Style="{StaticResource BaseTabItem}" Margin="-2,0,2,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="200"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="txtExcludedKeys" Grid.Row="0" Grid.Column="0" Margin="5" Grid.ColumnSpan="2" VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto" 
                             AcceptsReturn="True" TextWrapping="Wrap"/>
                    <Button x:Name="btnLoad" Content="Load" Grid.Row="1" Grid.Column="0" Margin="5" Style="{StaticResource RoundButton}" Click="btnLoad_Click"/>
                    <local:ListViewResultControl x:Name="lstLocale" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="5"/>
                </Grid>
            </TabItem>
            <TabItem Header="Compare to File" Style="{StaticResource BaseTabItem}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Label Content="Localization File" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <TextBox x:Name="txtCompareLocaleFile" Grid.Row="0" Grid.Column="1" Margin="5" IsReadOnly="True"/>
                    <Button x:Name="btnSelectLocaleFile" Content="Load File"
                            Click="btnSelectLocaleFile_Click"
                            Grid.Row="0" Grid.Column="2" Margin="5" Style="{StaticResource RoundButton}"/>

                    <Label Content="Available Sheets" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="5"/>
                    <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ComboBox x:Name="cmbAvailableSheets" Grid.Row="0" Grid.Column="0" Margin="5" Width="200" HorizontalAlignment="Left"/>
                        <Button x:Name="btnLoadSheet" Grid.Row="0" Grid.Column="1" Margin="5"
                                Click="btnLoadSheet_Click"
                                Content="Load Sheet" Style="{StaticResource RoundButton}"/>
                    </Grid>

                    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!--excel side-->
                        <Grid Grid.Row="0" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Sheet Data" Grid.Row="0" Grid.Column="0" Margin="5" Style="{StaticResource commonLabel}"/>
                            <local:ListViewResultControl x:Name="lstCompareExcelSheet" Grid.Row="1" Grid.Column="0" Margin="5"/>
                        </Grid>

                        <!--database side-->
                        <Grid Grid.Row="1" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Database Data" Grid.Row="0" Grid.Column="0" Margin="5" Style="{StaticResource commonLabel}"/>
                            <Button x:Name="btnCompare" Grid.Column="1" Grid.Row="0" Margin="5" Style="{StaticResource RoundButton}" Content="Compare" HorizontalAlignment="Right" Click="btnCompare_Click"/>
                            <local:ListViewResultControl x:Name="lstCompareDBData" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" Checkbox_Checked="lstCompareDBData_Checkbox_Checked" UnCheckbox_Checked="lstCompareDBData_UnCheckbox_Checked"/>
                        </Grid>

                    </Grid>
                    <Button x:Name="btnCompareExcelGenerateScript" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                            Margin="5" HorizontalAlignment="Right" Click="btnCompareExcelGenerateScript_Click"
                            Content="Generate Script" Style="{StaticResource RoundButton}"/>
                </Grid>
            </TabItem>
            <TabItem Header="Generate Script" Style="{StaticResource BaseTabItem}"></TabItem>
        </TabControl>
    </Grid>
</UserControl>
