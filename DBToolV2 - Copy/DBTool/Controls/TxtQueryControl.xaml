<UserControl x:Class="DBTool.Controls.TxtQueryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button x:Name="rdoExecute" Content="▶️ Execute" ToolTip="Execute" Grid.Row="0" Grid.Column="0" Margin="5" HorizontalAlignment="Left"
Click="Button_Click" Style="{StaticResource RoundButton}" VerticalAlignment="Top"/>
        <Border  Grid.Row="1" Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
            <avalon:TextEditor x:Name="txtQuery" PreviewMouseWheel="MyRichTextBox_PreviewMouseWheel"
FontSize="16"
                        BorderThickness="0,1,0,0"
                        HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
              PreviewKeyDown="txtQuery_PreviewKeyDown" VerticalContentAlignment="Top" VerticalAlignment="Stretch" 
                               MouseLeftButtonDown="txtQuery_MouseLeftButtonDown">
                <avalon:TextEditor.ContextMenu>
                    <ContextMenu  />
                </avalon:TextEditor.ContextMenu>
            </avalon:TextEditor>
        </Border>
    </Grid>
</UserControl>
