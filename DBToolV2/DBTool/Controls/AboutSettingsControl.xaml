<UserControl x:Class="DBTool.Controls.AboutSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Content="About" Grid.Row="0" Style="{StaticResource headerLabel}"/>

        <StackPanel Grid.Row="2" Margin="4">
            <TextBlock Text="🛢 DBTool" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontFamily="{StaticResource AppFont}"/>
            <TextBlock Text="Database Management Tool" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontFamily="{StaticResource AppFont}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="3" Margin="4,12,4,0" Padding="12" CornerRadius="8"
                Background="{DynamicResource DataGridHeaderBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Label x:Name="lblVersion" Content="Version" Style="{StaticResource commonLabel}"/>
        </Border>

        <!-- Update Section -->
        <Border Grid.Row="4" Margin="4,12,4,0" Padding="16" CornerRadius="8"
                Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="btnCheckUpdate" Content="Check for Updates" 
                            Style="{StaticResource RoundButton}" Click="btnCheckUpdate_Click"/>
                    <Label x:Name="lblUpdateStatus" Content="" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontFamily="{StaticResource AppFont}" FontSize="11"/>
                </StackPanel>

                <StackPanel x:Name="pnlUpdateAvailable" Visibility="Collapsed">
                    <TextBlock x:Name="txtNewVersion" Text="" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{StaticResource AppFont}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button x:Name="btnDownloadUpdate" Content="Download &amp; Install" 
                                Style="{StaticResource RoundButton}" Click="btnDownloadUpdate_Click"/>
                        <Button x:Name="btnViewChangelog" Content="View Changelog" 
                                Style="{StaticResource RoundButton}" Margin="8,0,0,0"
                                Click="btnViewChangelog_Click"/>
                    </StackPanel>
                    <ProgressBar x:Name="progressUpdate" Height="6" Margin="0,8,0,0"
                                 Visibility="Collapsed" Minimum="0" Maximum="100"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
