<UserControl x:Class="DBTool.Controls.ApiControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="180"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel (same style as EnvironmentControl) -->
        <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Margin="0,0,4,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Panel Header -->
                <Border Grid.Row="0" Background="{DynamicResource DataGridHeaderBgBrush}"
                        CornerRadius="12,12,0,0" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F310;" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="API Client" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Select a region and environment"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   FontFamily="{StaticResource AppFont}" Margin="28,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Region Selector -->
                <Border Grid.Row="1" Padding="14,12,14,8">
                    <StackPanel>
                        <TextBlock Text="REGION" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontFamily="{StaticResource AppFont}" Margin="2,0,0,6"/>
                        <ComboBox x:Name="cmbRegion" SelectionChanged="cmbRegion_SelectionChanged"/>
                    </StackPanel>
                </Border>

                <!-- Environment List + Schema List -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="80"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*" MinHeight="80"/>
                    </Grid.RowDefinitions>

                    <!-- Environments -->
                    <Border Grid.Row="0" Padding="8,0,8,4">
                        <local:ListViewResultControl x:Name="lstEnvironments"
                            SelectionChangedExecute="lstEnvironments_SelectionChanged"/>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch" Background="Transparent"
                                  ResizeDirection="Rows" ShowsPreview="True"
                                  Cursor="SizeNS" Focusable="False">
                        <GridSplitter.Style>
                            <Style TargetType="GridSplitter">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GridSplitter">
                                            <Border Background="Transparent" Height="6">
                                                <Border Height="2" Background="{DynamicResource BorderBrush}"
                                                        CornerRadius="1" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GridSplitter.Style>
                    </GridSplitter>

                    <!-- Schemas -->
                    <Border Grid.Row="2" Padding="8,4,8,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="SCHEMAS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontFamily="{StaticResource AppFont}" Margin="2,0,0,6"/>
                            <DataGrid x:Name="dgSchemas" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="False"
                                      SelectionMode="Single" SelectionUnit="FullRow"
                                      CanUserSortColumns="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="1"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="30">
                                        <DataGridCheckBoxColumn.Header>
                                            <CheckBox Checked="chkSelectAllSchemas_Checked" Unchecked="chkSelectAllSchemas_Unchecked"/>
                                        </DataGridCheckBoxColumn.Header>
                                    </DataGridCheckBoxColumn>
                                    <DataGridTextColumn Header="Schema" Binding="{Binding SchemaName}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Resizable Splitter -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" Background="Transparent"
                      ResizeDirection="Columns" ShowsPreview="True"
                      Panel.ZIndex="5" Cursor="SizeWE" Focusable="False">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="GridSplitter">
                                <Border Background="Transparent" Width="6">
                                    <Border Width="2" Background="{DynamicResource BorderBrush}"
                                            CornerRadius="1" HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <!-- Right: API Request/Response -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Request Section -->
            <Border Grid.Row="0" Style="{StaticResource grayBorders}" Margin="0,0,0,8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="cmbMethod" Grid.Column="0" SelectedIndex="0" Margin="0,0,8,0"
                                  VerticalContentAlignment="Center" FontWeight="SemiBold">
                            <ComboBoxItem Content="GET"/>
                            <ComboBoxItem Content="POST"/>
                            <ComboBoxItem Content="PUT"/>
                            <ComboBoxItem Content="PATCH"/>
                            <ComboBoxItem Content="DELETE"/>
                        </ComboBox>
                        <TextBox x:Name="txtUrl" Grid.Column="1" Margin="0,0,8,0"
                                 VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"/>
                        <Button x:Name="btnSend" Grid.Column="2" Content="Send" 
                                Style="{StaticResource RoundButton}" Click="btnSend_Click"/>
                    </Grid>

                    <Expander Grid.Row="1" Header="Headers (from environment)" IsExpanded="False" Margin="0,0,0,4">
                        <TextBox x:Name="txtHeaders" AcceptsReturn="True" TextWrapping="Wrap"
                                 FontFamily="Consolas" FontSize="11" MaxHeight="150"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Expander>

                    <Expander Grid.Row="2" Header="Request Body" IsExpanded="False" Margin="0,0,0,4">
                        <TextBox x:Name="txtRequestBody" AcceptsReturn="True" TextWrapping="Wrap"
                                 FontFamily="Consolas" FontSize="11" MinHeight="80" MaxHeight="200"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Expander>

                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                        <Label x:Name="lblStatus" Content="Ready" 
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontFamily="{StaticResource AppFont}" FontSize="11"/>
                        <Label x:Name="lblStatusCode" Content="" 
                               FontWeight="SemiBold"
                               FontFamily="{StaticResource AppFont}" FontSize="11"/>
                        <Label x:Name="lblElapsed" Content="" 
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontFamily="{StaticResource AppFont}" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Response Section -->
            <Border Grid.Row="1" Style="{StaticResource grayBorders}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Response" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                        <Button x:Name="btnCopy" Content="Copy" 
                                Style="{StaticResource RoundButton}" Margin="12,0,4,0"
                                Click="btnCopy_Click"/>
                        <Button x:Name="btnBeautify" Content="Beautify JSON" 
                                Style="{StaticResource RoundButton}" Margin="4,0,0,0"
                                Click="btnBeautify_Click"/>
                    </StackPanel>

                    <TextBox x:Name="txtResponse" Grid.Row="1"
                             IsReadOnly="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
