<UserControl x:Class="DBTool.Controls.ApplyFixControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Root Folder:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <TextBox x:Name="txtRootFolder" Width="300" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
            <Button Content="Browse" Style="{StaticResource RoundButton}" Click="BrowseFolder_Click"/>

            <TextBlock Text="Version:" VerticalAlignment="Center" Margin="16,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboVersion" Width="140" Margin="0,0,8,0"/>

            <TextBlock Text="Schema:" VerticalAlignment="Center" Margin="8,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboSchema" Width="80" SelectedIndex="0">
                <ComboBoxItem Content="FSH"/>
                <ComboBoxItem Content="SCAH"/>
            </ComboBox>

            <Button Content="Scan" Style="{StaticResource RoundButton}" Click="FixScan_Click" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Summary -->
        <Border Grid.Row="1" Style="{StaticResource grayBorders}" Padding="10" Margin="0,0,0,8">
            <TextBlock x:Name="txtSummary" Text="Select a folder, version, and schema, then scan for missing scripts." TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" FontSize="12"/>
        </Border>

        <!-- Fix Items DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgFixItems" AutoGenerateColumns="False" IsReadOnly="False"
                  CanUserSortColumns="True" SelectionChanged="DgFixItems_SelectionChanged"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Source File" Binding="{Binding SourceFile}" Width="220" IsReadOnly="True"/>
                <DataGridTextColumn Header="Target File" Binding="{Binding TargetFile}" Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Header="Script" Binding="{Binding Label}" Width="*" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch" Background="Transparent"
                      ResizeDirection="Rows" ShowsPreview="True" Cursor="SizeNS"/>

        <!-- Script Preview -->
        <Border Grid.Row="4" Style="{StaticResource grayBorders}" Padding="8">
            <TextBox x:Name="txtScriptPreview" IsReadOnly="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11"
                     Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderThickness="0"/>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Select All" Style="{StaticResource RoundButton}" Click="FixSelectAll_Click"/>
            <Button Content="Deselect All" Style="{StaticResource RoundButton}" Click="FixDeselectAll_Click"/>
            <Button Content="Apply Selected" Style="{StaticResource RoundButton}" Click="FixApply_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
