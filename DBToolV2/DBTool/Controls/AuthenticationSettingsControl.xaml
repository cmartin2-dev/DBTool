<UserControl x:Class="DBTool.Controls.AuthenticationSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" PreviewKeyDown="ScrollViewer_PreviewKeyDown">
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" x:Name="accessRow"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Authentication" Style="{StaticResource headerLabel}" Margin="0,0,0,12"/>

            <Label Grid.Row="1" Grid.Column="0" Content="Server" Style="{StaticResource commonLabel}" Margin="4"/>
            <Label Grid.Row="2" Grid.Column="0" Content="Username" Style="{StaticResource commonLabel}" Margin="4"/>
            <Label Grid.Row="3" Grid.Column="0" Content="Password" Style="{StaticResource commonLabel}" Margin="4"/>
            <Label Grid.Row="4" Grid.Column="0" Content="Windows Auth" Style="{StaticResource commonLabel}" Margin="4"/>
            <Label Grid.Row="5" Grid.Column="0" x:Name="lblFullAccess" Content="Full Access" Visibility="Hidden" Style="{StaticResource commonLabel}" Margin="4"/>

            <TextBox x:Name="txtServer" Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                     Grid.Row="1" Grid.Column="1" Margin="4"/>
            <TextBox x:Name="txtUsername" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Grid.Row="2" Grid.Column="1" Margin="4"/>
            <TextBox x:Name="txtPassword" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                     Grid.Row="3" Grid.Column="1" Margin="4"/>
            <CheckBox Name="chkWindowsAuthentication" Grid.Row="4" Grid.Column="1"
                      IsChecked="{Binding IsWindowsAuthentication, UpdateSourceTrigger=PropertyChanged}"
                      VerticalAlignment="Center" Margin="4,8"/>
            <CheckBox Name="chkIsFullAccess" Grid.Row="5" Grid.Column="1" Visibility="Hidden"
                      IsChecked="{Binding IsFullAccess, UpdateSourceTrigger=PropertyChanged}"
                      VerticalAlignment="Center" Margin="4,8"/>
        </Grid>
    </ScrollViewer>
</UserControl>
