<UserControl x:Class="DBTool.Controls.CompareVersionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Root Folder:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <TextBox x:Name="txtRootFolder" Width="220" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
            <Button Content="Browse" Style="{StaticResource RoundButton}" Click="BrowseFolder_Click"/>

            <TextBlock Text="Version A:" VerticalAlignment="Center" Margin="16,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboVersionA" Width="120" Margin="0,0,8,0" SelectionChanged="CboVersionA_SelectionChanged"/>

            <TextBlock Text="Version B:" VerticalAlignment="Center" Margin="8,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboVersionB" Width="120" Margin="0,0,8,0"/>

            <TextBlock Text="Schema:" VerticalAlignment="Center" Margin="8,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboSchema" Width="80" SelectedIndex="0" SelectionChanged="CboSchema_SelectionChanged">
                <ComboBoxItem Content="FSH"/>
                <ComboBoxItem Content="SCAH"/>
            </ComboBox>

            <TextBlock Text="File:" VerticalAlignment="Center" Margin="8,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboFile" Width="200" Margin="0,0,8,0"/>

            <Button Content="Compare" Style="{StaticResource RoundButton}" Click="Compare_Click"/>
        </StackPanel>

        <!-- Summary -->
        <Border Grid.Row="1" Style="{StaticResource grayBorders}" Padding="10" Margin="0,0,0,8">
            <TextBlock x:Name="txtSummary" Text="Select a folder, versions, schema, and file to compare." TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" FontSize="12"/>
        </Border>

        <!-- Side-by-side script panels -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Version A -->
            <Border Grid.Column="0" Style="{StaticResource grayBorders}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="txtHeaderA" Text="Version A" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtContentA" Grid.Row="1" IsReadOnly="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"
                          ResizeDirection="Columns" Cursor="SizeWE"/>

            <!-- Version B -->
            <Border Grid.Column="2" Style="{StaticResource grayBorders}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="txtHeaderB" Text="Version B" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtContentB" Grid.Row="1" IsReadOnly="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
