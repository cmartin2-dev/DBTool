<UserControl x:Class="DBTool.Controls.CompressFdbControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Browse + Version + CREATE/UPGRADE + Compress -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Browse" Style="{StaticResource RoundButton}" Click="BrowseFolder_Click"/>
            <TextBox x:Name="txtRootFolder" Width="280" IsReadOnly="True" VerticalContentAlignment="Center" Margin="8,0,8,0"/>

            <TextBlock Text="Version:" VerticalAlignment="Center" Margin="8,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboVersion" Width="140" Margin="0,0,8,0"/>

            <CheckBox x:Name="chkCreate" Content="CREATE" VerticalAlignment="Center" Margin="8,0,0,0" IsChecked="True"/>
            <CheckBox x:Name="chkUpgrade" Content="UPGRADE" VerticalAlignment="Center" Margin="8,0,0,0" IsChecked="True"/>

            <Button Content="Compress" Style="{StaticResource RoundButton}" Click="CompressFdb_Click" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- Row 1: AWS settings -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="AWS Profile:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboAwsProfile" Width="160" Margin="0,0,16,0"/>

            <TextBlock Text="Region:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <TextBox x:Name="txtAwsRegion" Width="120" Text="ap-southeast-1" VerticalContentAlignment="Center" Margin="0,0,16,0"/>

            <TextBlock Text="Bucket:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <TextBox x:Name="txtS3Bucket" Width="160" VerticalContentAlignment="Center" Margin="0,0,16,0"/>

            <TextBlock Text="Prefix:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <TextBox x:Name="txtS3Prefix" Width="140" Text="SQLSERVER/" VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Row 2: Summary -->
        <Border Grid.Row="2" Style="{StaticResource grayBorders}" Padding="10" Margin="0,0,0,8">
            <TextBlock x:Name="txtSummary" Text="Select a root folder, version, and click Compress to create FDB files." TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" FontSize="12"/>
        </Border>

        <!-- Row 3: DataGrid -->
        <DataGrid Grid.Row="3" x:Name="dgFdbResults" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Folder" Binding="{Binding Folder}" Width="100"/>
                <DataGridTextColumn Header="Schema" Binding="{Binding Schema}" Width="80"/>
                <DataGridTextColumn Header="Output File" Binding="{Binding OutputPath}" Width="220"/>
                <DataGridTextColumn Header="S3 Path" Binding="{Binding S3Path}" Width="280"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" Width="80"/>
                <DataGridTextColumn Header="S3 Status" Binding="{Binding S3Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="4" HorizontalAlignment="Stretch" Background="Transparent"
                      ResizeDirection="Rows" ShowsPreview="True" Cursor="SizeNS"/>

        <!-- Row 5: Console log -->
        <Border Grid.Row="5" Style="{StaticResource grayBorders}" Padding="4">
            <TextBox x:Name="txtConsoleLog" IsReadOnly="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11"
                     Background="#1E1E1E" Foreground="#DCDCDC"
                     BorderThickness="0"/>
        </Border>

        <!-- Row 6: Upload button -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Upload to S3" Style="{StaticResource RoundButton}" Click="UploadS3_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
