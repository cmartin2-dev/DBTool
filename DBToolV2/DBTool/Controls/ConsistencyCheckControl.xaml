<UserControl x:Class="DBTool.Controls.ConsistencyCheckControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Root Folder:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <TextBox x:Name="txtRootFolder" Width="300" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
            <Button Content="Browse" Style="{StaticResource RoundButton}" Click="BrowseFolder_Click"/>
            <TextBlock Text="Version:" VerticalAlignment="Center" Margin="16,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboVersion" Width="140" Margin="0,0,8,0"/>
            <TextBlock Text="Schema:" VerticalAlignment="Center" Margin="8,0,8,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <ComboBox x:Name="cboSchema" Width="80" SelectedIndex="0">
                <ComboBoxItem Content="FSH"/>
                <ComboBoxItem Content="SCAH"/>
            </ComboBox>
            <Button Content="Analyze" Style="{StaticResource RoundButton}" Click="Analyze_Click" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Summary -->
        <Border Grid.Row="1" Style="{StaticResource grayBorders}" Padding="10" Margin="0,0,0,8">
            <TextBlock x:Name="txtSummary" Text="Select a folder, version, and schema to begin." TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" FontSize="12"/>
        </Border>

        <!-- Results Grid -->
        <DataGrid Grid.Row="2" x:Name="dgResults" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" SelectionChanged="DgResults_SelectionChanged"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File Type" Binding="{Binding FileType}" Width="130"/>
                <DataGridTextColumn Header="Change Type" Binding="{Binding ChangeType}" Width="110"/>
                <DataGridTextColumn Header="Object Name" Binding="{Binding ObjectName}" Width="180"/>
                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Changeset ID" Binding="{Binding ChangesetId}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch" Background="Transparent"
                      ResizeDirection="Rows" ShowsPreview="True" Cursor="SizeNS"/>

        <!-- Script Preview -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource grayBorders}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="txtUpgradeHeader" Text="UPGRADE Script" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtUpgradeScript" Grid.Row="1" IsReadOnly="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"
                          ResizeDirection="Columns" Cursor="SizeWE"/>

            <Border Grid.Column="2" Style="{StaticResource grayBorders}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="txtCreateHeader" Text="CREATE Script" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtCreateScript" Grid.Row="1" IsReadOnly="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Export buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock x:Name="txtResultCount" VerticalAlignment="Center" Margin="0,0,16,0"
                       Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"/>
            <Button Content="Export CSV" Style="{StaticResource RoundButton}" Click="ExportCsv_Click"/>
            <Button Content="Export Excel" Style="{StaticResource RoundButton}" Click="ExportExcel_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
