<UserControl x:Class="DBTool.Controls.CustomControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Connection bar -->
        <Border Grid.Row="0" Style="{StaticResource grayBorders}" Margin="0,0,0,4" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Content="Database" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                <RadioButton x:Name="rdoMSSQL" Grid.Row="0" Grid.Column="1" Content="MS SQL" FontSize="14" Margin="4"
                             HorizontalAlignment="Left" Checked="rdoMSSQL_Checked"/>
                <RadioButton x:Name="rdoPostgre" Grid.Row="0" Grid.Column="2" Content="Postgre SQL" FontSize="14" Margin="4"
                             HorizontalAlignment="Left" Checked="rdoPostgre_Checked"/>
                <Label Content="Server" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                <ComboBox x:Name="cmbServer" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Width="200"
                          HorizontalAlignment="Left" Margin="4" SelectionChanged="cmbServer_SelectionChanged"/>
                <Label Content="Database Name" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                <ComboBox x:Name="cmbDatabase" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Width="200"
                          HorizontalAlignment="Left" Margin="4"/>
            </Grid>
        </Border>

        <!-- Query editor -->
        <local:TxtQueryControl x:Name="txtQueryControl" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
                                Margin="0,4" Execute="txtQueryControl_Execute"/>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" Height="3" Margin="4"
                      Background="{DynamicResource BorderBrush}" ResizeDirection="Rows" ShowsPreview="True"/>

        <!-- Results -->
        <local:ListViewResultControl x:Name="lstResult" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,4"/>
    </Grid>
</UserControl>
