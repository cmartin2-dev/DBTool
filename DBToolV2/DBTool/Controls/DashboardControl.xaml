<UserControl x:Class="DBTool.Controls.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <Label Content="Dashboard" Style="{StaticResource headerLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="4,4,0,0">
                    <TextBlock Text="&#x1F464;" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtCurrentUser" Text="" FontSize="13" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                    <Border x:Name="badgeAccess" CornerRadius="8" Padding="8,2" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="txtAccessLevel" Text="" FontSize="10" FontWeight="SemiBold"
                                   FontFamily="{StaticResource AppFont}"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Stats Cards -->
            <WrapPanel Grid.Row="1" Margin="0,0,0,16" Orientation="Horizontal">
                <Border Style="{StaticResource grayBorders}" Width="180" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="&#x1F30D;" FontSize="22" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtRegionCount" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Regions" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource grayBorders}" Width="180" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="&#x1F4E1;" FontSize="22" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtEnvironmentCount" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Environments" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource grayBorders}" Width="180" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="&#x1F4DD;" FontSize="22" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtQueryCount" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Saved Queries" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource grayBorders}" Width="180" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="&#x1F5E3;" FontSize="22" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtLanguageCount" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Languages" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource grayBorders}" Width="180" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="&#x1F5A5;" FontSize="22" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtServerCount" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="Servers" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Recent Script Executions -->
            <Border Grid.Row="2" Style="{StaticResource grayBorders}" Margin="0,0,0,16" Padding="18,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Recent Script Executions" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}" Margin="0,0,0,10"/>

                    <ListBox x:Name="lstRecentScripts" Grid.Row="1" 
                             SelectionChanged="lstRecentScripts_SelectionChanged"
                             MouseDoubleClick="lstRecentScripts_MouseDoubleClick"
                             BorderThickness="0" Background="Transparent" MaxHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TenantId}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}" FontFamily="{StaticResource AppFont}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Comment}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="{StaticResource AppFont}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DateExecuted}" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBox x:Name="txtQueryPreview" Grid.Row="2" 
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             MaxHeight="150" Margin="0,8,0,0"
                             FontFamily="Consolas" FontSize="11"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                </Grid>
            </Border>

            <!-- Top Tenants by Script Executions -->
            <Border Grid.Row="3" Style="{StaticResource grayBorders}" Margin="0,0,0,16" Padding="18,14">
                <StackPanel>
                    <TextBlock Text="Top Tenants by Script Executions" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="lstTopTenants">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,0,0,4" CornerRadius="6"
                                        Background="{DynamicResource SurfaceBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TenantId}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}" FontFamily="{StaticResource AppFont}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <Border Grid.Column="3" Margin="12,2,0,2" CornerRadius="3" Height="12"
                                                HorizontalAlignment="Left" Width="{Binding BarWidth}"
                                                Background="{DynamicResource AccentBrush}" Opacity="0.3"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
