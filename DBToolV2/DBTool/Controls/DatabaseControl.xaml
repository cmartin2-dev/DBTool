<UserControl x:Class="DBTool.Controls.DatabaseControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="Database" Style="{StaticResource headerLabel}" Margin="4,0,4,8"/>
        <TabControl Grid.Row="1">
            <TabItem Header="ERD" Style="{StaticResource BaseTabItem}">
                <local:ErdControl x:Name="erdControl"/>
            </TabItem>
            <TabItem Header="Consistency Check" Style="{StaticResource BaseTabItem}">
                <local:ConsistencyCheckControl x:Name="consistencyCheckControl"/>
            </TabItem>
            <TabItem Header="Compare Versions" Style="{StaticResource BaseTabItem}">
                <local:CompareVersionsControl x:Name="compareVersionsControl"/>
            </TabItem>
            <TabItem Header="Apply Fix" Style="{StaticResource BaseTabItem}">
                <local:ApplyFixControl x:Name="applyFixControl"/>
            </TabItem>
            <TabItem Header="Compress FDB" Style="{StaticResource BaseTabItem}">
                <local:CompressFdbControl x:Name="compressFdbControl"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
