<UserControl x:Class="DBTool.Controls.DropVersionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}">
            <TextBlock Text="{Binding tenantId}"/>
        </Label>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
            <Button x:Name="btnGetSchema" Content="Get Versions" Style="{StaticResource RoundButton}"
                    Margin="4" Click="btnGetSchema_Click"/>
            <Button x:Name="btnDropSchema" Content="Drop Version" Style="{StaticResource RoundButton}"
                    Margin="4" Click="btnDropSchema_Click"
                    Background="{DynamicResource DangerBrush}"/>
        </StackPanel>

        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource grayBorders}" Margin="0,4" Padding="0">
            <local:ListViewResultControl x:Name="lstResult"
                                         Checkbox_Checked="lstResult_Checkbox_Checked"
                                         UnCheckbox_Checked="lstResult_UnCheckbox_Checked"/>
        </Border>
    </Grid>
</UserControl>
