<UserControl x:Class="DBTool.Controls.EnvironmentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:local2="clr-namespace:DBTool"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.CommandBindings>
        <CommandBinding Command="{x:Static local:EnvironmentControl.CreateTabCommand}"
                        Executed="CreateTabCommand_Executed" />
    </UserControl.CommandBindings>
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftPanelColumn" Width="300" MinWidth="180"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <Border x:Name="LeftPanelBorder" Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Margin="0,0,4,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Panel Header -->
                <Border Grid.Row="0" Background="{DynamicResource DataGridHeaderBgBrush}"
                        CornerRadius="12,12,0,0" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F30D;" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Environments" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Select a region to view environments"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                   FontFamily="{StaticResource AppFont}" Margin="28,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Region Selector -->
                <Border Grid.Row="1" Padding="14,12,14,8">
                    <StackPanel>
                        <TextBlock Text="REGION" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontFamily="{StaticResource AppFont}" Margin="2,0,0,6"/>
                        <ComboBox x:Name="cmbRegion" SelectionChanged="cmbRegion_SelectionChanged"/>
                    </StackPanel>
                </Border>

                <!-- Environment List -->
                <Border Grid.Row="2" Padding="8,0,8,8">
                    <local:ListViewResultControl x:Name="lstResult"
                        SelectionChangedExecute="lstViewEnvironment_SelectionChanged"
                        UnCheckbox_Checked="HeaderCheckBox_Unchecked" Checkbox_Checked="HeaderCheckBox_Checked"/>
                </Border>
            </Grid>
        </Border>

        <!-- Resizable Splitter -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" Background="Transparent" 
                      ResizeDirection="Columns" ShowsPreview="True"
                      Panel.ZIndex="5" Cursor="SizeWE" Focusable="False">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="GridSplitter">
                                <Border Background="Transparent" Width="6">
                                    <Border Width="2" Background="{DynamicResource BorderBrush}"
                                            CornerRadius="1" HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <!-- Toggle button overlaid on splitter area -->
        <Button x:Name="btnTogglePanel" Grid.Column="1" Click="BtnTogglePanel_Click"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Width="24" Height="40" Cursor="Hand" ToolTip="Toggle panel"
                Margin="-9,0,-9,0" Panel.ZIndex="10" Focusable="False">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="toggleBg" Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Width="24" Height="40">
                        <Path x:Name="toggleArrow" Data="M8,0 L0,6 L8,12"
                              Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="1.5"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="toggleBg" Property="Background" Value="{DynamicResource MenuHoverBrush}"/>
                            <Setter TargetName="toggleBg" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="toggleArrow" Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Right panel -->
        <TabControl x:Name="tabMainControl" Grid.Column="2" SelectionChanged="TabControl_SelectionChanged"
                    PreviewKeyDown="tabMainControl_PreviewKeyDown">
            <TabItem Header="&#x1F4DD;  Query" x:Name="QueryTab" Style="{StaticResource BaseTabItem}">
                <TabControl x:Name="MainTabQueryControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </TabItem>
            <TabItem Header="&#x1F4CA;  Query per Schema" x:Name="QueryPerSchemaTab" Style="{StaticResource BaseTabItem}">
                <local:QueryPerSchemaControl x:Name="queryPerSchemaControl"/>
            </TabItem>
            <TabItem Header="&#x1F527;  Feature Toggle" x:Name="FeaureToggleTab" Style="{StaticResource BaseTabItem}">
                <local:FeatureToggleControl x:Name="featureToggleControl"/>
            </TabItem>
            <TabItem Header="&#x1F5D1;  Drop Version" x:Name="DropVersionTab" Style="{StaticResource BaseTabItem}">
                <local:DropVersionControl x:Name="dropVersionControl"/>
            </TabItem>
            <TabItem Header="&#x1F4E6;  Extract Table" x:Name="ExtractTableTab" Style="{StaticResource BaseTabItem}">
                <local:ExtractTableControl x:Name="extractTableControl"/>
            </TabItem>
            <TabItem Header="&#x2B06;  Upgrade" x:Name="UpgradeTab" Style="{StaticResource BaseTabItem}">
                <local:UpgradeControl x:Name="upgradeControl"/>
            </TabItem>
            <TabItem Header="&#x1F4CB;  Execution Log" x:Name="ExecutionLogTab" Style="{StaticResource BaseTabItem}">
                <local:ExecutionLogControl x:Name="executionLogControl"/>
            </TabItem>
            <TabItem Header="&#x2699;  Custom" x:Name="CustomCSTab" Visibility="Hidden" Style="{StaticResource BaseTabItem}">
                <local:CustomControl x:Name="customControl"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
