<UserControl x:Class="DBTool.Controls.EnvironmentServerSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Content="Environment Server" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource headerLabel}" Margin="0,0,0,12"/>

        <!-- Server list -->
        <Border Grid.Column="0" Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="0"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0">
            <ListView x:Name="lstViewServer" SelectionMode="Single" SelectionChanged="lstViewServer_SelectionChanged"/>
        </Border>

        <!-- Detail panel -->
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Action buttons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Label Content="➕" Name="btnAdd" ToolTip="Add" Style="{StaticResource labelButton}" MouseDown="btnAdd_MouseDown" Margin="4"/>
                <Label Content="📋" Name="btnCopy" ToolTip="Copy" Style="{StaticResource labelButton}" MouseDown="btnCopy_MouseDown" Margin="4"/>
                <Label Content="🗑️" Name="btnDelete" ToolTip="Delete" Style="{StaticResource labelButton}" MouseDown="btnDelete_MouseDown" Margin="4"/>
                <Label Content="⛔" Name="btnCancel" ToolTip="Cancel" Style="{StaticResource labelButton}" MouseDown="btnCancel_MouseDown" Margin="4"/>
            </StackPanel>

            <!-- Details form -->
            <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="stackPanelDetails">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Label Content="Id" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtId" Text="{Binding Id}" IsReadOnly="True" Grid.Row="0" Grid.Column="1"
                                     Width="60" HorizontalAlignment="Left" Margin="4"/>

                            <Label Content="Server" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtServer" Text="{Binding ServerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Grid.Row="1" Grid.Column="1" Margin="4" Style="{StaticResource TextboxValidation}"/>

                            <Label Content="Databases" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <DataGrid ItemsSource="{Binding Databases}" Grid.Column="1" Grid.Row="2" MinHeight="100"
                                      SelectionMode="Single" Margin="4" AutoGenerateColumns="False" CanUserAddRows="True"
                                      HeadersVisibility="Column" RowHeaderWidth="0" SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Database Name" Binding="{Binding DatabaseName}"/>
                                    <DataGridTextColumn Header="Username" Binding="{Binding Username}"/>
                                    <DataGridTextColumn Header="Password" Binding="{Binding Password}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
