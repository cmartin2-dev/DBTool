<UserControl x:Class="DBTool.Controls.ErdControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button x:Name="btnLoadDLL" Content="Load" Style="{StaticResource RoundButton}"
                Click="btnLoadDLL_Click" Margin="4" HorizontalAlignment="Left"/>
        <local:ListViewResultControl x:Name="lstEntityResults" Grid.Row="1" Grid.Column="0" Margin="4"
                                     SelectionChangedExecute="lstEntityResults_SelectionChangedExecute"/>
        <GridSplitter Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" ShowsPreview="True" Width="1" Margin="4,0"/>
        <TabControl Grid.Column="2" Grid.RowSpan="2" Margin="4">
            <TabItem Header="Object Checker" Style="{StaticResource BaseTabItem}">
                <local:ObjectCheckerControl x:Name="objectCheckerControl"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
