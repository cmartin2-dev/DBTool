<UserControl x:Class="DBTool.Controls.ExecutionLogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Log Grid -->
        <Border Grid.Row="0" Style="{StaticResource grayBorders}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Execution Log" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtSearch" Width="200" Margin="12,0,4,0"
                             VerticalContentAlignment="Center" FontSize="11"
                             TextChanged="txtSearch_TextChanged"/>
                    <TextBlock Text="  search" FontSize="10"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                    <Button x:Name="btnRefresh" Content="Refresh" 
                            Style="{StaticResource RoundButton}" Margin="12,0,0,0"
                            Click="btnRefresh_Click"/>
                    <Button x:Name="btnClearLog" Content="Clear Log" 
                            Style="{StaticResource RoundButton}" Margin="4,0,0,0"
                            Click="btnClearLog_Click"
                            Background="{DynamicResource DangerBrush}"/>
                </StackPanel>

                <DataGrid x:Name="dgLog" Grid.Row="1" 
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          SelectionChanged="dgLog_SelectionChanged"
                          CanUserSortColumns="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource BorderBrush}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding DateExecuted}" Width="140"/>
                        <DataGridTextColumn Header="Tenant" Binding="{Binding TenantId}" Width="120"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70"/>
                        <DataGridTextColumn Header="Schema" Binding="{Binding SchemaName}" Width="80"/>
                        <DataGridTextColumn Header="Changeset" Binding="{Binding ChangesetId}" Width="200"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Comment}" Width="*"/>
                        <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="200"/>
                        <DataGridTextColumn Header="User" Binding="{Binding ExecutedBy}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" Background="Transparent"
                      ResizeDirection="Rows" ShowsPreview="True"
                      Cursor="SizeNS" Focusable="False">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="GridSplitter">
                                <Border Background="Transparent" Height="6">
                                    <Border Height="2" Background="{DynamicResource BorderBrush}"
                                            CornerRadius="1" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <!-- Query Preview -->
        <Border Grid.Row="2" Style="{StaticResource grayBorders}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Query" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontFamily="{StaticResource AppFont}" Margin="0,0,0,6"/>
                <TextBox x:Name="txtQueryPreview" Grid.Row="1"
                         IsReadOnly="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderThickness="0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
