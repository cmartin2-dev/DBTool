<UserControl x:Class="DBTool.Controls.ExtractTableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tenant label -->
        <Label Style="{StaticResource commonLabel}" Grid.Row="0" Margin="4">
            <TextBlock Text="{Binding tenantId}"/>
        </Label>

        <!-- Schema section -->
        <Border Grid.Row="1" Style="{StaticResource grayBorders}" Margin="4" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button x:Name="btnFetchSchema" Content="Fetch Schema" Grid.Row="0"
                        Style="{StaticResource RoundButton}" Margin="8" HorizontalAlignment="Left"
                        Click="btnFetchSchema_ClickAsync"/>
                <local:ListViewResultControl x:Name="lstViewSchema" Grid.Row="1" Margin="4"
                    SelectionChangedExecute="lstViewSchema_SelectionChangedExecute"/>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Height="3" Margin="4" Background="{StaticResource BorderBrush}"
                      ResizeDirection="Rows" ShowsPreview="True"/>

        <!-- Tables section -->
        <Border Grid.Row="3" Style="{StaticResource grayBorders}" Margin="4" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnGetTable" Content="Get Tables" Grid.Column="0"
                            Style="{StaticResource RoundButton}" Click="btnGetTable_Click"/>
                    <Label Content="Records per file (Max 5000)" Grid.Column="2"
                           Style="{StaticResource commonLabel}" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBox x:Name="txtMaxRecord" Grid.Column="3" Width="60" VerticalAlignment="Center"
                             TextChanged="txtMaxRecord_TextChanged"
                             PreviewTextInput="txtMaxRecord_PreviewTextInput"
                             PreviewKeyDown="txtMaxRecord_PreviewKeyDown"/>
                    <Button x:Name="btnExtractTable" Grid.Column="4" Content="Extract Table"
                            Style="{StaticResource RoundButton}" Click="btnExtractTable_Click" Margin="4,0,0,0"/>
                </Grid>

                <local:ListViewResultControl x:Name="tabResult" Grid.Row="1" Margin="4"
                    Checkbox_Checked="HeaderCheckBox_Checked"
                    UnCheckbox_Checked="HeaderCheckBox_Unchecked"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
