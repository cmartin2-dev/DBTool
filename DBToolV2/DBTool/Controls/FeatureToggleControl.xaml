<UserControl x:Class="DBTool.Controls.FeatureToggleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tenant header -->
        <Label x:Name="lblTenantName" Grid.Column="0" Grid.Row="0" Style="{StaticResource commonLabel}" Margin="4">
            <TextBlock Text="{Binding tenantId}"/>
        </Label>

        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Action bar -->
            <Button x:Name="btnGetToggle" Content="Get Feature Toggle" Grid.Column="0" Grid.Row="0"
                    Style="{StaticResource RoundButton}" Margin="4"
                    Click="btnGetToggle_Click"/>

            <!-- List -->
            <local:ListViewResultControl x:Name="lstResult" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                         SelectionChangedExecute="lstResult_SelectionChangedExecute"/>

            <!-- Splitter -->
            <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Width="3" Background="{DynamicResource BorderBrush}"
                          ShowsPreview="True"/>

            <!-- Detail panel -->
            <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Style="{StaticResource grayBorders}" Margin="4">
                <GroupBox Header="Details" x:Name="grpDetail">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button x:Name="btnSave" Grid.Column="1" Grid.Row="0" Content="Save"
                                Click="btnSave_Click" Style="{StaticResource RoundButton}"
                                Margin="4" HorizontalAlignment="Right"/>

                        <Label Content="Id" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}"/>
                        <Label Content="Key" Grid.Row="3" Grid.Column="0" Style="{StaticResource commonLabel}"/>
                        <Label Content="Display Name" Grid.Row="4" Grid.Column="0" Style="{StaticResource commonLabel}"/>
                        <Label Content="Enabled" Grid.Row="5" Grid.Column="0" Style="{StaticResource commonLabel}"/>
                        <Label Content="Visible" Grid.Row="6" Grid.Column="0" Style="{StaticResource commonLabel}"/>
                        <Label Content="Description" Grid.Row="7" Grid.Column="0" Style="{StaticResource commonLabel}"/>
                        <Label Content="Version" Grid.Row="8" Grid.Column="0" Style="{StaticResource commonLabel}"/>
                        <Label Content="Expiry Date" Grid.Row="9" Grid.Column="0" Style="{StaticResource commonLabel}"/>
                        <Label Content="Format (MM/dd/yyyy)" FontSize="8" FontStyle="Italic" Grid.Row="10" Grid.Column="1"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                        <TextBox x:Name="txtId" Grid.Row="2" Text="{Binding APPFEATUREID}" Grid.Column="1"
                                 Width="60" HorizontalAlignment="Left" Margin="4" IsReadOnly="True"/>
                        <TextBox x:Name="txtKey" Grid.Row="3" Grid.Column="1"
                                 Text="{Binding KEY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                        <TextBox x:Name="txtDisplayName" Grid.Row="4" Grid.Column="1"
                                 Text="{Binding DISPLAYNAME, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                        <CheckBox x:Name="chkEnabled" Grid.Row="5" Grid.Column="1"
                                  IsChecked="{Binding ENABLED, UpdateSourceTrigger=PropertyChanged}" Margin="4,8"/>
                        <CheckBox x:Name="chkVisible" Grid.Row="6" Grid.Column="1"
                                  IsChecked="{Binding VISIBLE, UpdateSourceTrigger=PropertyChanged}" Margin="4,8"/>
                        <TextBox x:Name="txtDescription" Grid.Row="7" Grid.Column="1"
                                 Text="{Binding DESCRIPTION, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                        <TextBox x:Name="txtVersion" Grid.Row="8" Grid.Column="1"
                                 Text="{Binding VERSION, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                        <TextBox x:Name="txtExpiryDate" Grid.Row="9" Grid.Column="1"
                                 Text="{Binding EXPIRYDATE, StringFormat='{}{0:MM/dd/yyyy}', UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                    </Grid>
                </GroupBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
