<UserControl x:Class="DBTool.Controls.ListViewResultControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="800">
    <Border Background="{DynamicResource CardBrush}" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Padding="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="8,8,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtSearch" Grid.Column="0" Style="{StaticResource WatermarkTextBox1}"
                         TextChanged="txtSearch_TextChanged"/>
                <Label x:Name="lblTotalCount" Content="Total Count : 0" Grid.Column="1"
                       Style="{StaticResource commonLabel}" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <DockPanel Grid.Row="1">
                <DataGrid x:Name="dataGrid1" AutoGenerateColumns="False"
                          EnableRowVirtualization="True" EnableColumnVirtualization="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                          SelectionMode="Extended"
                          CellEditEnding="dataGrid1_CellEditEnding"
                          SelectionChanged="dataGrid1_SelectionChanged"/>
            </DockPanel>

            <local:LoadingControl x:Name="loadingControl" Grid.Row="1"/>

            <Label x:Name="lblProgress" Content="Status : Idle" Grid.Row="2"
                   Style="{StaticResource commonLabel}" Margin="8,2,8,4" FontSize="11"/>
        </Grid>
    </Border>
</UserControl>
