<UserControl x:Class="DBTool.Controls.LogDBExecutePRDControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="4,0,4,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <Label Content="Query Log" Style="{StaticResource headerLabel}" Padding="4,4,4,2"/>
                <TextBlock Text="View and manage executed query logs"
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           FontFamily="{StaticResource AppFont}" Margin="8,0,0,0"/>
            </StackPanel>

            <Button x:Name="btnGetLog" Grid.Column="1" Content="&#x1F4E5;  Load Logs"
                    Click="btnGetLog_Click" Style="{StaticResource RoundButton}" Margin="4"/>
            <Button x:Name="btnGenerateLogFile" Grid.Column="2" Content="&#x1F4C4;  Generate File"
                    Click="btnGenerateLogFile_Click" Style="{StaticResource RoundButton}" Margin="4"/>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Log List -->
            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="4"
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Panel Header -->
                    <Border Grid.Row="0" Background="{DynamicResource DataGridHeaderBgBrush}"
                            CornerRadius="12,12,0,0" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4CB;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Log Entries" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Data Grid -->
                    <local:ListViewResultControl x:Name="lstDBExecResult" Grid.Row="1" Margin="0"
                                                 SelectionChangedExecute="lstDBExecResult_SelectionChangedExecute"/>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Width="6" Background="Transparent"
                          ShowsPreview="True" Cursor="SizeWE">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent" Width="6">
                            <Border Width="2" Background="{DynamicResource BorderBrush}"
                                    CornerRadius="1" VerticalAlignment="Stretch"
                                    HorizontalAlignment="Center" Margin="0,20"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- Right: Script Viewer -->
            <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="4"
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Panel Header -->
                    <Border Grid.Row="0" Background="{DynamicResource DataGridHeaderBgBrush}"
                            CornerRadius="12,12,0,0" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4DC;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Script Preview" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Script Content -->
                    <Border Grid.Row="1" Margin="12" CornerRadius="8"
                            Background="{DynamicResource DataGridHeaderBgBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="4">
                        <TextBox x:Name="txtScript" IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top" Background="Transparent" BorderThickness="0"
                                 FontFamily="Cascadia Code, Consolas, Courier New" FontSize="12"
                                 Foreground="{DynamicResource TextPrimaryBrush}" Padding="8,6"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
