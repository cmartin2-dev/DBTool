<UserControl x:Class="DBTool.Controls.ObjectCheckerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="4,8,4,4">
            <Button x:Name="btnCheckDuplicate" Content="Check Duplicate Column" Style="{StaticResource RoundButton}"
                    Click="btnCheckDuplicate_Click"/>
            <Button x:Name="btnRefresh" Content="Refresh" Style="{StaticResource RoundButton}"
                    Click="btnRefresh_Click"/>
        </StackPanel>
        <local:ListViewResultControl x:Name="lstObjecResult" Grid.Row="1" Margin="4"/>
    </Grid>
</UserControl>
