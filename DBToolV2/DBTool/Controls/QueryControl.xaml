<UserControl x:Class="DBTool.Controls.QueryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:common="clr-namespace:DBTool.Commons"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Style="{StaticResource commonLabel}" Grid.Row="0" Margin="4,4,4,0">
            <TextBlock Text="{Binding tenantId}"/>
        </Label>
        <local:TxtQueryControl x:Name="txtQueryControl" Grid.Row="1" Execute="txtQueryControl_Execute"/>
        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Margin="4,4" ResizeDirection="Rows" ShowsPreview="True" Cursor="SizeNS">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="GridSplitter">
                                <Border Background="Transparent" Height="6">
                                    <Border Height="2" Background="{DynamicResource BorderBrush}"
                                            CornerRadius="1" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>
        <DockPanel Grid.Row="3" LastChildFill="True">
            <TabControl x:Name="tabQueryResultControl"/>
        </DockPanel>
    </Grid>
</UserControl>
