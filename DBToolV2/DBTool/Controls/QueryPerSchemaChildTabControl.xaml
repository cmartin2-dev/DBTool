<UserControl x:Class="DBTool.Controls.QueryPerSchemaChildTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
                          xmlns:converters="clr-namespace:DBTool.Commons"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <local:ListViewResultControl x:Name="lstResult" Grid.Column="0" Grid.Row="0" Checkbox_Checked="lstResult_Checkbox_Checked" UnCheckbox_Checked="lstResult_UnCheckbox_Checked"/>
        <!--<ListView x:Name="lstViewResult" Grid.Row="0" Grid.Column="0"/>
        <local:LoadingControl x:Name="loadingControl" Grid.Row="0" Grid.Column="0"/>-->
    </Grid>
</UserControl>
