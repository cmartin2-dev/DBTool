<UserControl x:Class="DBTool.Controls.QueryPerSchemaChildTabLstResultControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             xmlns:converters="clr-namespace:DBTool.Commons"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <local:ListViewResultControl x:Name="lstViewResult" Grid.Row="0"/>
        <!--<ListView x:Name="lstResult" Grid.Row="0"/>
        <local:LoadingControl x:Name="loadingControl" Grid.Column="0" Grid.Row="0"/>-->
    </Grid>
</UserControl>
