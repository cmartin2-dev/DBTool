<UserControl x:Class="DBTool.Controls.QueryPerSchemaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Schema tabs -->
        <Border Grid.Row="0" Style="{StaticResource grayBorders}" Margin="0,0,0,4" Padding="0">
            <TabControl x:Name="schemaTab"/>
        </Border>

        <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Height="3" Margin="4" Background="{DynamicResource BorderBrush}"
                      ResizeDirection="Rows" ShowsPreview="True"/>

        <!-- Query section -->
        <Border Grid.Row="2" Style="{StaticResource grayBorders}" Margin="0,4" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <CheckBox x:Name="chkSCAH" Content="SCAH" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="4"/>
                <CheckBox x:Name="chkSelectAllSchemas" Content="Select All Schemas" Grid.Row="0" Grid.Column="1" 
                          VerticalAlignment="Center" Margin="4" Checked="chkSelectAllSchemas_Checked" Unchecked="chkSelectAllSchemas_Unchecked"/>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="btnExtract" Content="Extract (Multi-Sheet)"
                            HorizontalAlignment="Left" Margin="4" Style="{StaticResource RoundButton}" Click="btnExtract_Click"/>
                    <Button x:Name="btnExtractReport" Content="Extract Report (Single Sheet)"
                            HorizontalAlignment="Left" Margin="4" Style="{StaticResource RoundButton}" Click="btnExtractReport_Click"/>
                </StackPanel>
                <local:TxtQueryControl x:Name="txtQueryControl" Grid.Row="1" Grid.Column="0"
                                       Execute="txtQueryControl_Execute" Grid.ColumnSpan="3"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Height="3" Margin="4" Background="{DynamicResource BorderBrush}"
                      ResizeDirection="Rows" ShowsPreview="True"/>

        <!-- Results -->
        <Border Grid.Row="4" Style="{StaticResource grayBorders}" Margin="0,4,0,0" Padding="0">
            <TabControl x:Name="tabResult"/>
        </Border>
    </Grid>
</UserControl>
