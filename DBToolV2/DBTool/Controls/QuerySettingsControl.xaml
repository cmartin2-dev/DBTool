<UserControl x:Class="DBTool.Controls.QuerySettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <Grid ShowGridLines="False" Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Query" Style="{StaticResource headerLabel}" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Query list -->
            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0">
                <ListView x:Name="lstViewQuery" ItemsSource="{Binding Queries}" SelectionMode="Single"
                          SelectionChanged="lstViewQuery_SelectionChanged"/>
            </Border>

            <!-- Detail panel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Action buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Label Content="➕" Name="btnAdd" ToolTip="Add" Style="{StaticResource labelButton}" MouseDown="btnAdd_MouseDown" Margin="4"/>
                    <Label Content="📋" Name="btnCopy" ToolTip="Copy" Style="{StaticResource labelButton}" MouseDown="btnCopy_MouseDown" Margin="4"/>
                    <Label Content="🗑️" Name="btnDelete" ToolTip="Delete" Style="{StaticResource labelButton}" MouseDown="btnDelete_MouseDown" Margin="4"/>
                    <Label Content="⛔" Name="btnCancel" ToolTip="Cancel" Style="{StaticResource labelButton}" MouseDown="btnCancel_MouseDown" Margin="4"/>
                </StackPanel>

                <!-- Details form -->
                <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="16"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel x:Name="stackPanelDetails">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Content="Name" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtName" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Style="{StaticResource TextboxValidation}" Grid.Row="0" Grid.Column="1" Margin="4"/>

                            <Label Content="Description" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtDescription" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="1" Grid.Column="1" Margin="4"/>

                            <Label Content="Query" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtQuery" Grid.Row="2" Grid.Column="1" Margin="4"
                                     Text="{Binding QueryString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto"/>

                            <Label Content="Is Private" Grid.Row="3" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <CheckBox x:Name="chkIsPrivate" Grid.Row="3" Grid.Column="1"
                                      IsChecked="{Binding IsPrivate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4,10"/>

                            <Label Content="Is User" Grid.Row="4" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <CheckBox x:Name="chkIsUser" Grid.Row="4" Grid.Column="1"
                                      IsChecked="{Binding IsUser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4,10"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
