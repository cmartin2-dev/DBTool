<UserControl x:Class="DBTool.Controls.RegionSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:commons="clr-namespace:DBTool.Commons"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="900">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Content="Regions" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource headerLabel}" Margin="0,0,0,12"/>

        <!-- Region list -->
        <Border Grid.Column="0" Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="0"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0">
            <ListView x:Name="lstViewRegion" SelectionMode="Single" SelectionChanged="lstViewRegion_SelectionChanged"/>
        </Border>

        <!-- Detail panel -->
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Action buttons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Label Content="➕" Name="btnAdd" ToolTip="Add" Style="{StaticResource labelButton}" MouseDown="btnAdd_MouseDown" Margin="4"/>
                <Label Content="📋" Name="btnCopy" ToolTip="Copy" Style="{StaticResource labelButton}" MouseDown="btnCopy_MouseDown" Margin="4"/>
                <Label Content="🗑️" Name="btnDelete" ToolTip="Delete" Style="{StaticResource labelButton}" MouseDown="btnDelete_MouseDown" Margin="4"/>
                <Label Content="⛔" Name="btnCancel" ToolTip="Cancel" Style="{StaticResource labelButton}" MouseDown="btnCancel_MouseDown" Margin="4"/>
            </StackPanel>

            <!-- Details form -->
            <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="stackPanelDetails">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Content="Id" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtId" Text="{Binding Id}" IsReadOnly="True" Grid.Row="0" Grid.Column="1"
                                     Width="60" HorizontalAlignment="Left" Margin="4"/>

                            <Label Content="Region Environment" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtRegionEnvironment" Text="{Binding RegionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Grid.Row="1" Grid.Column="1" Margin="4" Style="{StaticResource TextboxValidation}"/>

                            <Label Content="Endpoint" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtEndpoint" Grid.Row="2" Grid.Column="1" Margin="4"
                                     Text="{Binding RegionEndPoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Style="{StaticResource TextboxValidation}"/>

                            <Label Content="Client Id" Grid.Row="3" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtClientId" Grid.Row="3" Grid.Column="1" Margin="4"
                                     Text="{Binding RegionClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Style="{StaticResource TextboxValidation}"/>

                            <Label Content="Client Secret" Grid.Row="4" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <TextBox x:Name="txtClientSecret" Grid.Row="4" Grid.Column="1" Margin="4"
                                     Text="{Binding RegionClientSecret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Style="{StaticResource TextboxValidation}"/>

                            <Label Content="Base Tenant" Grid.Row="5" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <ComboBox x:Name="cmbBaseTenant" DisplayMemberPath="EnvironmentName" SelectedValuePath="Id"
                                      SelectedValue="{Binding HeaderEnvironmentId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Grid.Row="5" Grid.Column="1" Margin="4"/>

                            <Label Content="Headers" Grid.Row="6" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                            <DataGrid ItemsSource="{Binding Headers}" Grid.Column="1" Grid.Row="6" MinHeight="100"
                                      SelectionMode="Single" Margin="4" AutoGenerateColumns="False" CanUserAddRows="True"
                                      HeadersVisibility="Column" RowHeaderWidth="0" SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Key" Binding="{Binding Key}"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
