<Window x:Class="DBTool.Controls.SaveQueyControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DBTool.Controls"
        mc:Ignorable="d"
        Title="Save Query" Height="170" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource SurfaceBrush}">
    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Name:" VerticalAlignment="Center" Style="{StaticResource commonLabel}"/>
            <TextBox x:Name="txtName" Grid.Column="1" Margin="8,0,0,0"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Width="90" IsDefault="True" Click="Save_Click" Style="{StaticResource RoundButton}"/>
            <Button Content="Cancel" Width="90" IsCancel="True" Style="{StaticResource RoundButton}"/>
        </StackPanel>
    </Grid>
</Window>
