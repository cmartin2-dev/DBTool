<UserControl x:Class="DBTool.Controls.ScriptPathSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Content="Script Path" Style="{StaticResource headerLabel}" Margin="0,0,0,12"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Utility Path" Style="{StaticResource commonLabel}" Margin="4"/>
        <TextBox x:Name="txtUtilityPath" Text="{Binding UtilityPath, UpdateSourceTrigger=PropertyChanged}"
                 IsReadOnly="True" Grid.Row="1" Grid.Column="1" Margin="4"/>
        <Button x:Name="btnBrowse" Content="Browse" Grid.Column="2" Grid.Row="1"
                Style="{StaticResource RoundButton}" Margin="4" Click="btnBrowse_Click"/>

        <GroupBox Header="Paths" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,12,0,0">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Content="Create Folder Path" Grid.Row="0" Grid.Column="0" Margin="4" Style="{StaticResource commonLabel}"/>
                <Label Content="Upgrade Folder Path" Grid.Row="1" Grid.Column="0" Margin="4" Style="{StaticResource commonLabel}"/>
                <TextBox Name="txtCreateFolderPath" Text="{Binding CreatePath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="0" Grid.Column="1" Margin="4" IsReadOnly="True"/>
                <TextBox Name="txtUpgradeFolderPath" Text="{Binding UpgradePath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="1" Grid.Column="1" Margin="4" IsReadOnly="True"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
