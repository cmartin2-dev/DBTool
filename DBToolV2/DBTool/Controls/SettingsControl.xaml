<UserControl x:Class="DBTool.Controls.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" d:Height="800" d:Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header row -->
        <Grid Grid.Row="0" Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Content="Settings" Style="{StaticResource headerLabel}"/>
            <Button Name="btnSave" Content="Save" Grid.Column="1" Style="{StaticResource RoundButton}" Click="btnSave_Click"/>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Settings nav -->
            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="6,12" Margin="0,0,12,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel Width="64">
                    <RadioButton Name="rdoDatabaseSettings" Content="&#x1F9D1;&#x200D;&#x1F4BB;" ToolTip="Admin" Checked="rdoSettings_Checked"/>
                    <RadioButton Name="rdoEnvironmentSettings" Content="&#x1F30D;" ToolTip="Environment" Checked="rdoSettings_Checked"/>
                    <RadioButton Name="rdoQuerySettings" Content="&#x1F4DD;" ToolTip="Query" Checked="rdoSettings_Checked"/>
                    <RadioButton Name="rdoDataGrowthSettings" Content="&#x1F4C8;" ToolTip="Data Growth" Checked="rdoSettings_Checked" Visibility="Collapsed"/>
                    <RadioButton Name="rdoLanguageSettings" Content="&#x1F310;" ToolTip="Language / Locale" Checked="rdoSettings_Checked"/>
                    <RadioButton Name="rdoAboutSettings" Content="&#x2139;" ToolTip="About" Checked="rdoSettings_Checked" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Column="1" Style="{StaticResource grayBorders}" Margin="0">
                <Grid>
                    <local:DatabaseSettingsControl x:Name="databaseSettingsControl" Visibility="Visible"/>
                    <local:EnvironmentSettingsControl x:Name="environmentSettingsControl" Visibility="Visible"/>
                    <local:QuerySettingsControl x:Name="querySettingsControl" Visibility="Visible"/>
                    <local:AboutSettingsControl x:Name="aboutSettingsControl" Visibility="Visible"/>
                    <local:LanguageSettingsControl x:Name="languageSettingsControl" Visibility="Visible"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
