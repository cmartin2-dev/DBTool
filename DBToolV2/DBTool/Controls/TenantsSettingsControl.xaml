<UserControl x:Class="DBTool.Controls.TenantsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" PreviewKeyDown="ScrollViewer_PreviewKeyDown">
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Content="Tenants" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource headerLabel}" Margin="0,0,0,12"/>

            <!-- Tenant list -->
            <Border Grid.Column="0" Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0">
                <ListView x:Name="lstViewTenants" SelectionMode="Single" SelectionChanged="lstViewTenants_SelectionChanged"/>
            </Border>

            <!-- Detail panel -->
            <Grid Grid.Column="1" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Action buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Label Content="➕" Name="btnAdd" ToolTip="Add" Style="{StaticResource labelButton}" MouseDown="btnAdd_MouseDown" Margin="4"/>
                    <Label Content="📋" Name="btnCopy" ToolTip="Copy" Style="{StaticResource labelButton}" MouseDown="btnCopy_MouseDown" Margin="4"/>
                    <Label Content="🗑️" Name="btnDelete" ToolTip="Delete" Style="{StaticResource labelButton}" MouseDown="btnDelete_MouseDown" Margin="4"/>
                    <Label Content="⛔" Name="btnCancel" ToolTip="Cancel" Style="{StaticResource labelButton}" MouseDown="btnCancel_MouseDown" Margin="4"/>
                </StackPanel>

                <!-- Details form -->
                <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="16"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="stackPanelDetails">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Content="Id" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                                <TextBox x:Name="txtId" Text="{Binding Id}" IsReadOnly="True" Grid.Row="0" Grid.Column="1"
                                         Width="60" HorizontalAlignment="Left" Margin="4"/>

                                <Label Content="Tenant Name" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                                <TextBox x:Name="txtTenantName" Text="{Binding TenantName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                         Style="{StaticResource TextboxValidation}" Grid.Row="1" Grid.Column="1" Margin="4"/>

                                <Label x:Name="lblEndpoint" Content="Endpoint" Grid.Row="2" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4" Visibility="Collapsed"/>
                                <TextBox x:Name="txtEndpoint" Grid.Row="2" Grid.Column="1" Margin="4" Visibility="Collapsed"
                                         Text="{Binding EndPoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Label Content="Client Id" Grid.Row="3" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                                <TextBox x:Name="txtClientId" Grid.Row="3" Grid.Column="1" Margin="4"
                                         Text="{Binding ClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Label Content="Client Secret" Grid.Row="4" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                                <TextBox x:Name="txtClientSecret" Grid.Row="4" Grid.Column="1" Margin="4"
                                         Text="{Binding ClientSecret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Label Content="Resource" Grid.Row="5" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                                <TextBox x:Name="txtResouce" Grid.Row="5" Grid.Column="1" Margin="4"
                                         Text="{Binding Resource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Label Content="Token URL" Grid.Row="6" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                                <TextBox x:Name="txtTokenURL" Grid.Row="6" Grid.Column="1" Margin="4"
                                         Text="{Binding TokenUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Label Content="Username" Grid.Row="7" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                                <TextBox x:Name="txtUsername" Grid.Row="7" Grid.Column="1" Margin="4"
                                         Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Label Content="Password" Grid.Row="8" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                                <TextBox x:Name="txtPassword" Grid.Row="8" Grid.Column="1" Margin="4"
                                         Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Label Content="OAuth1" Grid.Row="9" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                                <CheckBox x:Name="rdoOAuth1" Grid.Row="9" Grid.Column="1"
                                          IsChecked="{Binding isOAuth1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4,8"/>

                                <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" DataContext="{Binding SQLDBInfo}" Margin="0,12,0,0">
                                    <GroupBox Header="SQL Database Info">
                                        <Grid Margin="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Row="0" Grid.Column="0" Content="Server" Style="{StaticResource commonLabel}" Margin="4"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtServer"
                                                     Text="{Binding Server, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                                            <Label Grid.Row="1" Grid.Column="0" Content="Username" Style="{StaticResource commonLabel}" Margin="4"/>
                                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtServerUsername"
                                                     Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                                            <Label Grid.Row="2" Grid.Column="0" Content="Password" Style="{StaticResource commonLabel}" Margin="4"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtServerPassword"
                                                     Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                                            <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="Windows Authentication"
                                                      HorizontalAlignment="Right"
                                                      IsChecked="{Binding IsWindowsAuthentication, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4"/>
                                        </Grid>
                                    </GroupBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
