<Window x:Class="DBTool.Controls.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DBTool" SizeToContent="Height" Width="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">
    <Border CornerRadius="12" Margin="10"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
        </Border.Effect>
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtTitle" Grid.Row="0" Text="Title" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontFamily="{StaticResource AppFont}" Margin="0,0,0,10"/>

            <TextBlock x:Name="txtMessage" Grid.Row="1" TextWrapping="Wrap" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontFamily="{StaticResource AppFont}" Margin="0,0,0,20"/>

            <StackPanel x:Name="pnlButtons" Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</Window>
