<UserControl x:Class="DBTool.Controls.TranslationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="MainGrid" ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Left panel -->
        <Border Grid.Column="0" Style="{StaticResource grayBorders}" Margin="0,0,4,0" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="209*"/>
                    <ColumnDefinition Width="21*"/>
                </Grid.ColumnDefinitions>

                <Label Content="Translation" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource headerLabel}"/>

                <Label Content="Regions" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource commonLabel}"/>
                <ComboBox x:Name="cmbRegion" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                          SelectionChanged="cmbRegion_SelectionChanged" Margin="0,31,0,0" Grid.RowSpan="2"/>

                <Label Content="Environments" Grid.Row="3" Visibility="Hidden" Grid.Column="0" Grid.ColumnSpan="3"
                       Style="{StaticResource commonLabel}" Margin="0,25,0,31" Grid.RowSpan="3"/>

                <local:ListViewResultControl x:Name="lstResult" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4"
                                             SelectionChangedExecute="lstViewEnvironment_SelectionChanged"/>
                <local:ListViewResultControl x:Name="lstSchema" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4"/>

                <GroupBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Header="Options">
                    <StackPanel Margin="4">
                        <CheckBox x:Name="chkRemoveMnemonic" Content="Remove mnemonic" Margin="4" Style="{StaticResource customCheckboxLabel}"/>
                        <CheckBox x:Name="chkRemoveExcludedKeys" Content="Remove excluded keys" Margin="4" Style="{StaticResource customCheckboxLabel}"/>
                        <CheckBox x:Name="chkNewUpdatedLocaleOnly" Content="New / Updated locales only" Margin="4" Style="{StaticResource customCheckboxLabel}"/>
                        <CheckBox x:Name="chkIncludedLength" Content="Include length" Margin="4" Style="{StaticResource customCheckboxLabel}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3" Header="Languages">
                    <local:ListViewResultControl x:Name="lstLanguage"
                                                 Checkbox_Checked="HeaderCheckBox_Checked"
                                                 UnCheckbox_Checked="HeaderCheckBox_Unchecked"/>
                </GroupBox>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Width="3" Background="{DynamicResource BorderBrush}"
                      ShowsPreview="True"/>

        <!-- Right panel - Tabs -->
        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource grayBorders}" Margin="4,0,0,0" Padding="0">
            <TabControl Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3">
                <TabItem Header="Extract Locale" Style="{StaticResource BaseTabItem}" Margin="-2,0,2,0">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="200"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="txtExcludedKeys" Grid.Row="0" Grid.Column="0" Margin="4" Grid.ColumnSpan="2"
                                 VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True" TextWrapping="Wrap"/>
                        <Button x:Name="btnLoad" Content="Load" Grid.Row="1" Grid.Column="0" Margin="4"
                                Style="{StaticResource RoundButton}" Click="btnLoad_Click"/>
                        <local:ListViewResultControl x:Name="lstLocale" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4"/>
                    </Grid>
                </TabItem>
                <TabItem Header="Compare to File" Style="{StaticResource BaseTabItem}">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Content="Localization File" Grid.Row="0" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                        <TextBox x:Name="txtCompareLocaleFile" Grid.Row="0" Grid.Column="1" Margin="4" IsReadOnly="True"/>
                        <Button x:Name="btnSelectLocaleFile" Content="Load File" Click="btnSelectLocaleFile_Click"
                                Grid.Row="0" Grid.Column="2" Margin="4" Style="{StaticResource RoundButton}"/>

                        <Label Content="Available Sheets" Grid.Row="1" Grid.Column="0" Style="{StaticResource commonLabel}" Margin="4"/>
                        <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cmbAvailableSheets" Grid.Column="0" Margin="4" Width="200" HorizontalAlignment="Left"/>
                            <Button x:Name="btnLoadSheet" Grid.Column="1" Margin="4" Click="btnLoadSheet_Click"
                                    Content="Load Sheet" Style="{StaticResource RoundButton}"/>
                        </Grid>

                        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Excel side -->
                            <Grid Grid.Row="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="Sheet Data" Grid.Row="0" Margin="4" Style="{StaticResource commonLabel}"/>
                                <local:ListViewResultControl x:Name="lstCompareExcelSheet" Grid.Row="1" Margin="4"/>
                            </Grid>
                            <!-- Database side -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="Database Data" Grid.Row="0" Grid.Column="0" Margin="4" Style="{StaticResource commonLabel}"/>
                                <Button x:Name="btnCompare" Grid.Column="1" Grid.Row="0" Margin="4"
                                        Style="{StaticResource RoundButton}" Content="Compare"
                                        HorizontalAlignment="Right" Click="btnCompare_Click"/>
                                <local:ListViewResultControl x:Name="lstCompareDBData" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                             Margin="4" Checkbox_Checked="lstCompareDBData_Checkbox_Checked"
                                                             UnCheckbox_Checked="lstCompareDBData_UnCheckbox_Checked"/>
                            </Grid>
                        </Grid>
                        <Button x:Name="btnCompareExcelGenerateScript" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                Margin="4" HorizontalAlignment="Right" Click="btnCompareExcelGenerateScript_Click"
                                Content="Generate Script" Style="{StaticResource RoundButton}"/>
                    </Grid>
                </TabItem>
                <TabItem Header="Generate Script" Style="{StaticResource BaseTabItem}"/>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
