<UserControl x:Class="DBTool.Controls.TxtQueryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button x:Name="rdoExecute" Content="&#x25B6;  Execute" ToolTip="Execute"
                Grid.Row="0" Margin="4" HorizontalAlignment="Left"
                Click="Button_Click" Style="{StaticResource RoundButton}"/>
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" SnapsToDevicePixels="True" Background="{DynamicResource CardBrush}">
            <avalon:TextEditor x:Name="txtQuery" PreviewMouseWheel="MyRichTextBox_PreviewMouseWheel"
                               FontSize="14" FontFamily="Cascadia Code, Consolas, Courier New"
                               BorderThickness="0"
                               HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                               PreviewKeyDown="txtQuery_PreviewKeyDown"
                               VerticalContentAlignment="Top" VerticalAlignment="Stretch"
                               MouseLeftButtonDown="txtQuery_MouseLeftButtonDown"
                               Padding="8,6">
                <avalon:TextEditor.ContextMenu>
                    <ContextMenu/>
                </avalon:TextEditor.ContextMenu>
            </avalon:TextEditor>
        </Border>
    </Grid>
</UserControl>
