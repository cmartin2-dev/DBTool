<UserControl x:Class="DBTool.Controls.UpgradeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Folder Selection -->
        <Border Grid.Row="0" Style="{StaticResource grayBorders}" Margin="0,0,0,8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Upgrade Folder" 
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontFamily="{StaticResource AppFont}" Margin="0,0,0,6"/>

                <TextBox x:Name="txtUpgradePath" Grid.Row="1" Grid.Column="0" 
                         IsReadOnly="True" Margin="0,0,8,0"
                         VerticalContentAlignment="Center"/>
                <Button x:Name="btnBrowse" Grid.Row="1" Grid.Column="1" 
                        Content="Browse" Style="{StaticResource RoundButton}"
                        Click="btnBrowse_Click"/>
            </Grid>
        </Border>

        <!-- Main resizable area: Versions | Schemas | Changesets | Log -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="150"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Versions -->
            <Border Grid.Column="0" Style="{StaticResource grayBorders}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Select Versions" 
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                        <Button x:Name="btnSelectAll" Content="Select All" 
                                Style="{StaticResource RoundButton}" Margin="12,0,4,0"
                                Click="btnSelectAll_Click"/>
                        <Button x:Name="btnDeselectAll" Content="Deselect All" 
                                Style="{StaticResource RoundButton}" Margin="4,0,0,0"
                                Click="btnDeselectAll_Click"/>
                        <Border Margin="16,0,0,0" Padding="8,2" BorderThickness="1" 
                                BorderBrush="{DynamicResource BorderBrush}" CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Module:" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontFamily="{StaticResource AppFont}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <CheckBox x:Name="chkSCAH" Content="SCAH" IsChecked="True" 
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <CheckBox x:Name="chkFSH" Content="FSH" IsChecked="True" 
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <ListView x:Name="lstVersions" Grid.Row="1" 
                              SelectionMode="Multiple"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Checked="VersionCheckBox_Checked"
                                                      Unchecked="VersionCheckBox_Unchecked"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Version" Width="200" 
                                                DisplayMemberBinding="{Binding Version}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <!-- Vertical Splitter -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" Background="Transparent"
                          ResizeDirection="Columns" ShowsPreview="True"
                          Cursor="SizeWE" Focusable="False">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="GridSplitter">
                                    <Border Background="Transparent" Width="6">
                                        <Border Width="2" Background="{DynamicResource BorderBrush}"
                                                CornerRadius="1" HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Right: Schema + Changesets + Log (stacked vertically) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="80"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="1.5*" MinHeight="80"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="1.5*" MinHeight="80"/>
                </Grid.RowDefinitions>

                <!-- Schema Grid -->
                <Border Grid.Row="0" Style="{StaticResource grayBorders}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Schema" 
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                            <Button x:Name="btnFetchSchemas" Content="Fetch Schemas" 
                                    Style="{StaticResource RoundButton}" Margin="12,0,4,0"
                                    Click="btnFetchSchemas_Click"/>
                            <Button x:Name="btnLoadChangesets" Content="Load Changesets" 
                                    Style="{StaticResource RoundButton}" Margin="4,0,0,0"
                                    Click="btnLoadChangesets_Click"/>
                        </StackPanel>

                        <DataGrid x:Name="dgSchemas" Grid.Row="1" 
                                  AutoGenerateColumns="False" IsReadOnly="False"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  CanUserSortColumns="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40">
                                    <DataGridCheckBoxColumn.Header>
                                        <CheckBox x:Name="chkSelectAllSchemas"
                                                  Checked="chkSelectAllSchemas_Checked"
                                                  Unchecked="chkSelectAllSchemas_Unchecked"/>
                                    </DataGridCheckBoxColumn.Header>
                                </DataGridCheckBoxColumn>
                                <DataGridTextColumn Header="Schema Name" Binding="{Binding SchemaName}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Module" Binding="{Binding ModuleCode}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="DB Version" Binding="{Binding DbVersion}" Width="*" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Horizontal Splitter 1 -->
                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" Background="Transparent"
                              ResizeDirection="Rows" ShowsPreview="True"
                              Cursor="SizeNS" Focusable="False">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridSplitter">
                                        <Border Background="Transparent" Height="6">
                                            <Border Height="2" Background="{DynamicResource BorderBrush}"
                                                    CornerRadius="1" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <!-- Changeset List -->
                <Border Grid.Row="2" Style="{StaticResource grayBorders}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Changesets" 
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtChangesetSearch" Width="200" Margin="12,0,0,0"
                                     VerticalContentAlignment="Center" FontSize="11"
                                     TextChanged="txtChangesetSearch_TextChanged"/>
                            <TextBlock Text="  search" FontSize="10" 
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <DataGrid x:Name="dgChangesets" Grid.Row="1" 
                                  AutoGenerateColumns="False" IsReadOnly="False"
                                  CanUserSortColumns="True"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  SelectionChanged="dgChangesets_SelectionChanged"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40">
                                    <DataGridCheckBoxColumn.Header>
                                        <CheckBox x:Name="chkSelectAllChangesets" 
                                                  IsChecked="True"
                                                  Checked="chkSelectAllChangesets_Checked"
                                                  Unchecked="chkSelectAllChangesets_Unchecked"/>
                                    </DataGridCheckBoxColumn.Header>
                                </DataGridCheckBoxColumn>
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Schema" Binding="{Binding Schema}" Width="60" IsReadOnly="True"/>
                                <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="200" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Changeset ID" Binding="{Binding Id}" Width="250" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Horizontal Splitter 2 -->
                <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" Background="Transparent"
                              ResizeDirection="Rows" ShowsPreview="True"
                              Cursor="SizeNS" Focusable="False">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridSplitter">
                                        <Border Background="Transparent" Height="6">
                                            <Border Height="2" Background="{DynamicResource BorderBrush}"
                                                    CornerRadius="1" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <!-- Detail / Log TabControl -->
                <Border Grid.Row="4" Style="{StaticResource grayBorders}" Padding="4">
                    <TabControl x:Name="tabDetail">
                        <TabItem Header="Script Content" Style="{StaticResource BaseTabItem}">
                            <TextBox x:Name="txtScriptContent" 
                                     IsReadOnly="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="11"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderThickness="0"/>
                        </TabItem>
                        <TabItem Header="DATABASECHANGELOG Preview" Style="{StaticResource BaseTabItem}">
                            <DataGrid x:Name="dgChangelogPreview" 
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="220"/>
                                    <DataGridTextColumn Header="AUTHOR" Binding="{Binding Author}" Width="80"/>
                                    <DataGridTextColumn Header="FILENAME" Binding="{Binding FileName}" Width="200"/>
                                    <DataGridTextColumn Header="EXECTYPE" Binding="{Binding ExecType}" Width="80"/>
                                    <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="80"/>
                                    <DataGridTextColumn Header="COMMENTS" Binding="{Binding Comments}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Execution Log" Style="{StaticResource BaseTabItem}">
                            <TextBox x:Name="txtLog" 
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="11"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderThickness="0"/>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <!-- Action Buttons & Progress -->
        <Border Grid.Row="2" Padding="0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label x:Name="lblStatus" Grid.Column="0" 
                       Content="Ready" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontFamily="{StaticResource AppFont}" FontSize="11"/>

                <Button x:Name="btnVerify" Grid.Column="1" 
                        Content="Verify" Style="{StaticResource RoundButton}"
                        Margin="0,0,8,0" MinWidth="120" Height="40" Click="btnVerify_Click"/>
                <Button x:Name="btnPreview" Grid.Column="2" 
                        Content="Preview Script" Style="{StaticResource RoundButton}"
                        Margin="0,0,8,0" MinWidth="120" Height="40" Click="btnPreview_Click"/>
                <Button x:Name="btnExecute" Grid.Column="3" 
                        Content="Execute Upgrade" Style="{StaticResource RoundButton}"
                        MinWidth="120" Height="40" Click="btnExecute_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
