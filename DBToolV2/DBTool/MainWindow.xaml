<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DBTool"
        xmlns:Controls="clr-namespace:DBTool.Controls" x:Class="DBTool.MainWindow"
        xmlns:converters="clr-namespace:DBTool.Commons"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="DBTool" Height="450" Width="800" Icon="support.ico"
        WindowStyle="None" AllowsTransparency="False"
        Background="{DynamicResource SurfaceBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <Style TargetType="avalonedit:TextEditor">
            <Setter Property="converters:AvalonEditWatermark.Watermark" Value=" " />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--  CUSTOM TITLE BAR  -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryDarkBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F6E2;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="DBTool" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"
                               FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                    <TextBlock Text="  Database Management" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                               FontFamily="{StaticResource AppFont}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button Click="BtnMinimize_Click" ToolTip="Minimize" WindowChrome.IsHitTestVisibleInChrome="True"
                            Width="46" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <TextBlock Text="&#xE949;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Click="BtnMaximize_Click" ToolTip="Maximize" WindowChrome.IsHitTestVisibleInChrome="True"
                            Width="46" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <TextBlock x:Name="ico" Text="&#xE739;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Click="BtnClose_Click" ToolTip="Close" WindowChrome.IsHitTestVisibleInChrome="True"
                            Width="46" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#C42B1C"/>
                                        <Setter TargetName="bg" Property="TextElement.Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  MAIN AREA  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBgBrush}">
                <DockPanel LastChildFill="False">

                    <TextBlock DockPanel.Dock="Top" Text="NAVIGATION" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}" Margin="20,16,0,8"/>

                    <RadioButton DockPanel.Dock="Top" Name="rdoDashboard" Checked="mainRdo_Checked" PreviewMouseDown="checkSettingsObject_PreviewMouseDown" ToolTip="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4CA;" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton DockPanel.Dock="Top" Name="rdoEnvironment" Checked="mainRdo_Checked" PreviewMouseDown="checkSettingsObject_PreviewMouseDown" ToolTip="Environment">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F30D;" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Environment" FontSize="13" VerticalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton DockPanel.Dock="Top" Name="rdoTranslation" Checked="mainRdo_Checked" PreviewMouseDown="checkSettingsObject_PreviewMouseDown" ToolTip="Translation">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F5E3;" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Translation" FontSize="13" VerticalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton DockPanel.Dock="Top" Name="rdoDatabase" Checked="mainRdo_Checked" PreviewMouseDown="checkSettingsObject_PreviewMouseDown" ToolTip="Database">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F5C4;" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Database" FontSize="13" VerticalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton DockPanel.Dock="Top" Name="rdoApi" Checked="mainRdo_Checked" ToolTip="API">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F310;" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="API" FontSize="13" VerticalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton DockPanel.Dock="Top" Name="rdoQueryLog" Checked="mainRdo_Checked" ToolTip="Query Log">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4DD;" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Query Log" FontSize="13" VerticalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </RadioButton>

                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource SidebarDividerBrush}" BorderThickness="0,1,0,0" Margin="16,16,16,0"/>
                    <TextBlock DockPanel.Dock="Top" Text="SYSTEM" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}" Margin="20,12,0,8"/>

                    <RadioButton DockPanel.Dock="Top" Name="rdoSettings" Checked="mainRdo_Checked" ToolTip="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Settings" FontSize="13" VerticalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Theme Toggle Button -->
                    <Button DockPanel.Dock="Bottom" x:Name="btnThemeToggle" Click="BtnThemeToggle_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Margin="12,10">
                            <TextBlock x:Name="themeIcon" Text="&#x1F319;" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="themeLabel" Text="Dark Mode" FontSize="13" VerticalAlignment="Center"
                                       FontFamily="{StaticResource AppFont}" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </Button>

                    <Border DockPanel.Dock="Bottom" Padding="16,12" BorderBrush="{DynamicResource SidebarDividerBrush}" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{DynamicResource Success}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="Connected" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource AppFont}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Background="{Binding CheckAccess, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToBrushConverter}}" Height="3" Margin="0,4,0,4"/>
                            </StackPanel>
                    </Border>

                </DockPanel>
            </Border>

            <!-- MAIN CONTENT -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" Padding="16">
                <DockPanel Name="mainDockPanel">
                    <Grid>
                        <Controls:DashboardControl x:Name="dashboardControl"/>
                        <Controls:SettingsControl x:Name="settingsControl"/>
                        <Controls:EnvironmentControl x:Name="environmentControl"/>
                        <Controls:TranslationControl x:Name="translationControl"/>
                        <Controls:DatabaseControl x:Name="databaseControl"/>
                        <Controls:ApiControl x:Name="apiControl"/>
                        <Controls:LogDBExecutePRDControl x:Name="logDBExecuteControl"/>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>