<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Colors -->
    <Color x:Key="PrimaryDark">#0B0F19</Color>
    <Color x:Key="SidebarBg">#111827</Color>
    <Color x:Key="SidebarHover">#1F2937</Color>
    <Color x:Key="SidebarActive">#3B82F6</Color>
    <Color x:Key="Accent">#60A5FA</Color>
    <Color x:Key="AccentHover">#3B82F6</Color>
    <Color x:Key="AccentPressed">#2563EB</Color>
    <Color x:Key="Surface">#0F172A</Color>
    <Color x:Key="Card">#1E293B</Color>
    <Color x:Key="Border">#334155</Color>
    <Color x:Key="BorderFocus">#60A5FA</Color>
    <Color x:Key="TextPrimary">#F1F5F9</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color>
    <Color x:Key="TextMuted">#64748B</Color>
    <Color x:Key="Success">#34D399</Color>
    <Color x:Key="Danger">#F87171</Color>
    <Color x:Key="DangerBg">#371520</Color>
    <Color x:Key="RowHover">#1E293B</Color>
    <Color x:Key="RowSelected">#172554</Color>

    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBg}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHover}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActive}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource Card}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocus}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="RowHoverBrush" Color="{StaticResource RowHover}"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="{StaticResource RowSelected}"/>

    <!-- Theme-specific extras -->
    <SolidColorBrush x:Key="TextBoxBgBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="TabHeaderBgBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="TabSelectedBgBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="DataGridHeaderBgBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="SidebarSelectedBgBrush" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="SidebarDividerBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="MenuHoverBrush" Color="#334155"/>

    <!-- Button theme brushes -->
    <Color x:Key="BtnDefault">#E2E8F0</Color>
    <Color x:Key="BtnHover">#CBD5E1</Color>
    <Color x:Key="BtnPressed">#94A3B8</Color>
    <Color x:Key="BtnDisabledBg">#334155</Color>
    <Color x:Key="BtnDisabledFg">#64748B</Color>
    <SolidColorBrush x:Key="BtnDefaultBrush" Color="{StaticResource BtnDefault}"/>
    <SolidColorBrush x:Key="BtnHoverBrush" Color="{StaticResource BtnHover}"/>
    <SolidColorBrush x:Key="BtnPressedBrush" Color="{StaticResource BtnPressed}"/>
    <SolidColorBrush x:Key="BtnDisabledBgBrush" Color="{StaticResource BtnDisabledBg}"/>
    <SolidColorBrush x:Key="BtnDisabledFgBrush" Color="{StaticResource BtnDisabledFg}"/>
    <SolidColorBrush x:Key="BtnForegroundBrush" Color="#0F172A"/>

</ResourceDictionary>
