<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors -->
    <Color x:Key="PrimaryDark">#111827</Color>
    <Color x:Key="SidebarBg">#1F2937</Color>
    <Color x:Key="SidebarHover">#374151</Color>
    <Color x:Key="SidebarActive">#3B82F6</Color>
    <Color x:Key="Accent">#3B82F6</Color>
    <Color x:Key="AccentHover">#2563EB</Color>
    <Color x:Key="AccentPressed">#1D4ED8</Color>
    <Color x:Key="Surface">#F3F4F6</Color>
    <Color x:Key="Card">#FFFFFF</Color>
    <Color x:Key="Border">#E5E7EB</Color>
    <Color x:Key="BorderFocus">#93C5FD</Color>
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextMuted">#9CA3AF</Color>
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="DangerBg">#FEF2F2</Color>
    <Color x:Key="RowHover">#F9FAFB</Color>
    <Color x:Key="RowSelected">#EFF6FF</Color>

    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBg}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHover}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActive}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource Card}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocus}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="RowHoverBrush" Color="{StaticResource RowHover}"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="{StaticResource RowSelected}"/>

    <!-- Theme-specific extras -->
    <SolidColorBrush x:Key="TextBoxBgBrush" Color="White"/>
    <SolidColorBrush x:Key="TabHeaderBgBrush" Color="#EEF1F6"/>
    <SolidColorBrush x:Key="TabSelectedBgBrush" Color="White"/>
    <SolidColorBrush x:Key="DataGridHeaderBgBrush" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="SidebarSelectedBgBrush" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="SidebarDividerBrush" Color="#374151"/>
    <SolidColorBrush x:Key="MenuHoverBrush" Color="#E5E7EB"/>

    <!-- Button theme brushes -->
    <Color x:Key="BtnDefault">#1F2937</Color>
    <Color x:Key="BtnHover">#111827</Color>
    <Color x:Key="BtnPressed">#0F172A</Color>
    <Color x:Key="BtnDisabledBg">#E5E7EB</Color>
    <Color x:Key="BtnDisabledFg">#9CA3AF</Color>
    <SolidColorBrush x:Key="BtnDefaultBrush" Color="{StaticResource BtnDefault}"/>
    <SolidColorBrush x:Key="BtnHoverBrush" Color="{StaticResource BtnHover}"/>
    <SolidColorBrush x:Key="BtnPressedBrush" Color="{StaticResource BtnPressed}"/>
    <SolidColorBrush x:Key="BtnDisabledBgBrush" Color="{StaticResource BtnDisabledBg}"/>
    <SolidColorBrush x:Key="BtnDisabledFgBrush" Color="{StaticResource BtnDisabledFg}"/>
    <SolidColorBrush x:Key="BtnForegroundBrush" Color="White"/>

</ResourceDictionary>
