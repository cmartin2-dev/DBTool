\tIF ISNULL(@STYLEPATTERNPAGEID,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLEPATTERNPIECE','SELECT * FROM ' + @SCHEMA + '.STYLEPATTERNPIECE WITH (NOLOCK) WHERE STYLEPATTERNPAGEID IN (' + @STYLEPATTERNPAGEID + ')')\t\t\n\n\t\t\t\tEND\n\n\t\t\tEND\n\t\tEND\n\t\t--stylemarkerpage\n\t\tIF UPPER(@TABLENAME) = 'STYLEMARKERPAGE'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\t\n\n\t\t\t\tDECLARE @STYLEMARKERPAGEID NVARCHAR(MAX)\n\n\t\t\t\tSELECT @STYLEMARKERPAGEID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLEMARKERPAGEID) FROM FSH1.STYLEMARKERPAGE WHERE STYLEID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\t\tIF ISNULL(@STYLEMARKERPAGEID,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLEMARKERPAGETABLE','SELECT * FROM ' + @SCHEMA + '.STYLEMARKERPAGETABLE WITH (NOLOCK) WHERE STYLEMARKERPAGEID IN (' + @STYLEMARKERPAGEID + ')')\t\t\n\n\t\t\t\tEND\n\n\t\t\tEND\n\t\tEND\n\t\t--stylelabel\n\t\tIF UPPER(@TABLENAME) = 'STYLELABEL'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\t\n\n\t\t\t\tDECLARE @STYLELABELID NVARCHAR(MAX)\n\n\t\t\t\tSELECT @STYLELABELID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLELABELID) FROM FSH1.STYLELABEL WHERE STYLEID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\t\tIF ISNULL(@STYLELABELID,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLELABELINST','SELECT * FROM ' + @SCHEMA + '.STYLELABELINST WITH (NOLOCK) WHERE STYLELABELID IN (' + @STYLELABELID + ')')\t\t\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLELABELPART','SELECT * FROM ' + @SCHEMA + '.STYLELABELPART WITH (NOLOCK) WHERE STYLELABELID IN (' + @STYLELABELID + ')')\t\n\n\t\t\t\tEND\n\n\t\t\tEND\n\t\tEND\n\t\t--stylecosting\n\t\tIF UPPER(@TABLENAME) = 'STYLECOSTING'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\t\n\n\t\t\t\tDECLARE @STYLECOSTINGID NVARCHAR(MAX)\n\n\t\t\t\tSELECT @STYLECOSTINGID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLECOSTINGID) FROM FSH1.STYLECOSTING WHERE STYLEID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\t\tIF ISNULL(@STYLECOSTINGID,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLECOSTINGELEMENT','SELECT * FROM ' + @SCHEMA + '.STYLECOSTINGELEMENT WITH (NOLOCK) WHERE STYLECOSTINGID IN (' + @STYLECOSTINGID + ')')\t\t\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLECOSTINGSUPPLIER','SELECT * FROM ' + @SCHEMA + '.STYLECOSTINGSUPPLIER WITH (NOLOCK) WHERE STYLECOSTINGID IN (' + @STYLECOSTINGID + ')')\t\n\n\t\t\t\t\tDECLARE @STYLECOSTINGSUPPLIERID NVARCHAR(MAX)\n\n\t\t\t\t\tSELECT @STYLECOSTINGSUPPLIERID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLECOSTINGSUPPLIERID) FROM FSH1.STYLECOSTINGSUPPLIER WHERE STYLECOSTINGID IN (SELECT VALUE FROM string_split(@STYLECOSTINGID,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\t\t\tIF ISNULL(@STYLECOSTINGSUPPLIERID,'0') != '0'\n\t\t\t\t\tBEGIN\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('STYLECOSTINGSUPPLIERVAL','SELECT * FROM ' + @SCHEMA + '.STYLECOSTINGSUPPLIERVAL WITH (NOLOCK) WHERE STYLECOSTINGSUPPLIERID IN (' + @STYLECOSTINGSUPPLIERID + ')')\t\n\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('STYLESOURCING','SELECT * FROM ' + @SCHEMA + '.STYLESOURCING WITH (NOLOCK) WHERE STYLECOSTINGSUPPLIERID IN (' + @STYLECOSTINGSUPPLIERID + ')')\t\n\n\t\t\t\t\tEND\n\n\t\t\t\tEND\n\n\t\t\tEND\n\t\tEND\n\t\t--compliance\n\t\tIF UPPER(@TABLENAME) = 'COMPLIANCE'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE MODULEID = 1 AND OBJID IN (' + @ARCHIVED_STYLES + ')')\t\t\n\n\t\t\t\tDECLARE @COMPLIANCEID NVARCHAR(MAX)\n\n\t\t\t\tSELECT @COMPLIANCEID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),COMPLIANCEID) FROM FSH1.COMPLIANCE WHERE MODULEID = 1 AND OBJID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\t\tIF ISNULL(@COMPLIANCEID,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('COMPLIANCETEST','SELECT * FROM ' + @SCHEMA + '.COMPLIANCETEST WITH (NOLOCK) WHERE COMPLIANCEID IN (' + @COMPLIANCEID + ')')\t\t\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('COMPLIANCESUPPLIER','SELECT * FROM ' + @SCHEMA + '.COMPLIANCESUPPLIER WITH (NOLOCK) WHERE COMPLIANCEID IN (' + @COMPLIANCEID + ')')\t\n\n\t\t\t\t\tDECLARE @COMPLIANCESUPPLIERID NVARCHAR(MAX)\n\n\t\t\t\t\tSELECT @COMPLIANCESUPPLIERID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),COMPLIANCESUPPLIERID) FROM FSH1.COMPLIANCESUPPLIER WHERE COMPLIANCEID IN (SELECT VALUE FROM string_split(@COMPLIANCEID,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\t\t\tIF ISNULL(@COMPLIANCESUPPLIERID,'0') != '0'\n\t\t\t\t\tBEGIN\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('COMPLIANCESUPPLIERVAL','SELECT * FROM ' + @SCHEMA + '.COMPLIANCESUPPLIERVAL WITH (NOLOCK) WHERE COMPLIANCESUPPLIERID IN (' + @COMPLIANCESUPPLIERID + ')')\t\n\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('COMPLIANCESUPPLIERCOLORRNG','SELECT * FROM ' + @SCHEMA + '.COMPLIANCESUPPLIERCOLORRNG WITH (NOLOCK) WHERE COMPLIANCESUPPLIERID IN (' + @COMPLIANCESUPPLIERID + ')')\t\n\t\t\t\t\n\t\t\t\t\t\tDECLARE @COMPLIANCESUPPLIERCOLORRNGID NVARCHAR(MAX)\n\n\t\t\t\t\t\tSELECT @COMPLIANCESUPPLIERCOLORRNGID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),COMPLIANCESUPPLIERCOLORRNGID) FROM FSH1.COMPLIANCESUPPLIERCOLORRNG WHERE COMPLIANCESUPPLIERID IN (SELECT VALUE FROM string_split(@COMPLIANCESUPPLIERID,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\t\t\t\tIF ISNULL(@COMPLIANCESUPPLIERCOLORRNGID,'0') != '0'\n\t\t\t\t\t\tBEGIN\n\t\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t\t('COMPLIANCESUPPLIERCOLORRNGVAL','SELECT * FROM ' + @SCHEMA + '.COMPLIANCESUPPLIERCOLORRNGVAL WITH (NOLOCK) WHERE COMPLIANCESUPPLIERCOLORRNGID IN (' + @COMPLIANCESUPPLIERCOLORRNGID + ')')\t\n\t\t\t\t\n\t\t\t\t\t\tEND\n\t\t\t\t\tEND\n\n\t\t\t\tEND\n\n\t\t\tEND\n\t\tEND\n\t\t--stylesuplier\n\t\tIF UPPER(@TABLENAME) = 'STYLESUPLIER'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\t\t\t\t\t\n\t\t\t\tEND\n\t\tEND\n\t\t--stylefollowup\n\t\tIF UPPER(@TABLENAME) = 'STYLEFOLLOWUP'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\t\t\t\t\t\n\t\t\t\tEND\t\n\n\t\t\tDECLARE @STYLEFOLLOWUPID NVARCHAR(MAX)\n\n\t\t\tSELECT @STYLEFOLLOWUPID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLEFOLLOWUPID) FROM FSH1.STYLEFOLLOWUP WHERE STYLEID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\tIF ISNULL(@STYLEFOLLOWUPID,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLEFOLLOWUPVAL','SELECT * FROM ' + @SCHEMA + '.STYLEFOLLOWUPVAL WITH (NOLOCK) WHERE STYLEFOLLOWUPID IN (' + @STYLEFOLLOWUPID + ')')\t\t\t\t\t\n\t\t\tEND\n\t\tEND\n\t\t--stylefollowupinfo\n\t\tIF UPPER(@TABLENAME) = 'STYLEFOLLOWUPINFO'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\n\t\t\tEND\n\t\tEND\n\t\t--styleextra\n\t\tIF UPPER(@TABLENAME) = 'STYLEEXTRA'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\n\t\t\tEND\n\t\tEND\n\t\t--stylechar\n\t\tIF UPPER(@TABLENAME) = 'STYLECHAR'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\n\t\t\tEND\n\t\tEND\n\t\t--sku\n\t\tIF UPPER(@TABLENAME) = 'SKU'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\n\t\t\tEND\n\t\tEND\n\t\t--STYLEVIEW3D\n\t\tIF UPPER(@TABLENAME) = 'STYLEVIEW3D'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\n\t\t\tEND\n\t\tEND\n\t\t--STYLESCULTUREINFO\n\t\tIF UPPER(@TABLENAME) = 'STYLESCULTUREINFO'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE REFID IN (' + @ARCHIVED_STYLES + ')')\t\n\t\t\tEND\n\t\tEND\n\t\t--STPACKV2\n\t\tIF UPPER(@TABLENAME) = 'STPACKV2'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE REFID IN (' + @ARCHIVED_STYLES + ')')\t\n\n\t\t\t\tDECLARE @STPACKV2ID NVARCHAR(MAX)\n\n\t\t\t\tSELECT @STPACKV2ID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STPACKV2ID) FROM FSH1.STPACKV2 WHERE STYLEID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\t\tIF ISNULL(@STPACKV2ID,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('STPACKV2CONT','SELECT * FROM ' + @SCHEMA + '.STPACKV2CONT WITH (NOLOCK) WHERE STPACKV2ID IN (' + @STPACKV2ID + ')')\t\n\n\t\t\t\t\t\tDECLARE @STPACKV2CONTID NVARCHAR(MAX)\n\n\t\t\t\t\t\tSELECT @STPACKV2CONTID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STPACKV2CONTID) FROM FSH1.STPACKV2CONT WHERE STPACKV2ID IN (SELECT VALUE FROM string_split(@STPACKV2ID,',')) FOR XML PATH('')),1,1,'')\n\n\t\t\t\t\t\tIF ISNULL(@STPACKV2CONTID,'0') != '0'\n\t\t\t\t\t\tBEGIN\n\t\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t\t('STPACKV2CONTDTLS','SELECT * FROM ' + @SCHEMA + '.STPACKV2CONTDTLS WITH (NOLOCK) WHERE STPACKV2CONTID IN (' + @STPACKV2CONTID + ')')\t\n\n\t\t\t\t\t\tEND\t\t\t\t\n\t\t\t\tEND\t\t\t\t\n\t\t\tEND\n\t\tEND\n\t\t--BOMLINEMAINMATERIALINFO\n\t\tIF UPPER(@TABLENAME) = 'BOMLINEMAINMATERIALINFO'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE REFID IN (' + @ARCHIVED_STYLES + ')')\t\n\t\t\tEND\n\t\tEND\n\n\t\tFETCH NEXT FROM ARCHIVE_CURSOR INTO @TABLENAME\n\tEND\n\n\tCLOSE ARCHIVE_CURSOR  \n\tDEALLOCATE ARCHIVE_CURSOR\n\n\tSELECT * FROM @RETURNTABLE\nEND","IsPrivate":true,"isUser":false},{"Name":"Get Comments V2 Log","Description":null,"QueryString":"SELECT * FROM SCAH.APPFEATUREAUDIT where [key] = 'comments-v2' order by auditdate desc\n","IsPrivate":false,"isUser":false},{"Name":"GLROLECLASS FIX","Description":null,"QueryString":"SELECT SF.STYLEID, SFL.ROLEID, SFL.USERID,\nCASE WHEN SFL.ROLEID = 1 THEN\n\tS.DESIGNER\nWHEN SFL.ROLEID = 2 THEN\n\tS.TECHDESIGNER\nWHEN SFL.ROLEID = 3 THEN\n\tS.PRODSPECIALIST\nWHEN SFL.ROLEID = 4 THEN\n\tS.FABCOORDINATOR\nWHEN SFL.ROLEID = 5 THEN\n\tS.TRMSPECIALIST\nWHEN SFL.ROLEID = 6 THEN\n\tS.BUYER\nELSE\nNULL\nEND AS ROLESSSS\nFROM FSH382.STYLEFOLLOWUPVAL SFL\nINNER JOIN FSH382.STYLEFOLLOWUP SF\nON SFL.STYLEFOLLOWUPID = SF.STYLEFOLLOWUPID\nINNER JOIN FSH382.STYLE S\nON SF.STYLEID = S.STYLEID\n WHERE ISNULL(SFL.ROLEID,0) > 0\n\n","IsPrivate":true,"isUser":false},{"Name":"FIX GLROLECLASS","Description":null,"QueryString":"UPDATE FSH382.STYLEFOLLOWUPVAL \nSET \n USERID = A.NEW_USERID\nFROM\n(\nSELECT SFL.STYLEFOLLOWUPVALID, SF.STYLEID, SFL.ROLEID, SFL.USERID,\nCASE WHEN SFL.ROLEID = 1 THEN\n\tS.DESIGNER\nWHEN SFL.ROLEID = 2 THEN\n\tS.TECHDESIGNER\nWHEN SFL.ROLEID = 3 THEN\n\tS.PRODSPECIALIST\nWHEN SFL.ROLEID = 4 THEN\n\tS.FABCOORDINATOR\nWHEN SFL.ROLEID = 5 THEN\n\tS.TRMSPECIALIST\nWHEN SFL.ROLEID = 6 THEN\n\tS.COLORIST\nELSE\nNULL\nEND AS NEW_USERID\nFROM FSH382.STYLEFOLLOWUPVAL SFL\nINNER JOIN FSH382.STYLEFOLLOWUP SF\nON SFL.STYLEFOLLOWUPID = SF.STYLEFOLLOWUPID\nINNER JOIN FSH382.STYLE S\nON SF.STYLEID = S.STYLEID\n WHERE ISNULL(SFL.ROLEID,0) > 0\n ) A\n WHERE FSH382.STYLEFOLLOWUPVAL.STYLEFOLLOWUPVALID = A.STYLEFOLLOWUPVALID\n\n","IsPrivate":true,"isUser":false},{"Name":"testing","Description":null,"QueryString":"begin tran\nSELECT 1 FROM fsh1.STYLE WITH (TABLOCKX)\nwaitfor delay '00:00:10'\nrollback tran","IsPrivate":true,"isUser":false},{"Name":"OFFSET","Description":null,"QueryString":"SELECT\nSA.AUDITDATE,\nSA.PRIMARYKEY,\nSAV.COLUMNAME,\nSAV.OLDVALUE,\nSAV.NEWVALUE\nFROM FSH3.STYLEAUDIT SA\nINNER JOIN FSH3.STYLEAUDITVAL SAV\nON SA.STYLEAUDITID = SAV.STYLEAUDITID\nWHERE\nSA.TABLENAME = 'STYLE'\nAND\nSA.AUDITDATE BETWEEN '01/28/2025 00:00:00' AND '03/25/2025 23:59:59'\nAND\nSAV.COLUMNAME = 'NAME' \norder by sa.auditdate,sa.primarykey\nOFFSET 60001 ROWS FETCH NEXT 30000 ROWS ONLY;\n\n","IsPrivate":false,"isUser":false},{"Name":"QUERY STYLEAUDIT","Description":"QUERY STYLEAUDIT","QueryString":"DECLARE @IDS NVARCHAR(MAX)\n\nSELECT @IDS = STUFF((\nselect  ',' + convert(nvarchar(20),SA.STYLEAUDITID) \nFROM FSH3.STYLEAUDIT SA WITH (NOLOCK)\nWHERE\nSA.AUDITDATE BETWEEN '01/28/2025 00:00:00' AND '03/25/2025 23:59:59'\nAND SA.TABLENAME = 'STYLE'\nORDER BY 1\nOFFSET 1200001 ROWS FETCH NEXT 100000 ROWS ONLY\n FOR XML PATH(''))\n,1,1,'') \n\nDECLARE @TABLE_STYLEAUDITVAL TABLE (STYLEAUDITVALID INT, STYLEAUDITID INT, COLUMNAME NVARCHAR(MAX), OLDVALUE NVARCHAR(MAX),NEWVALUE NVARCHAR(MAX))\n\n\n\n\nDECLARE @ID INT\n\n\nDECLARE SAMPLE_CURSOR CURSOR FOR \nSELECT VALUE FROM string_split(@IDS,',')\n\nOPEN SAMPLE_CURSOR  \nFETCH NEXT FROM SAMPLE_CURSOR INTO @ID  \n\nWHILE @@FETCH_STATUS = 0  \nBEGIN  \n\n\t\n\tINSERT INTO @TABLE_STYLEAUDITVAL\n\t(STYLEAUDITVALID , STYLEAUDITID , COLUMNAME , OLDVALUE ,NEWVALUE)\n\tSELECT * FROM FSH3.STYLEAUDITVAL WHERE STYLEAUDITID = @ID AND COLUMNAME = 'NAME'\n\tFETCH NEXT FROM SAMPLE_CURSOR INTO @ID \nEND \n\nCLOSE SAMPLE_CURSOR  \nDEALLOCATE SAMPLE_CURSOR\n\n\n\nSELECT * FROM @TABLE_STYLEAUDITVAL\n\n","IsPrivate":true,"isUser":false},{"Name":"Get specific trigger","Description":null,"QueryString":"SELECT \n    trg.name AS TriggerName,\n    sch.name AS SchemaName,\n    tbl.name AS TableName,\n    trg.is_disabled AS IsDisabled,\n    mod.definition AS TriggerDefinition\nFROM \n    sys.triggers trg\nJOIN \n    sys.tables tbl ON trg.parent_id = tbl.object_id\nJOIN \n    sys.schemas sch ON tbl.schema_id = sch.schema_id\nJOIN \n    sys.sql_modules mod ON trg.object_id = mod.object_id\nWHERE \n    tbl.name = 'REQUEST'\n    AND sch.name = 'FSH882';\n","IsPrivate":true,"isUser":false},{"Name":"Archiving List","Description":null,"QueryString":"\nUPDATE SCAH.APPSETTINGCE\nSET [VALUE] = 'STYLE,DICTIONARYMODULE,STYLECOLORRNG,ATTAFILELIST,STYLESIZECATRNG,STYLEMEAS,STYLEBOM,STYLEBOL,STYLEPATTERNPAGE,STYLEMARKERPAGE,STYLELABEL,STYLECOSTING,COMPLIANCE,STYLECOLORRNGVAL,STYLECOLORRNGCHANNEL,STYLECOLORDELIVERY,STYLECOLORRNGMF1,STYLECOLORRNGUDF12,STYLECOLORRNGUDF13,ATTADETAILS,STYLESIZE,STYLEMEASGR,STYLEMEASSIZE,STYLEMEASPOM,STYLEMEASPOMSIZE,STYLEMEASUREMENTPOMCULTUREINFO,STYLESAMP,STYLESAMPPOMDETAILS,STYLESAMPPOMSIZE,STYLESAMPPOMSIZEVALUES,STYLESAMPSIZECOLOR,BOMLINE,BOMLINEALLSTYLESIZEQTY,BOMLINECELLCOLORRNG,BOMLINECOLORRNG,BOMLINECOLORRNGVAL,BOMLINESIZECATRNG,BOMLINESIZE,STYLEBOLBOMVER,STYLEBOLOPERATION,STYLEBOLOPSINS,STYLEPATTERNPIECE,STYLEMARKERPAGETABLE,STYLELABELINST,STYLELABELPART,STYLECOSTINGELEMENT,STYLECOSTINGSUPPLIER,STYLECOSTINGSUPPLIERVAL,COMPLIANCETEST,COMPLIANCESUPPLIER,COMPLIANCESUPPLIERVAL,COMPLIANCESUPPLIERCOLORRNG,COMPLIANCESUPPLIERCOLORRNGVAL,STYLESOURCING,STYLESUPLIER,STYLEFOLLOWUP,STYLEFOLLOWUPVAL,STYLEFOLLOWUPINFO,STYLEEXTRA,STYLECHAR,SKU,STYLEVIEW3D,STYLESCULTUREINFO,STPACKV2,STPACKV2CONT,STPACKV2CONTDTLS,BOMLINEMAINMATERIALINFO'\nWHERE [KEY] = 'archived_module_list'","IsPrivate":true,"isUser":false},{"Name":"Insert stylecostingsupplier","Description":null,"QueryString":"\nDECLARE @Count INT = 10000;\n\n\nDECLARE @SourceID INT = 629;\nDECLARE @InsertedIDs TABLE (\n    ID INT\n);\n\n\nWITH Numbers AS (\n    SELECT TOP (@Count) ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS n\n    FROM sys.all_objects \n)\n\n-- Insert 100 duplicates into the table\nINSERT INTO FSH129.STYLECOSTINGSUPPLIER ([STYLECOSTINGID],[STYLESUPID],[LEADTIME],[LEADTIMEUOM],[CURRENCYID],[MINQTY],[MINQTYUOM],[BOMVERSIONID],[ISMAINVERSION],[ITERATIONNO],[ISACTIVE],[DELIVERYTRMID],[DELIVERYMTID],[COUNTRYID],[STYLECOLORRNGID],[REQUESTID],[FREEFIELD],[COSTINGDATE],[STATUS],[ISLOCK],[EXCHRATETYPE],[EXCHRATEDATE],[STYLECOLORRNGIDLIST]\n,[SUPPCURRID],[PAYMENTTRMID],[QUOTEDATE],[VALIDFROM],[VALIDTO],[AGREEMENTNUM],[SUPPREFNUM],[RESPATSUPP]\n,[NOTESTOSUPP],[FREEFIELD2],[ISLINKEDFROMSOURCING])\nOUTPUT INSERTED.STYLECOSTINGSUPPLIERID INTO @InsertedIDs(ID)\nSELECT \n[STYLECOSTINGID],[STYLESUPID],[LEADTIME],[LEADTIMEUOM],[CURRENCYID],[MINQTY],[MINQTYUOM],[BOMVERSIONID],[ISMAINVERSION],[ITERATIONNO],[ISACTIVE],[DELIVERYTRMID],[DELIVERYMTID],[COUNTRYID],[STYLECOLORRNGID],[REQUESTID],[FREEFIELD],[COSTINGDATE],[STATUS],[ISLOCK],[EXCHRATETYPE],[EXCHRATEDATE],[STYLECOLORRNGIDLIST]\n,[SUPPCURRID],[PAYMENTTRMID],[QUOTEDATE],[VALIDFROM],[VALIDTO],[AGREEMENTNUM],[SUPPREFNUM],[RESPATSUPP]\n,[NOTESTOSUPP],[FREEFIELD2],[ISLINKEDFROMSOURCING]\nFROM \n    FSH129.STYLECOSTINGSUPPLIER YT\nCROSS JOIN \n    Numbers\nWHERE \n   YT.STYLECOSTINGSUPPLIERID = @SourceID;\n\n\nINSERT INTO FSH129.STYLECOSTINGSUPPLIERVAL\n(STYLECOSTINGSUPPLIERID,STYLECOSTINGELEMENTID,VALUE)\nSELECT ID,SCSV.STYLECOSTINGELEMENTID, SCSV.VALUE  from @InsertedIDs \nCROSS JOIN\nFSH129.STYLECOSTINGSUPPLIERVAL SCSV\nWHERE SCSV.STYLECOSTINGSUPPLIERID = @SourceID\n\n","IsPrivate":true,"isUser":false},{"Name":"Delete Schema","Description":null,"QueryString":"DECLARE @SchemaName NVARCHAR(128) = 'YourSchemaName';\nDECLARE @sql NVARCHAR(MAX) = '';\n\n-- Drop Triggers\nSELECT @sql += 'DROP TRIGGER [' + s.name + '].[' + o.name + '];' + CHAR(13)\nFROM sys.objects o\nJOIN sys.schemas s ON o.schema_id = s.schema_id\nWHERE s.name = @SchemaName AND o.type = 'TR'; -- SQL DML Triggers\n\n-- Drop Foreign Keys (to allow dropping of tables)\nSELECT @sql += 'ALTER TABLE [' + s.name + '].[' + t.name + '] DROP CONSTRAINT [' + fk.name + '];' + CHAR(13)\nFROM sys.foreign_keys fk\nJOIN sys.tables t ON fk.parent_object_id = t.object_id\nJOIN sys.schemas s ON t.schema_id = s.schema_id\nWHERE s.name = @SchemaName;\n\n-- Drop Views\nSELECT @sql += 'DROP VIEW [' + s.name + '].[' + o.name + '];' + CHAR(13)\nFROM sys.views o\nJOIN sys.schemas s ON o.schema_id = s.schema_id\nWHERE s.name = @SchemaName;\n\n-- Drop Stored Procedures\nSELECT @sql += 'DROP PROCEDURE [' + s.name + '].[' + o.name + '];' + CHAR(13)\nFROM sys.procedures o\nJOIN sys.schemas s ON o.schema_id = s.schema_id\nWHERE s.name = @SchemaName;\n\n-- Drop Functions (scalar, table-valued)\nSELECT @sql += 'DROP FUNCTION [' + s.name + '].[' + o.name + '];' + CHAR(13)\nFROM sys.objects o\nJOIN sys.schemas s ON o.schema_id = s.schema_id\nWHERE s.name = @SchemaName AND o.type IN ('FN', 'TF', 'IF');\n\n-- Drop Synonyms\nSELECT @sql += 'DROP SYNONYM [' + s.name + '].[' + sn.name + '];' + CHAR(13)\nFROM sys.synonyms sn\nJOIN sys.schemas s ON sn.schema_id = s.schema_id\nWHERE s.name = @SchemaName;\n\n-- Drop Sequences\nSELECT @sql += 'DROP SEQUENCE [' + s.name + '].[' + sq.name + '];' + CHAR(13)\nFROM sys.sequences sq\nJOIN sys.schemas s ON sq.schema_id = s.schema_id\nWHERE s.name = @SchemaName;\n\n-- Drop Defaults\nSELECT @sql += 'DROP DEFAULT [' + s.name + '].[' + d.name + '];' + CHAR(13)\nFROM sys.objects d\nJOIN sys.schemas s ON d.schema_id = s.schema_id\nWHERE s.name = @SchemaName AND d.type = 'D';\n\n-- Drop User-Defined Types\nSELECT @sql += 'DROP TYPE [' + s.name + '].[' + t.name + '];' + CHAR(13)\nFROM sys.types t\nJOIN sys.schemas s ON t.schema_id = s.schema_id\nWHERE s.name = @SchemaName AND t.is_user_defined = 1;\n\n-- Drop Tables\nSELECT @sql += 'DROP TABLE [' + s.name + '].[' + t.name + '];' + CHAR(13)\nFROM sys.tables t\nJOIN sys.schemas s ON t.schema_id = s.schema_id\nWHERE s.name = @SchemaName;\n\n-- Finally drop the schema\nSET @sql += 'DROP SCHEMA [' + @SchemaName + '];';\n\n-- Print for verification (optional)\nPRINT @sql;\n","IsPrivate":true,"isUser":false},{"Name":"test123","Description":null,"QueryString":"Select * from scah.dataschemas","IsPrivate":false,"isUser":true},{"Name":"Last seven days","Description":null,"QueryString":"SELECT *\nFROM SCAH.TASKMONITOR\nWHERE DATECREATED >= DATEADD(DAY, -7, GETDATE())\nORDER BY TASKMONID \nOFFSET 0 ROWS FETCH NEXT 100000 ROWS ONLY;\n","IsPrivate":false,"isUser":true}],"Languages":[{"Name":"English","Culture":"en-US"},{"Name":"Spanish","Culture":"es-ES"},{"Name":"French","Culture":"fr-FR"},{"Name":"Chinese","Culture":"zh-CN"},{"Name":"Turkish","Culture":"tr-TR"},{"Name":"German","Culture":"de-DE"},{"Name":"Italian","Culture":"it-IT"}],"Regions":[{"Id":1,"RegionName":"US Environment","RegionEndPoint":"https://prd-use1.fplm.inforcloudsuite.com/api/provision/tenants/dbupgrade","RegionClientId":"fplmprd01","RegionClientSecret":"margaritifer22","RegionUpgradePath":null,"RegionUpgradeBody":null,"Headers":[],"HeaderEnvironmentId":43},{"Id":2,"RegionName":"EU Environment","RegionEndPoint":"https://prd-euc1.fplm.eu1.inforcloudsuite.com/api/provision/tenants/dbupgrade","RegionClientId":"fplmprdeuc01","RegionClientSecret":"cassini17","RegionUpgradePath":null,"RegionUpgradeBody":null,"Headers":[],"HeaderEnvironmentId":42},{"Id":3,"RegionName":"QA Environment test","RegionEndPoint":"https://QA.fplm.dev.inforcloudsuite.com/api/provision/tenants/dbupgrade","RegionClientId":"fplminternal","RegionClientSecret":"mlpnoihsafrofni","RegionUpgradePath":"https://qa.fplm.dev.inforcloudsuite.com/api/job/tasks","RegionUpgradeBody":"{\n               \"TaskId\": \"upgradeSchema\",\n               \"IsSystem\": true,\n               \"CustomData\": [],\n               \"Sequence\": 1\n}","Headers":[{"Key":"Content-Type","Value":"application/json"},{"Key":"x-fplm-client","Value":"1"},{"Key":"x-ionapi-forwarded-proto","Value":" "},{"Key":"X-Infor-TenantId","Value":null}],"HeaderEnvironmentId":44},{"Id":4,"RegionName":"DEV Environment","RegionEndPoint":"https://DEV.fplm.dev.inforcloudsuite.com/api/provision/tenants/dbupgrade","RegionClientId":"fplminternal","RegionClientSecret":"mlpnoihsafrofni","RegionUpgradePath":"https://dev.fplm.dev.inforcloudsuite.com/api/job/tasks","RegionUpgradeBody":"{\n               \"TaskId\": \"upgradeSchema\",\n               \"IsSystem\": true,\n               \"CustomData\": [],\n               \"Sequence\": 1\n}\n","Headers":[{"Key":"Content-Type","Value":"application/json"},{"Key":"x-fplm-client","Value":"1"},{"Key":"X-Infor-TenantId","Value":""},{"Key":"x-ionapi-forwarded-proto","Value":" "}],"HeaderEnvironmentId":60},{"Id":5,"RegionName":"Local Odata","RegionEndPoint":"http://localhost:5000/api/provision/tenants/dbupgrade","RegionClientId":"fplminternal","RegionClientSecret":"mlpnoihsafrofni","RegionUpgradePath":null,"RegionUpgradeBody":null,"Headers":[],"HeaderEnvironmentId":4},{"Id":6,"RegionName":"Bugfix Environment","RegionEndPoint":"https://bugfix.fplm.dev.inforcloudsuite.com/api/provision/tenants/dbupgrade","RegionClientId":"fplminternal","RegionClientSecret":"mlpnoihsafrofni","RegionUpgradePath":"https://bugfix.fplm.dev.inforcl