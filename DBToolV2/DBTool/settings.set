,"IsWindowsAuthentication":false},"DefaultFSH":null,"IDMTask":"","ThumbnailTask":"","IONAPI":"","TenantList":"","GetDataGrowth":false,"isUS":false,"isEU":false},{"Id":61,"EnvironmentName":"L746ARYR7JN2LPC6_PRD","TenantName":"L746ARYR7JN2LPC6_PRD","Headers":{"X-Infor-TenantId":"ANY_EU_TENANT","content-type":"application/json","x-fplm-schema":"FSH1"},"EndPoint":"https://prd-euc1.fplm.eu1.inforcloudsuite.com/api/odata/getqueryCOMPRESSED","ClientId":"fplmprdeuc01","ClientSecret":"cassini17","Resource":"","TokenUrl":"","Username":"","Password":"","Token":null,"isOAuth1":true,"SQLDBInfo":{"Server":"","Username":"","Password":"","IsWindowsAuthentication":false},"DefaultFSH":null,"IDMTask":"","ThumbnailTask":"","IONAPI":"","TenantList":"","GetDataGrowth":false,"isUS":false,"isEU":false},{"Id":62,"EnvironmentName":"L746ARYR7JN2LPC6_TST","TenantName":"L746ARYR7JN2LPC6_TST","Headers":{"X-Infor-TenantId":"ANY_EU_TENANT","content-type":"application/json","x-fplm-schema":"FSH1"},"EndPoint":"https://prd-euc1.fplm.eu1.inforcloudsuite.com/api/odata/getqueryCOMPRESSED","ClientId":"fplmprdeuc01","ClientSecret":"cassini17","Resource":"","TokenUrl":"","Username":"","Password":"","Token":null,"isOAuth1":true,"SQLDBInfo":{"Server":"","Username":"","Password":"","IsWindowsAuthentication":false},"DefaultFSH":null,"IDMTask":"","ThumbnailTask":"","IONAPI":"","TenantList":"","GetDataGrowth":false,"isUS":false,"isEU":false},{"Id":63,"EnvironmentName":"L746ARYR7JN2LPC6_TRN","TenantName":"L746ARYR7JN2LPC6_TRN","Headers":{"X-Infor-TenantId":"ANY_EU_TENANT","content-type":"application/json","x-fplm-schema":"FSH1"},"EndPoint":"https://prd-euc1.fplm.eu1.inforcloudsuite.com/api/odata/getqueryCOMPRESSED","ClientId":"fplmprdeuc01","ClientSecret":"cassini17","Resource":"","TokenUrl":"","Username":"","Password":"","Token":null,"isOAuth1":true,"SQLDBInfo":{"Server":"","Username":"","Password":"","IsWindowsAuthentication":false},"DefaultFSH":null,"IDMTask":"","ThumbnailTask":"","IONAPI":"","TenantList":"","GetDataGrowth":false,"isUS":false,"isEU":false},{"Id":64,"EnvironmentName":"ANY_HOTFIX_TENANT","TenantName":"ANY_HOTFIX_TENANT","Headers":{"X-Infor-TenantId":"ANY_CQA_TENANT","content-type":"application/json","x-fplm-schema":"FSH1"},"EndPoint":"https://hotfix.fplm.dev.inforcloudsuite.com/api/odata2/getquerycompressed","ClientId":"fplminternal","ClientSecret":"mlpnoihsafrofni","Resource":"","TokenUrl":"","Username":"","Password":"","Token":null,"isOAuth1":true,"SQLDBInfo":{"Server":"","Username":"","Password":"","IsWindowsAuthentication":false},"DefaultFSH":null,"IDMTask":"","ThumbnailTask":"","IONAPI":"","TenantList":"","GetDataGrowth":false,"isUS":false,"isEU":false},{"Id":65,"EnvironmentName":"ANY_UAT_TENANT","TenantName":"ANY_UAT_TENANT","Headers":{"X-Infor-TenantId":"ANY_CQA_TENANT","content-type":"application/json","x-fplm-schema":"FSH1"},"EndPoint":"https://uat.fplm.dev.inforcloudsuite.com/api/odata2/getquery","ClientId":"fplminternal","ClientSecret":"mlpnoihsafrofni","Resource":"","TokenUrl":"","Username":"","Password":"","Token":null,"isOAuth1":true,"SQLDBInfo":{"Server":"","Username":"","Password":"","IsWindowsAuthentication":false},"DefaultFSH":null,"IDMTask":"","ThumbnailTask":"","IONAPI":"","TenantList":"","GetDataGrowth":false,"isUS":false,"isEU":false},{"Id":66,"EnvironmentName":"local2","TenantName":"local2","Headers":{"X-Infor-TenantId":"Local","content-type":"application/json","x-fplm-schema":"FSH1"},"EndPoint":"http://localhost:5018/api/odata2/getquerycompressed","ClientId":"fplminternal","ClientSecret":"mlpnoihsafrofni","Resource":"","TokenUrl":"","Username":"","Password":"","Token":null,"isOAuth1":false,"SQLDBInfo":{"Server":".","Username":"","Password":"","IsWindowsAuthentication":true},"DefaultFSH":null,"IDMTask":"","ThumbnailTask":"","IONAPI":"","TenantList":"","GetDataGrowth":false,"isUS":false,"isEU":false},{"Id":67,"EnvironmentName":"ANY_PEN_TEST_TENANT","TenantName":"ANY_PEN_TEST_TENANT","Headers":{"X-Infor-TenantId":"ANY_POC_TENANT","content-type":"application/json","x-fplm-schema":"FSH1"},"EndPoint":"https://pentest.fplm.dev.inforcloudsuite.com/api/odata2/getqueryCOMPRESSED","ClientId":"fplminternal","ClientSecret":"mlpnoihsafrofni","Resource":"","TokenUrl":"","Username":"","Password":"","Token":null,"isOAuth1":true,"SQLDBInfo":{"Server":"","Username":"","Password":"","IsWindowsAuthentication":false},"DefaultFSH":null,"IDMTask":"","ThumbnailTask":"","IONAPI":"","TenantList":null,"GetDataGrowth":false,"isUS":false,"isEU":false}],"Mapping":[{"Key":"TenantName","Value":"Environments"},{"Key":"TenantName2","Value":"Tenant Name2"}],"Queries":[{"Name":"Delete Material CultureInfo","Description":"To delete multiple material cultureinfo","QueryString":"DELETE M FROM\n( SELECT ROW_NUMBER() OVER (PARTITION BY REFID, CULTURE ORDER BY MODIFYDATE DESC) AS CNT,  * FROM <%schema_name%>.MATERIALSCULTUREINFO ) M\nWHERE M.CNT > 1\n","IsPrivate":false,"isUser":false},{"Name":"Get row count without column count","Description":"get all row count of each table without column count","QueryString":"DECLARE @QueryString NVARCHAR(MAX) ;\nSELECT @QueryString = COALESCE(@QueryString + ' UNION ALL ','')                      \n+ 'SELECT '                       \n+'''' + SCHEMA_NAME(sOBJ.schema_id) + '''' \n+ ' AS [Schema], '\n+                      \n+ '''' \n+ QUOTENAME(sOBJ.name) \n+ '''' \n+ ' AS [TableName],'                                           \n+ ' COUNT(*) AS [RowCount] FROM '                      \n+ QUOTENAME(SCHEMA_NAME(sOBJ.schema_id))                     \n+ '.' + QUOTENAME(sOBJ.name) \n+ ' WITH (NOLOCK) '\nFROM sys.objects AS sOBJ WHERE SCHEMA_NAME(sOBJ.schema_id) = '<%SCHEMA_NAME%>' \nAND      sOBJ.type = 'U'      \nAND sOBJ.is_ms_shipped = 0x0\nORDER BY SCHEMA_NAME(sOBJ.schema_id), sOBJ.name ;\n\nEXEC sp_executesql @QueryString","IsPrivate":false,"isUser":false},{"Name":"Get row count with column count","Description":"get all row count of each table with column count","QueryString":"DECLARE @QueryString NVARCHAR(MAX) ;\nSELECT @QueryString = COALESCE(@QueryString + ' UNION ALL ','')                      \n+ 'SELECT '                       \n+'''' + SCHEMA_NAME(sOBJ.schema_id) \n+ '''' \n+ ' AS [Schema], '\n+                      \n+ '''' \n+ QUOTENAME(sOBJ.name) \n+ '''' \n+ ' AS [TableName],'                                          \n+ ' COUNT(*) AS [RowCount],'                      \n+  convert(nvarchar(50), COUNT(sOBJ.name)) \n+ ' AS [ColumnCount] FROM '                     \n+ QUOTENAME(SCHEMA_NAME(sOBJ.schema_id))                     \n+ '.' + QUOTENAME(sOBJ.name) \n+ ' WITH (NOLOCK) '\nFROM sys.objects sOBJ\nINNER JOIN INFORMATION_SCHEMA.COLUMNS IC\nON SCHEMA_NAME(sOBJ.schema_id) = IC.TABLE_SCHEMA \nAND QUOTENAME(sOBJ.name) = QUOTENAME(IC.TABLE_NAME)WHERE\nSCHEMA_NAME(sOBJ.schema_id) = '<%schema_name%>' \nAND      sOBJ.type = 'U'      AND sOBJ.is_ms_shipped = 0x0\nGROUP BY SCHEMA_NAME(sOBJ.schema_id),\nQUOTENAME(sOBJ.name)\nORDER BY \nSCHEMA_NAME(sOBJ.schema_id), \nQUOTENAME(sOBJ.name) \n\nEXEC sp_executesql @QueryString","IsPrivate":false,"isUser":false},{"Name":"Check duplicate material cultureinfo","Description":"","QueryString":"SELECT REFID, CULTURE, COUNT(REFID) COUNT FROM <%SCHEMA_NAME%>.MATERIALSCULTUREINFO\nGROUP BY REFID,CULTURE\nHAVING COUNT(REFID)> 1","IsPrivate":false,"isUser":false},{"Name":"Clean up duplicate material cultureinfo","Description":"","QueryString":"DELETE M FROM\n(SELECT ROW_NUMBER() OVER (PARTITION BY REFID, CULTURE ORDER BY MODIFYDATE) CNT, * FROM <%SCHEMA_NAME%>.MATERIALSCULTUREINFO) M\nWHERE M.CNT > 1","IsPrivate":false,"isUser":false},{"Name":"Sp Helptext","Description":"","QueryString":"SELECT OBJECT_DEFINITION (OBJECT_ID(N'<%SCHEMA_NAME%>.Your_SP'))","IsPrivate":false,"isUser":false},{"Name":"Update appfeature","Description":"","QueryString":"\nALTER TABLE [SCAH].[APPFEATURE] DISABLE TRIGGER [APPFEATURE_AUDIT_UPDATE]\n\n\nDECLARE @APPFEATUREKEY NVARCHAR(100) = N''\n\nIF EXISTS(SELECT 1 FROM SCAH.APPFEATURE WHERE [KEY]=@APPFEATUREKEY)\nBEGIN\n    UPDATE SCAH.APPFEATURE\n    SET ENABLED=1\n    WHERE [KEY]=@APPFEATUREKEY\nEND\n\n\nALTER TABLE [SCAH].[APPFEATURE] ENABLE TRIGGER [APPFEATURE_AUDIT_UPDATE]\n\n\n\n\n\n","IsPrivate":false,"isUser":false},{"Name":"Get table index","Description":"","QueryString":"SP_HELPINDEX '<TABLE_NAME'>","IsPrivate":false,"isUser":false},{"Name":"Down Grade Version","Description":"","QueryString":"UPDATE SCAH.SCVERINFO SET [VERSION] = '{0}'","IsPrivate":false,"isUser":false},{"Name":"Get schema","Description":null,"QueryString":"SELECT * FROM <%SCHEMA_NAME%>.DATASCHEMAS","IsPrivate":false,"isUser":false},{"Name":"STYLE NAME NOT EQUAL","Description":null,"QueryString":"SELECT S.STYLEID, SC.CULTURE, S.NAME AS 'STYLETABLE - NAME', SC.NAME AS 'STYLESCULTUREINFO - NAME'  FROM <%SCHEMA_NAME%>.STYLE S\nINNER JOIN <%SCHEMA_NAME%>.STYLESCULTUREINFO SC\nON S.STYLEID = SC.REFID\nWHERE ISNULL(S.NAME,'') != ISNULL(SC.NAME,'')","IsPrivate":false,"isUser":false},{"Name":"STYLE DESCRIPTION NOT EQUAL","Description":null,"QueryString":"SELECT S.STYLEID, SC.CULTURE, S.DESCRIPTION AS 'STYLETABLE - DESCRIPTION', SC.DESCRIPTION  AS 'STYLESCULTUREINFO - DESCRIPTION'  FROM <%SCHEMA_NAME%>.STYLE S\nINNER JOIN <%SCHEMA_NAME%>.STYLESCULTUREINFO SC\nON S.STYLEID = SC.REFID\nWHERE ISNULL(S.DESCRIPTION,'') != ISNULL(SC.DESCRIPTION,'')","IsPrivate":false,"isUser":false},{"Name":"STYLE MEASPOM NAME NOT EQUAL","Description":null,"QueryString":"SELECT\nSMP.STYLEMEASPOMID, SM.CULTURE, SMP.POMNAME AS 'STYLEMEASPOMTABLE - NAME',\nSM.NAME AS 'STYLEMEASPOMCULTURETABLE - NAME'\nFROM <%SCHEMA_NAME%>.STYLEMEASUREMENTPOMCULTUREINFO SM\nINNER JOIN <%SCHEMA_NAME%>.STYLEMEASPOM SMP\nON SM.REFID = SMP.STYLEMEASPOMID\nWHERE ISNULL(SM.NAME,'') != ISNULL(SMP.POMNAME,'') ","IsPrivate":false,"isUser":false},{"Name":"STYLE MEASPOM DESCRIPTION NOT EQUAL","Description":null,"QueryString":"\nSELECT\nSMP.STYLEMEASPOMID, SM.CULTURE, SMP.POMDESC AS 'STYLEMEASPOMTABLE - DESCRIPTION',\nSM.DESCRIPTION AS 'STYLEMEASPOMCULTURETABLE - DESCRIPTION'\nFROM <%SCHEMA_NAME%>.STYLEMEASUREMENTPOMCULTUREINFO SM\nINNER JOIN <%SCHEMA_NAME%>.STYLEMEASPOM SMP\nON SM.REFID = SMP.STYLEMEASPOMID\nWHERE ISNULL(SM.DESCRIPTION,'') != ISNULL(SMP.POMDESC,'') ","IsPrivate":false,"isUser":false},{"Name":"BOMLINE PLACEMENT NOT EQUAL","Description":null,"QueryString":"SELECT BL.BOMLINEID, BC.CULTURE, BL.PLACEMENT AS 'BOMLINETABLE - PLACEMENT', \nBC.PLACEMENT AS 'BOMLINECULTUREINFOTABLE - PLACEMENT' FROM <%SCHEMA_NAME%>.BOMLINECULTUREINFO BC\nINNER JOIN <%SCHEMA_NAME%>.BOMLINE BL\nON BC.REFID = BL.BOMLINEID\nWHERE ISNULL(bl.PLACEMENT,'') != ISNULL(bc.PLACEMENT,'')  \n","IsPrivate":false,"isUser":false},{"Name":"MATERIAL NAME NOT EQUAL","Description":null,"QueryString":"SELECT F.FABRICID, MC.CULTURE, F.FABRICNAME AS 'MATERIALTABLE - NAME',\nMC.NAME AS 'MATERIALCULTURETABLE - NAME' FROM <%SCHEMA_NAME%>.MATERIALSCULTUREINFO MC\nINNER JOIN <%SCHEMA_NAME%>.FABRIC F\nON MC.REFID = F.FABRICID\nWHERE ISNULL(MC.NAME,'') != ISNULL(F.FABRICNAME,'')","IsPrivate":false,"isUser":false},{"Name":"MAT ERIAL DESCRIPTION NOT EQUAL","Description":null,"QueryString":"SELECT F.FABRICID, MC.CULTURE, F.DESCRIPTION AS 'MATERIALTABLE - DESCRIPTION',\nMC.DESCRIPTION AS 'MATERIALCULTURETABLE - DESCRIPTION' FROM <%SCHEMA_NAME%>.MATERIALSCULTUREINFO MC\nINNER JOIN <%SCHEMA_NAME%>.FABRIC F\nON MC.REFID = F.FABRICID\nWHERE ISNULL(MC.DESCRIPTION,'') != ISNULL(F.DESCRIPTION,'')","IsPrivate":false,"isUser":false},{"Name":"TRIM NAME NOT EQUAL","Description":null,"QueryString":"SELECT T.TRIMID, TC.CULTURE, T.NAME AS 'TRIMTABLE - NAME',\nTC.NAME AS 'TRIMCULTURETABLE - NAME' FROM <%SCHEMA_NAME%>.TRIMSCULTUREINFO TC\nINNER JOIN <%SCHEMA_NAME%>.TRIM T\nON TC.REFID = T.TRIMID\nWHERE ISNULL(TC.NAME,'') != ISNULL(T.NAME,'')","IsPrivate":false,"isUser":false},{"Name":"TRIM DESCRIPTION NOT EQUAL","Description":null,"QueryString":"SELECT T.TRIMID, TC.CULTURE, T.DESCRIPTION AS 'TRIMTABLE - DESCRIPTION',\nTC.DESCRIPTION AS 'TRIMCULTURETABLE - DESCRIPTION' FROM <%SCHEMA_NAME%>.TRIMSCULTUREINFO TC\nINNER JOIN <%SCHEMA_NAME%>.TRIM T\nON TC.REFID = T.TRIMID\nWHERE ISNULL(TC.DESCRIPTION,'') != ISNULL(T.DESCRIPTION,'')","IsPrivate":false,"isUser":false},{"Name":"Get style code duplicate","Description":null,"QueryString":"SELECT STYLECODE FROM <%SCHEMA_NAME%>.STYLE WHERE ISDELETED = 0 AND CREATEDATE BETWEEN '' AND '' GROUP BY STYLECODE HAVING COUNT(STYLECODE) > 1","IsPrivate":false,"isUser":false},{"Name":"Datagrowth","Description":"get all row count of each table without column count","QueryString":"DECLARE @QueryString NVARCHAR(MAX) ;\nSELECT @QueryString = COALESCE(@QueryString + ' UNION ALL ','')                      \n+ 'SELECT '                       \n+'''' + SCHEMA_NAME(sOBJ.schema_id) + '''' \n+ ' AS [Schema], '\n+                      \n+ '''' \n+ QUOTENAME(sOBJ.name) \n+ '''' \n+ ' AS [TableName],'                                           \n+ ' COUNT(*) AS [RowCount] FROM '                      \n+ QUOTENAME(SCHEMA_NAME(sOBJ.schema_id))                     \n+ '.' + QUOTENAME(sOBJ.name) \n+ ' WITH (NOLOCK) '\nFROM sys.objects AS sOBJ WHERE SCHEMA_NAME(sOBJ.schema_id) = '<%SCHEMA_NAME%>' \nAND      sOBJ.type = 'U'      \nAND sOBJ.is_ms_shipped = 0x0\nORDER BY SCHEMA_NAME(sOBJ.schema_id), sOBJ.name ;\n\nEXEC sp_executesql @QueryString","IsPrivate":true,"isUser":false},{"Name":"OdataV1Allowed True","Description":null,"QueryString":"\nUPDATE SCAH.APPSETTINGCE\nSET [VALUE] = 'true'\n WHERE [KEY] = 'ODATAV1ALLOWED'\n","IsPrivate":false,"isUser":false},{"Name":"OdataV1Allowed False","Description":null,"QueryString":"\nUPDATE SCAH.APPSETTINGCE\nSET [VALUE] = 'false'\n WHERE [KEY] = 'ODATAV1ALLOWED'\n","IsPrivate":false,"isUser":false},{"Name":"Odata restriction","Description":null,"QueryString":"\nIF NOT EXISTS ( SELECT 1 FROM SCAH.APPSETTINGCE WHERE [KEY] = 'ODATAv1Allowed')\nBEGIN\n\tINSERT INTO SCAH.APPSETTINGCE\n\t([KEY],[VALUE])\n\tVALUES\n\t('ODATAv1Allowed','true')\nEND\n\n\nIF NOT EXISTS ( SELECT 1 FROM SCAH.APPSETTINGCE WHERE [KEY] = 'OdataTenantAllowed')\nBEGIN\n\tINSERT INTO SCAH.APPSETTINGCE\n\t([KEY],[VALUE])\n\tVALUES\n\t('OdataTenantAllowed','true')\nEND\n\nIF NOT EXISTS ( SELECT 1 FROM SCAH.APPSETTINGCE WHERE [KEY] = 'OdataEntitiesNotAllowed')\nBEGIN\n\tINSERT INTO SCAH.APPSETTINGCE\n\t([KEY],[VALUE])\n\tVALUES\n\t('OdataEntitiesNotAllowed','StyleCosting')\nEND\n","IsPrivate":false,"isUser":false},{"Name":"Update ODATAv1Allowed","Description":null,"QueryString":"UPDATE SCAH.APPSETTINGCE\nSET\n[VALUE] = 'true'\nWHERE\n[KEY] = 'ODATAv1Allowed'","IsPrivate":false,"isUser":false},{"Name":"Update OdataTenantAllowed","Description":null,"QueryString":"UPDATE SCAH.APPSETTINGCE\nSET\n[VALUE] = 'true'\nWHERE\n[KEY] = 'OdataTenantAllowed'","IsPrivate":false,"isUser":false},{"Name":"Update OdataEntitiesNotAllowed","Description":null,"QueryString":"UPDATE SCAH.APPSETTINGCE\nSET\n[VALUE] = 'StyleCosting'\nWHERE\n[KEY] = 'OdataEntitiesNotAllowed'","IsPrivate":false,"isUser":false},{"Name":"Style Pviot cultureinfo","Description":null,"QueryString":"\nSELECT *\nFROM\n(\nSELECT STYLEID AS STYLEID, STYLECODE, [NAME],\n[en-US] as [NAME_en-US],[en-GB] as [NAME_en-GB]\nFROM\n(\nSELECT \nS.STYLEID,\nS.STYLECODE,\nS.NAME,\nSC.NAME AS [VALUE],\nSC.CULTURE AS CULTURE\nFROM\nFSH2.STYLE S\nINNER JOIN FSH2.STYLESCULTUREINFO SC\nON S.STYLEID = SC.REFID\n) SRC\nPIVOT\n(\n\tMAX(VALUE)\n\tfor CULTURE in ([en-US],[en-GB])\n) AS PVT\n) A\nINNER JOIN\n(\nSELECT STYLEID AS STYLEID, STYLECODE, [DESCRIPTION],\n[en-US] as [DESCRIPTION_en-US],[en-GB] as [DESCRIPTION_en-GB]\nFROM\n(\nSELECT \nS.STYLEID,\nS.STYLECODE,\nS.DESCRIPTION,\nSC.DESCRIPTION AS [VALUE],\nSC.CULTURE AS CULTURE\nFROM\nFSH2.STYLE S\nINNER JOIN FSH2.STYLESCULTUREINFO SC\nON S.STYLEID = SC.REFID\n) SRC\nPIVOT\n(\n\tMAX(VALUE)\n\tfor CULTURE in ([en-US],[en-GB])\n) AS PVT\n)\nB\nON A.STYLEID = B.STYLEID\n","IsPrivate":false,"isUser":false},{"Name":"bomlinecomposition","Description":null,"QueryString":";WITH CTE (BOMLINEID, splitValue) AS  (\nSELECT TOP 20 B.BOMLINEID, COMPO.value FROM <%SCHEMA_NAME%>.BOMLINE B\nCROSS APPLY string_split(ISNULL(COMPOSITION,''),';') COMPO\nWHERE ISNULL(COMPOSITION,'') != '' AND OBJID = 0\n),\nCTELAYER AS (\n\tSELECT\n\t   bomlineid,\n\t   CASE WHEN CHARINDEX(':',splitValue) > 0 THEN\n       TRIM(SUBSTRING(splitValue, 1,charindex(':',splitValue)-1))\n\t   ELSE\n\t   ''\n\t   END LAYER\n\t   ,\n\t   TRIM(SUBSTRING(splitValue, charindex(':',splitValue)+1,len(splitValue)-charindex(';',splitValue)+1 )) AS CONTENT\n    FROM cte\n)\n,\nCTECONTENT (BOMLINEID, LAYER, SPLITVALUE) AS (\n\tSELECT\n\t   bomlineid,\n\t   layer,\n\t   COMPO.value\n    FROM CTELAYER\n\tCROSS APPLY string_split(ISNULL(CONTENT,''),',') COMPO\n)\n,\nCTE2 AS (\n\tSELECT\n\t   bomlineid,\n\t   layer,\n       TRIM(SUBSTRING(splitValue, 1,charindex('%',splitValue)-1)) AS contentpercent,\n\t   TRIM(SUBSTRING(splitValue, charindex('%',splitValue)+1,len(splitValue)-charindex('%',splitValue)+1 )) AS [name]\n    FROM CTECONTENT\n)\n\nselect \n\ttoInsert.BOMLINEID,\n\ttoInsert.seq, \n\ttoInsert.contentpercent,\n\ttoInsert.GLCONTENTTYPEID,\n\ttoInsert.GLLAYERID \nfrom \n(\nSELECT ROW_NUMBER() over (partition by c.bomlineid order by bomlineid) seq, c.BOMLINEID, \nc.contentpercent,gc.GLCONTENTTYPEID as GLCONTENTTYPEID, gl.GLLAYERID AS GLLAYERID  FROM cte2 c \nleft join <%SCHEMA_NAME%>.GLCONTENTTYPE gc\non c.name = gc.NAME \nleft join <%SCHEMA_NAME%>.GLLAYER gl on c.LAYER = gl.NAME\n)\ntoInsert\nLEFT JOIN\n<%SCHEMA_NAME%>.BOMLINECOMPOSITION bc\nON toInsert.BOMLINEID = BC.BOMLINEID\nWHERE \ntoInsert.BOMLINEID IS NULL\n\n","IsPrivate":false,"isUser":false},{"Name":"IFPLMCE-45983","Description":null,"QueryString":"UPDATE SMPC\nSET SMPC.[NAME] = POMC.[NAME]\nFROM FSH3.STYLE S\nINNER JOIN FSH3.STYLEMEAS SM ON S.STYLEID = SM.STYLEID\nINNER JOIN FSH3.STYLEMEASPOM SMP ON SM.STYLEMEASID = SMP.STYLEMEASID\nINNER JOIN FSH3.STYLEMEASUREMENTPOMCULTUREINFO SMPC ON SMP.STYLEMEASPOMID =  SMPC.REFID\nINNER JOIN FSH3.POMCULTUREINFO POMC ON SMP.POMID =  POMC.REFID\nWHERE SMPC.CULTURE LIKE 'en-us' AND POMC.CULTURE LIKE 'en-us' AND SMPC.[NAME] IS NULL AND YEAR(S.CREATEDATE) IN (2023, 2024)","IsPrivate":true,"isUser":false},{"Name":"IFPLMCE-45995","Description":null,"QueryString":"UPDATE FSH2.STYLECOSTINGELEMENT\nSET USEREXITID = 'aadc1278-3ec1-4f0e-bc5b-f55f1891398e'\nWHERE STYLECOSTINGELEMENTID IN\n(\nSELECT\nSTCOSTELEM.STYLECOSTINGELEMENTID\nFROM FSH2.STYLECOSTINGELEMENT STCOSTELEM\nINNER JOIN FSH2.STYLECOSTING STCOST ON STCOSTELEM.STYLECOSTINGID = STCOST.STYLECOSTINGID\nINNER JOIN FSH2.COSTMODEL CM ON STCOST.COSTMODELID = CM.COSTMODELID AND STCOST.COSTMODELID = 5\nINNER JOIN FSH2.COSTMODELELEMENT CMELEM ON CM.COSTMODELID = CMELEM.COSTMODELID AND STCOSTELEM.CODE = CMELEM.CODE AND STCOSTELEM.CODE = 'EXC'\nINNER JOIN FSH2.STYLE ST ON STCOST.STYLEID = ST.STYLEID\nWHERE STCOSTELEM.TYPE = 4  AND CMELEM.USEREXITID != '' AND STCOSTELEM.USEREXITID = '' AND ST.STATUS != 4\n)","IsPrivate":true,"isUser":false},{"Name":"Get value of props","Description":null,"QueryString":"DECLARE @COMPDATA NVARCHAR(MAX)\nDECLARE @VALUE NVARCHAR(MAX)\nDECLARE @LAYOUTID INT\nDECLARE @TABLE TABLE (LAYOUTID INT)\n\nDECLARE layoutCursor CURSOR FOR \nSELECT LAYOUTID, COMPDATA FROM SCAH.LAYOUTCE -- where layoutid = 2608\n\nOPEN layoutCursor  \nFETCH NEXT FROM layoutCursor INTO @LAYOUTID, @COMPDATA\n\nWHILE @@FETCH_STATUS = 0\nBEGIN\n\n\tDECLARE valueCursor CURSOR FOR\n\tSELECT VALUE FROM OPENJSON(@COMPDATA)\n\n\tOPEN valueCursor  \n\tFETCH NEXT FROM valueCursor INTO @VALUE\n\n\tWHILE @@FETCH_STATUS = 0\n\tBEGIN\n\t\t\n\t\tDECLARE @isError BIT = 0\n\t\tDECLARE @PROPS NVARCHAR(MAX)\n\t\tiF EXISTS (select *  FROM OPENJSON(@VALUE) WHERE [KEY] = 'DataField' AND [value] = 'ModifyDate')\n\t\tBEGIN\n\n\t\t\tselect @PROPS = VALUE   FROM OPENJSON(@VALUE) WHERE [KEY] = 'Props'\n\t\t\tIF EXISTS (SELECT * FROM OPENJSON(@PROPS) WHERE [KEY] = 'IsReadOnly' AND VALUE = 'false')\n\t\t\tBEGIN\n\t\t\t\tSET @isError = 1\n\t\t\tEND\n\t\tEND\n\n\t\tiF EXISTS (select *  FROM OPENJSON(@VALUE) WHERE [KEY] = 'DataField' AND [value] = 'CreateDate')\n\t\tBEGIN\n\t\t\t\n\t\t\tselect @PROPS = VALUE   FROM OPENJSON(@VALUE) WHERE [KEY] = 'Props'\n\t\t\tIF EXISTS (SELECT * FROM OPENJSON(@PROPS) WHERE [KEY] = 'IsReadOnly' AND VALUE = 'false')\n\t\t\tBEGIN\n\t\t\t\tSET @isError = 1\n\t\t\tEND\n\t\tEND\n\n\t\tiF EXISTS (select *  FROM OPENJSON(@VALUE) WHERE [KEY] = 'DataField' AND [value] = 'CreatedBy')\n\t\tBEGIN\n\t\n\t\t\tselect @PROPS = VALUE   FROM OPENJSON(@VALUE) WHERE [KEY] = 'Props'\n\t\t\tIF EXISTS (SELECT * FROM OPENJSON(@PROPS) WHERE [KEY] = 'IsReadOnly' AND VALUE = 'false')\n\t\t\tBEGIN\n\t\t\t\tSET @isError = 1\n\t\t\tEND\n\t\tEND\n\n\t\tiF EXISTS (select *  FROM OPENJSON(@VALUE) WHERE [KEY] = 'DataField' AND [value] = 'ModifyBy')\n\t\tBEGIN\n\n\t\t\tselect @PROPS = VALUE   FROM OPENJSON(@VALUE) WHERE [KEY] = 'Props'\n\t\t\tIF EXISTS (SELECT * FROM OPENJSON(@PROPS) WHERE [KEY] = 'IsReadOnly' AND VALUE = 'false')\n\t\t\tBEGIN\n\t\t\t\tSET @isError = 1\n\t\t\tEND\n\t\tEND\n\n\n\t\tif @isError = 1\n\t\tBEGIN\n                     INSERT INTO @TABLE (LAYOUTID)\n\t\t\tSELECT @LAYOUTID\n\t\tEND\n\n\n\t\tFETCH NEXT FROM valueCursor INTO @VALUE\n\tEND\n\n\t\tCLOSE valueCursor  \n\tDEALLOCATE valueCursor \n\nFETCH NEXT FROM layoutCursor INTO @LAYOUTID, @COMPDATA\n\nEND\n\n\n\nCLOSE layoutCursor  \nDEALLOCATE layoutCursor \n\nSELECTE * FROM SCAH.LAYOUTCE WHERE LAYOUTID IN (\nSELECT LAYOUTID FROM @TABLE  GROUP BY  LAYOUTID)\n\n\n\n\n\n\n","IsPrivate":true,"isUser":false},{"Name":"Set Sequence","Description":null,"QueryString":"IF NOT EXISTS (SELECT 1\n\t\tFROM sys.objects\n\t\tWHERE object_id = OBJECT_ID(N'<%SCHEMA_NAME%>.STYLE_SEQ') AND type IN (N'P', N'PC',N'SO')\n\t\t)\n\t\tBEGIN\n\t\tDECLARE @MAXSTYLEID BIGINT\n\t\tDECLARE @QUERY NVARCHAR(MAX)\n\t\tSELECT @MAXSTYLEID = MAX(STYLEID) FROM <%SCHEMA_NAME%>.STYLE\n\t\tSET @QUERY = 'CREATE SEQUENCE <%SCHEMA_NAME%>.STYLE_SEQ \n\t\t\tSTART WITH ' + CONVERT(NVARCHAR(100), ISNULL(@MAXSTYLEID,0) + 1) + \n\t\t\t' INCREMENT BY 1 ;'  \n\t\tEXEC sp_executesql @QUERY\n\t\tEND\n\t\tELSE\n\t\tBEGIN\n\t\tDECLARE @MAXSTYLEID_STYLE_SEQ BIGINT\n\t\tDECLARE @QUERY_STYLE_SEQ NVARCHAR(MAX)\n\t\tSELECT @MAXSTYLEID_STYLE_SEQ = MAX(STYLEID) FROM <%SCHEMA_NAME%>.STYLE\n\t\tSET @QUERY_STYLE_SEQ = 'ALTER SEQUENCE <%SCHEMA_NAME%>.STYLE_SEQ RESTART WITH  ' + CONVERT(NVARCHAR(100), ISNULL(@MAXSTYLEID_STYLE_SEQ, 0) + 1) + ' ;' \n\t\tEXEC sp_executesql @QUERY_STYLE_SEQ\n\t\tEND\n\n\t\tIF NOT EXISTS (SELECT 1\n\t\tFROM sys.objects\n\t\tWHERE object_id = OBJECT_ID(N'<%SCHEMA_NAME%>.STYLESIZE_SEQ') AND type IN (N'P', N'PC',N'SO')\n\t\t)\n\t\tBEGIN\n\t\tDECLARE @QUERY1 NVARCHAR(MAX)\n\t\tDECLARE @MAXSTYLESIZEID BIGINT\n\t\tSELECT @MAXSTYLESIZEID = MAX(stylesizeid) FROM <%SCHEMA_NAME%>.stylesize\n\t\tSET @QUERY1 = 'CREATE SEQUENCE <%SCHEMA_NAME%>.STYLESIZE_SEQ \n\t\t\tSTART WITH ' + CONVERT(NVARCHAR(100), ISNULL(@MAXSTYLESIZEID,0) + 1) + \n\t\t\t' INCREMENT BY 1 ;'  \n\t\tEXEC sp_executesql @QUERY1\n\t\tEND\n\t\tELSE\n\t\tBEGIN\n\t\tDECLARE @QUERY_STYLESIZE_SEQ NVARCHAR(MAX)\n\t\tDECLARE @MAXSTYLESIZEID_STYLESIZE_SEQ BIGINT\n\t\tSELECT @MAXSTYLESIZEID_STYLESIZE_SEQ = MAX(stylesizeid) FROM <%SCHEMA_NAME%>.stylesize\n\t\tSET @QUERY_STYLESIZE_SEQ = 'ALTER SEQUENCE <%SCHEMA_NAME%>.STYLESIZE_SEQ RESTART WITH  ' + CONVERT(NVARCHAR(100), ISNULL(@MAXSTYLESIZEID_STYLESIZE_SEQ, 0) + 1) + ';'  \n\t\tEXEC sp_executesql @QUERY_STYLESIZE_SEQ\n\t\tEND\n\n\t\tIF NOT EXISTS (SELECT 1\n\t\tFROM sys.objects\n\t\tWHERE object_id = OBJECT_ID(N'<%SCHEMA_NAME%>.STYLESUPLIER_SEQ') AND type IN (N'P', N'PC',N'SO')\n\t\t)\n\t\tBEGIN\n\t\tDECLARE @QUERY2 NVARCHAR(MAX)\n\t\tDECLARE @MAXSTYLESUPLIERID BIGINT\n\t\tSELECT @MAXSTYLESUPLIERID = MAX(STYLESUPID) FROM <%SCHEMA_NAME%>.STYLESUPLIER\n\t\tSET @QUERY2 = 'CREATE SEQUENCE <%SCHEMA_NAME%>.STYLESUPLIER_SEQ \n\t\t\tSTART WITH ' + CONVERT(NVARCHAR(100), ISNULL(@MAXSTYLESUPLIERID,0) + 1) + \n\t\t\t' INCREMENT BY 1 ;'  \n\t\tEXEC sp_executesql @QUERY2\n\t\tEND\n\t\tELSE\n\t\tBEGIN\n\t\tDECLARE @QUERY_STYLESUPLIER_SEQ NVARCHAR(MAX)\n\t\tDECLARE @MAXSTYLESUPLIERID_STYLESUPLIER_SEQ BIGINT\n\t\tSELECT @MAXSTYLESUPLIERID_STYLESUPLIER_SEQ = MAX(STYLESUPID) FROM <%SCHEMA_NAME%>.STYLESUPLIER\n\t\tSET @QUERY_STYLESUPLIER_SEQ = 'ALTER SEQUENCE <%SCHEMA_NAME%>.STYLESUPLIER_SEQ RESTART WITH  ' + CONVERT(NVARCHAR(100), ISNULL(@MAXSTYLESUPLIERID_STYLESUPLIER_SEQ, 0) + 1) + ';'  \n\t\tEXEC sp_executesql @QUERY_STYLESUPLIER_SEQ\n\t\tEND","IsPrivate":false,"isUser":false},{"Name":"Insert appfeature template","Description":null,"QueryString":"DECLARE @APPFEATUREKEY NVARCHAR(100) = N'mass-update-data-service';\nDECLARE @DISPLAYNAME NVARCHAR(100) = N'Mass Update API Optimization';\nDECLARE @DESCRIPTION NVARCHAR(100) = N'Mass Update API Optimization';\nIF NOT EXISTS (SELECT 1 FROM SCAH.APPFEATURE WHERE [KEY]=@APPFEATUREKEY)\nBEGIN\n\tINSERT INTO [SCAH].[APPFEATURE] (\n\t\t[KEY],\n\t\t[DISPLAYNAME],\n        [DESCRIPTION],\n\t\t[FEATURETYPE],\n\t\t[VISIBLE],\n        [ENABLED],\n\t\t[VERSION],\n\t\t[FEATUREID],\n        [CREATEDATE],\n\t\t[RELEASEEXPIRY]\n\t)\n    VALUES (\n\t\t@APPFEATUREKEY,\n        @DISPLAYNAME,\n        @DESCRIPTION,\n\t\t3,\n        1,\n        0,\n\t\t'2025.04.00',\n\t\t0,\n        GETUTCDATE(),\n\t\t'2025.10'\n\t)\nEND","IsPrivate":true,"isUser":false},{"Name":"Get style count per cluster","Description":null,"QueryString":"\nDECLARE @STYLEID INT = 1\n\nSELECT *\nFROM\n(\n\tSELECT \n\t'STYLEBOM' as CLUSTER,\n\tCOUNT(STYLEBOMID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID ) A\nUNION\n(\n\tSELECT \n\t'BOMLINE' as CLUSTER,\n\tCOUNT(BOMLINEID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID )\n\t)\nUNION\n(\n\tSELECT \n\t'BOMLINE' as CLUSTER,\n\tCOUNT(BOMLINEID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID )\n\t) \nUNION\n(\n\tSELECT \n\t'BOMLINEALLSTYLESIZEQTY' as CLUSTER,\n\tCOUNT(BOMLINEALLSTYLESIZEQTYID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINEALLSTYLESIZEQTY WHERE\n\tBOMLINEID IN (SELECT BOMLINEID FROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID ))\n\t) \nUNION\n(\n\tSELECT \n\t'BOMLINECELLCOLORRNG' as CLUSTER,\n\tCOUNT(BOMLINECELLCOLORRNGID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINECELLCOLORRNG WHERE\n\tBOMLINEID IN (SELECT BOMLINEID FROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID ))\n\t) \t\nUNION\n(\n\tSELECT \n\t'BOMLINECOLORRNG' as CLUSTER,\n\tCOUNT(BOMLINECOLORRNGID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINECOLORRNG WHERE\n\tBOMLINEID IN (SELECT BOMLINEID FROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID ))\n\t) \t\nUNION\n(\n\tSELECT \n\t'BOMLINECOLORRNGVAL' as CLUSTER,\n\tCOUNT(BOMLINECOLORRNGVALID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINECOLORRNGVAL WHERE BOMLINECOLORRNGID IN (SELECT BOMLINECOLORRNGID FROM <%SCHEMA_NAME%>.BOMLINECOLORRNG WHERE\n\tBOMLINEID IN (SELECT BOMLINEID FROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID )))\n\t)\nUNION\n(\n\tSELECT \n\t'BOMLINECOMPOSITION' as CLUSTER,\n\tCOUNT(BOMLINECOMPOSITIONID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINECOMPOSITION WHERE\n\tBOMLINEID IN (SELECT BOMLINEID FROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID ))\n\t)\nUNION\n(\n\tSELECT \n\t'BOMLINECULTUREINFO' as CLUSTER,\n\tCOUNT(CULTUREINFOID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINECULTUREINFO WHERE\n\tREFID IN (SELECT BOMLINEID FROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID ))\n\t)\nUNION\n(\n\tSELECT \n\t'BOMLINESIZECATRNG' as CLUSTER,\n\tCOUNT(BOMLINESIZECATRNGID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINESIZECATRNG WHERE\n\tBOMLINEID IN (SELECT BOMLINEID FROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID ))\n\t)\nUNION\n(\n\tSELECT \n\t'BOMLINESIZE' as CLUSTER,\n\tCOUNT(BOMLINESIZEID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINESIZE WHERE\n\tBOMLINESIZECATRNGID IN (SELECT BOMLINESIZECATRNGID FROM <%SCHEMA_NAME%>.BOMLINESIZECATRNG WHERE\n\tBOMLINEID IN (SELECT BOMLINEID FROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID )))\n\t)\nUNION\n(\n\tSELECT \n\t'BOMLINEUDF13' as CLUSTER,\n\tCOUNT(BOMLINEUDF13ID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.BOMLINEUDF13 WHERE\n\tBOMLINEID IN (SELECT BOMLINEID FROM <%SCHEMA_NAME%>.BOMLINE WHERE STYLEBOMID IN ( SELECT STYLEBOMID FROM <%SCHEMA_NAME%>.STYLEBOM WHERE STYLEID =@STYLEID ))\n\t)\n\nUNION\n(\n\tSELECT \n\t'STYLESIZECATRNG' as CLUSTER,\n\tCOUNT(STYLESIZECATRNGID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.STYLESIZECATRNG WHERE STYLEID = @STYLEID\n\t)\nUNION\n(\n\tSELECT \n\t'STYLESIZE' as CLUSTER,\n\tCOUNT(STYLESIZEID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.STYLESIZE WHERE STYLEID = @STYLEID\n\t)\nUNION\n(\n\tSELECT \n\t'STYLEMEAS' as CLUSTER,\n\tCOUNT(STYLEMEASID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.STYLEMEAS WHERE STYLEID = @STYLEID\n\t)\nUNION\n(\n\tSELECT \n\t'STYLEMEASSIZE' as CLUSTER,\n\tCOUNT(STYLEMEASSIZEID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.STYLEMEASSIZE WHERE STYLEMEASID IN (SELECT STYLEMEASID FROM <%SCHEMA_NAME%>.STYLEMEAS WHERE STYLEID = @STYLEID)\n\t)\nUNION\n(\n\tSELECT \n\t'STYLEMEASPOM' as CLUSTER,\n\tCOUNT(STYLEMEASPOMID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.STYLEMEASPOM WHERE STYLEMEASID IN (SELECT STYLEMEASID FROM <%SCHEMA_NAME%>.STYLEMEAS WHERE STYLEID = @STYLEID)\n\t)\nUNION\n(\n\tSELECT \n\t'STYLEMEASPOMSIZE' as CLUSTER,\n\tCOUNT(STYLEMEASPOMSIZEID) AS COUNT \n\t\tFROM <%SCHEMA_NAME%>.STYLEMEASPOMSIZE \n\tWHERE STYLEMEASPOMID IN (SELECT STYLEMEASPOMID FROM <%SCHEMA_NAME%>.STYLEMEASPOM WHERE STYLEMEASID IN (SELECT STYLEMEASID FROM <%SCHEMA_NAME%>.STYLEMEAS WHERE STYLEID = @STYLEID))\n\t)\nUNION\n(\n\tSELECT \n\t'STYLESAMP' as CLUSTER,\n\tCOUNT(STYLESAMPID) AS COUNT \n\t\tFROM <%SCHEMA_NAME%>.STYLESAMP WHERE STYLEMEASID IN (SELECT STYLEMEASID FROM <%SCHEMA_NAME%>.STYLEMEAS WHERE STYLEID = @STYLEID)\n\t)\nUNION\n(\n\tSELECT \n\t'STYLECOLORRNG' as CLUSTER,\n\tCOUNT(STYLECOLORRNGID) AS COUNT \n\tFROM <%SCHEMA_NAME%>.STYLECOLORRNG WHERE STYLEID = @STYLEID\n\t)","IsPrivate":false,"isUser":false},{"Name":"Add Style","Description":null,"QueryString":"INSERT INTO <%SCHEMA_NAME%>.STYLE\n(STYLEID,NAME,STYLECODE,PHANTOMCODE,ISPHANTOM,STATUS,SKUCNT,ISDELETED,MODIFYID,MODIFYDATE,CREATEDATE)\nVALUES\n(1,'STYLE HOTFIX TST','STYLE HOTFIX TST','',1,1,0,0,1,GETDATE(),GETDATE())\n","IsPrivate":false,"isUser":false},{"Name":"Check Index","Description":null,"QueryString":"SELECT * \nFROM sys.indexes \nWHERE name='STYLEFOLLOWUPVAL_STYLEFOLLOWUPID_TYPE_MODIFYDATE' AND object_id = OBJECT_ID('[FSH3].STYLEFOLLOWUPVAL')\n","IsPrivate":false,"isUser":false},{"Name":"Get layout with specific datafield","Description":null,"QueryString":"DECLARE @TABLE TABLE (LAYOUTID INT)\n\nDECLARE @COMPDATA NVARCHAR(MAX)\nDECLARE @LAYOUTID INT\n\nDECLARE layoutCursor CURSOR FOR \nSELECT layoutid, COMPDATA FROM SCAH.LAYOUTCE WHERE ENTITY = 'style' --LAYOUTID = 2435\n\nOPEN layoutCursor  \nFETCH NEXT FROM layoutCursor INTO @LAYOUTID, @COMPDATA\n\nWHILE @@FETCH_STATUS = 0  \nBEGIN\nDECLARE @ORIGINALJSON NVARCHAR(MAX) = @COMPDATA\nDECLARE @VALUE NVARCHAR(MAX)\nDECLARE @KEYINT INT\n\n\n\tDECLARE valueCursor CURSOR FOR\n\tSELECT value,[KEY] FROM OPENJSON(@ORIGINALJSON) \n\n\tOPEN valueCursor\n\tFETCH NEXT FROM valueCursor INTO @VALUE, @KEYINT\n\n\n\tWHILE @@FETCH_STATUS = 0  \n\tBEGIN  \n\n\t\tIF EXISTS (SELECT 1 FROM OPENJSON(@VALUE)  WHERE [key]='DataField' and [value] = 'UserDefinedField8Ids')\n\t\tBEGIN\n\t\t\tINSERT INTO @TABLE VALUES (@LAYOUTID)\n\t\tEND\n\n\n\tFETCH NEXT FROM valueCursor INTO @VALUE, @KEYINT\n\tEND\n\tCLOSE valueCursor  \n\tDEALLOCATE valueCursor \n\n\n\tFETCH NEXT FROM layoutCursor INTO @LAYOUTID, @COMPDATA \nEND\nCLOSE layoutCursor  \nDEALLOCATE layoutCursor \n\n\nSELECT * FROM @TABLE t inner join scah.layoutce lc on t.layoutid = lc.layoutid\n","IsPrivate":false,"isUser":false},{"Name":"Spaced Used","Description":null,"QueryString":"EXEC sp_spaceused;","IsPrivate":true,"isUser":false},{"Name":"ADD PK/CLUSTER INDEX","Description":null,"QueryString":"DECLARE @TABLENAME NVARCHAR(MAX)\nDECLARE @SCHEMA NVARCHAR(10) = '<%SCHEMA_NAME%>'\nDECLARE @HASCLUSTEREDINDEX BIT = 0\nDECLARE @IDENTITYCOLUMN NVARCHAR(MAX)\nDECLARE @QUERY NVARCHAR(MAX)\n\nDECLARE TABLE_CURSOR CURSOR FOR \nSELECT \n    t.namE\nFROM \n    sys.tables t\nLEFT JOIN \n    sys.key_constraints pk ON t.object_id = pk.parent_object_id AND pk.type = 'PK'\nWHERE \nSCHEMA_NAME(t.schema_id) = '<%SCHEMA_NAME%>' AND\n   pk.object_id is null\n   ORDER BY T.name\n\nOPEN TABLE_CURSOR  \nFETCH NEXT FROM TABLE_CURSOR INTO @TABLENAME  \n\nWHILE @@FETCH_STATUS = 0  \nBEGIN  \n\tSET @HASCLUSTEREDINDEX = 0\n\t--check if table has clustered index\n\tIF EXISTS (SELECT  1 \n\t\t\t\tFROM SYS.tables T\n\t\t\t\tLEFT JOIN SYS.indexes I\n\t\t\t\tON T.object_id = I.object_id AND I.index_id = 1\n\t\t\t\tWHERE\n\t\t\t\tI.object_id IS NOT NULL \n\t\t\t\tAND SCHEMA_NAME(T.SCHEMA_ID) = @SCHEMA \n\t\t\t\tAND T.NAME = @TABLENAME)\n\tBEGIN\n\t\tSET @HASCLUSTEREDINDEX = 1\n\tEND\n\n\t\n\t--CHECK IF TABLE HAS IDENTITY COLUMN\n\tSET @IDENTITYCOLUMN = ''\n\tSELECT @IDENTITYCOLUMN = c.name \n\t\t\t\tFROM \n\t\t\t\tsys.tables t\n\t\t\t\tJOIN \n\t\t\t\tsys.columns c \n\t\t\t\tON t.object_id = c.object_id \n\t\t\t\tWHERE \n\t\t\t\tt.name = @TABLENAME \n\t\t\t\tAND SCHEMA_NAME(T.SCHEMA_ID) = @SCHEMA  -- Replace with your table name\n\t\t\t\tAND c.is_identity = 1\n\tIF @IDENTITYCOLUMN IS NOT NULL AND @IDENTITYCOLUMN != ''\n\tBEGIN\n\t\tIF @HASCLUSTEREDINDEX = 1 -- HAS CLUSTERED AND HAS IDENTITYCOLUMN\n\t\tBEGIN\n\t\t\t--SET IDENTITY COLUMN TO PRIMARY KEY\n\t\t\tSET @QUERY = 'ALTER TABLE '+@SCHEMA+'.'+@TABLENAME+' ADD CONSTRAINT PK_'+UPPER(@TABLENAME)+' PRIMARY KEY NONCLUSTERED ('+@IDENTITYCOLUMN+')'\n\t\t\tEXEC sp_executesql @QUERY\n\t\tEND\n\t\tELSE\n\t\tBEGIN -- NO CLUSTERED BUT HAS IDENTITY COLUMN\n\t\t\tSET @QUERY = 'ALTER TABLE '+@SCHEMA+'.'+@TABLENAME+' ADD CONSTRAINT PK_'+UPPER(@TABLENAME)+' PRIMARY KEY CLUSTERED ('+@IDENTITYCOLUMN+')'\n\t\t\tEXEC sp_executesql @QUERY\n\t\tEND\n\tEND\n\tELSE \n\tBEGIN \n\t\tIF @HASCLUSTEREDINDEX = 0 -- NO CLUSTERED AND NO IDENTITY\n\t\tBEGIN\n\t\tIF NOT EXISTS (SELECT 1 FROM INFORMATION_SCHEMA.TABLES T \n\t\t\t\t\t\tINNER JOIN INFORMATION_SCHEMA.COLUMNS C \n\t\t\t\t\t\tON T.TABLE_NAME = C.TABLE_NAME AND T.TABLE_SCHEMA = C.TABLE_SCHEMA\n\t\t\t\t\t\tWHERE T.TABLE_SCHEMA = @SCHEMA AND C.COLUMN_NAME = @TABLENAME + 'ID') -- CHECK COLUMN IF EXISTS\n\t\t\tBEGIN\n\n\t\t\t\tSET @QUERY = 'ALTER TABLE '+@SCHEMA+'.'+@TABLENAME+' ADD '+UPPER(@TABLENAME)+'ID INT NOT NULL IDENTITY(1,1)'\n\t\t\t\tEXEC sp_executesql @QUERY\n\t\t\t\tSET @QUERY = 'ALTER TABLE '+@SCHEMA+'.'+@TABLENAME+' ADD CONSTRAINT PK_'+UPPER(@TABLENAME)+' PRIMARY KEY CLUSTERED ('+@TABLENAME+'ID)'\n\t\t\t\tEXEC sp_executesql @QUERY\n\t\t\tEND\n\t\tEND\n\t\tELSE --NO IDENTITY COLUMN BUT HAS CLUSTERED\n\t\tBEGIN\n\t\t\t\tIF EXISTS (SELECT 1 FROM INFORMATION_SCHEMA.TABLES T \n\t\t\t\t\t\tINNER JOIN INFORMATION_SCHEMA.COLUMNS C \n\t\t\t\t\t\tON T.TABLE_NAME = C.TABLE_NAME AND T.TABLE_SCHEMA = C.TABLE_SCHEMA \n\t\t\t\t\t\tWHERE T.TABLE_SCHEMA = @SCHEMA AND C.COLUMN_NAME = @TABLENAME + 'ID') -- CHECK COLUMN IF EXISTS\n\t\t\t\t\tBEGIN\n\t\t\t\t\t\tSET @QUERY = 'ALTER TABLE '+@SCHEMA+'.'+@TABLENAME+' ADD CONSTRAINT PK_'+UPPER(@TABLENAME)+' PRIMARY KEY NONCLUSTERED ('+@TABLENAME+'ID)'\n\t\t\t\t\t\tEXEC sp_executesql @QUERY\n\t\t\t\t\tEND\n\t\t\t\tELSE\n\t\t\t\tBEGIN\n\t\t\t\t\tSET @QUERY = 'ALTER TABLE '+@SCHEMA+'.'+@TABLENAME+' ADD '+UPPER(@TABLENAME)+'ID INT NOT NULL IDENTITY(1,1)'\n\t\t\t\t\tEXEC sp_executesql @QUERY\n\t\t\t\t\tSET @QUERY = 'ALTER TABLE '+@SCHEMA+'.'+@TABLENAME+' ADD CONSTRAINT PK_'+UPPER(@TABLENAME)+' PRIMARY KEY NONCLUSTERED ('+@TABLENAME+'ID)'\n\t\t\t\t\tEXEC sp_executesql @QUERY\n\t\t\t\tEND\n\t\tEND\n\t\t\n\tEND\n\tFETCH NEXT FROM TABLE_CURSOR INTO @TABLENAME \nEND \n\nCLOSE TABLE_CURSOR  \nDEALLOCATE TABLE_CURSOR\n\n\n","IsPrivate":true,"isUser":false},{"Name":"GET ATTACHMENTS FOR MIGRAITON","Description":null,"QueryString":"SELECT \n\tATTAFILELISTID,\n\tCFILENAME,\n\tCODE,\n\tREFERENCEID\nFROM FSH1.ATTAFILELIST WHERE REFERENCEID  > 0 AND ISDELETED = 0","IsPrivate":true,"isUser":false},{"Name":"DATABASE TABLE SIZE","Description":null,"QueryString":"\nSELECT \n    t.name AS TableName,\n    s.name AS SchemaName,\n    p.rows,\n    SUM(a.total_pages) * 8 AS TotalSpaceKB, \n    CAST(ROUND(((SUM(a.total_pages) * 8) / 1024.00), 2) AS NUMERIC(36, 2)) AS TotalSpaceMB,\n    SUM(a.used_pages) * 8 AS UsedSpaceKB, \n    CAST(ROUND(((SUM(a.used_pages) * 8) / 1024.00), 2) AS NUMERIC(36, 2)) AS UsedSpaceMB, \n    (SUM(a.total_pages) - SUM(a.used_pages)) * 8 AS UnusedSpaceKB,\n    CAST(ROUND(((SUM(a.total_pages) - SUM(a.used_pages)) * 8) / 1024.00, 2) AS NUMERIC(36, 2)) AS UnusedSpaceMB\nFROM \n    sys.tables t\nINNER JOIN      \n    sys.indexes i ON t.object_id = i.object_id\nINNER JOIN \n    sys.partitions p ON i.object_id = p.object_id AND i.index_id = p.index_id\nINNER JOIN \n    sys.allocation_units a ON p.partition_id = a.container_id\nLEFT OUTER JOIN \n    sys.schemas s ON t.schema_id = s.schema_id\nWHERE \n    t.name NOT LIKE 'dt%' \n    AND t.is_ms_shipped = 0\n    AND i.object_id > 255 \nGROUP BY \n    t.name, s.name, p.rows\nORDER BY \n    TotalSpaceMB DESC, t.name\n","IsPrivate":false,"isUser":false},{"Name":"Create  (n) style","Description":"create number of style in style table, styleextra table only","QueryString":"\nDECLARE @TOTALRECORDCOUNT INT = 5;\nDECLARE @COUNTER INT = 1;\nDECLARE @STYLENAME NVARCHAR(50);\nDECLARE @STYLECODE NVARCHAR(50);\nDECLARE @STYLEDESCRIPTION NVARCHAR(50);\ndeclare @NEWIDS INT\n\nWHILE @COUNTER <= @TOTALRECORDCOUNT\nBEGIN\n\tSET @STYLENAME ='01242025 SOURCE RECORD_' + CONVERT(NVARCHAR(50), @COUNTER);\n\tSET @STYLECODE ='01242025 SOURCE RECORD_' + CONVERT(NVARCHAR(50), @COUNTER);\n\tSET @STYLEDESCRIPTION ='01242025 SOURCE RECORD_' + CONVERT(NVARCHAR(50), @COUNTER);\n\n\t \n\tEXEC FSH2.[P_GET_NEXT_IDS] @PROFILE_ID = 1 ,  \n\t\t\t\t @TABLE_NAME = 'STYLE' ,  \n\t\t\t\t @ONLINE = 'Y' ,  \n\t\t\t\t @QUANTITY = 1,  \n\t\t\t\t @NEWIDS = @NEWIDS OUT; \n\n\tINSERT INTO FSH2.STYLE\n(STYLEID,COLLFOLDID,ORGLEVELID,ISSEASONMNGD,NAME,DESCRIPTION,STYLECODE,ALTCODE,PHANTOMCODE,ISPHANTOM,SUPPLIERID,COUNTRYID,OPITEMTEMPID,TRADEMARKID,REMARK,PURCCURRID,PURCPRICE,COSTPERCENT,COSTPRICE,NETWEIGHT,GROSSWEIGHT,VOLUME,BUYER,STATUS,RESPONSIBLEID,M3RESPONSIBLE,SKUCNT,MARGINPERCENT,MARGINPERCENT2,ISDELETED,MODIFYID,MODIFYDATE,CREATEDATE,DESIGNER,TECHDESIGNER,PRODSPECIALIST,FABCOORDINATOR,TRMSPECIALIST,COLORIST,GENDERID,GLPRODTYPEID,GLTHEMEID,GLPACKGID,GLPRODSUBCATID,GLPRODSUBSUBCATID,SEASONID,LINEPLANID,TYPE,GLUOMID,FREEFLD1,FREEFLD2,FREEFLD3,FREEFLD4,GLUSRDEFFLD1ID,GLUSRDEFFLD2ID,GLUSRDEFFLD3ID,GLUSRDEFFLD4ID,NUMVAL1,NUMVAL2,GLHTSID,ISNORMAL,BOMNOTE,ISCOSTINGSYNCED,RETAILPRICE,WHOLESALEPRICE,RETAILPRICECURRENCYID,WHOLESALEPRICECURRENCYID,SUPPAGENTID,COUNTRYIDLIST,GLREGIONIDLIST,GLCHANNELIDLIST,GLMARKETFLD1IDLIST,GLMARKETFLD2IDLIST,GLMARKETFLD3ID,GLMARKETFLD4ID,GLMARKETFLD5ID,GLDIVID,INTGCODE,INTGNAME,INTGDESCRIPTION,INTGSTATUSMHS,INTGSTATUSMMS,VATCODE,FREECAPUNIT,PLANNER,WAREHOUSE,GROSSWEIGHTUOMID,NETWEIGHTUOMID,VOLUMEUOMID,FREECAPUNITUOMID,MABU,GLDELIVIDLIST,ISSAMEID,ISAPPENDED,STYLEPATTERNNUMBER,STYLEPATTERNSPECNUMBER,STYLEMARKERSPECNUMBER,COSTCURRID,GLUSRDEFFLD8IDS,GLUSRDEFFLD9IDS,GLUSRDEFFLD10IDS,GLUSRDEFFLD11IDS,GLUSRDEFFLD12IDS,GLUSRDEFFLD13IDS,QUANTITY,EXFACTORYDATE,RETAILINSTOREDATE,DATE3,DATE4,CREATEID,NLINEPLANID,COPIEDFROM,EXTERNALSTYLEID,URL3D,GLUSERDEFFLD5IDID,GLUSERDEFFLD6IDID,GLUSERDEFFLD7IDID,INTGMODIFYDATE,SUPPURCPRICE,COSTPRICEBASE,SUPPURCPRICECURRID,COSTPRICEBASECURRID,ISGENAIGENERATED,ISSET)\nVALUES (@NEWIDS,2,null,0,@STYLENAME,@STYLEDESCRIPTION,@STYLECODE,@STYLECODE,'4E2F6A975BA24558A363914C0B51424F',1,18,1,1,1,'01242025 SOURCE RECORD',3,20,0,20,null,null,null,null,1,0,null,0,20,20,0,2138,GETDATE(),GETDATE(),0,0,0,0,0,0,1,2,2,4,2,2,7,null,1,2,'01242025 SOURCE RECORD','01242025 SOURCE RECORD','01242025 SOURCE RECORD','01242025 SOURCE RECORD',2,1,4,3,20,40,2,0,null,0,20,20,2,1,null,'1','2','1','1','1',1,2,5,2,null,null,null,null,null,null,null,null,null,null,null,null,null,null,'1',null,0,'01242025 SOURCE RECORD','01242025 SOURCE RECORD','01242025 SOURCE RECORD',3,null,null,null,null,null,null,10,'2/7/2025 12:00:00 AM','2/8/2025 12:00:00 AM','1/24/2025 12:00:00 AM','2/7/2025 12:00:00 AM',2138,null,null,null,null,null,null,null,null,null,null,null,3,0,null)\n\nINSERT INTO FSH2.STYLEEXTRA\n(STYLEID,MODIFYDATE,MODIFYID)\nVALUES\n(@NEWIDS,GETDATE(),1)\n\n\tSET @COUNTER +=1;\nEND\n\n","IsPrivate":true,"isUser":false},{"Name":"updated style name","Description":null,"QueryString":"\nSELECT\nSA.AUDITDATE AS AUDITDATE,\nSA.USERID AS MODIFIEDBY,\nSC.NAME AS [USER],\nSA.PRIMARYKEY AS STYLEID, \nSA.INFOCLUSTER AS INFOCLUSTER,\nSAV.COLUMNAME AS COLUMNNAME,\nSAV.OLDVALUE AS OLDVALUE,\nSAV.NEWVALUE AS NEWVALUE\nFROM\nFSH3.STYLEAUDIT SA\nINNER JOIN \nFSH3.STYLEAUDITVAL SAV\nON SA.STYLEAUDITID = SAV.STYLEAUDITID\nINNER JOIN\nSCAH.SCUSER SC\nON SA.USERID = SC.SCUSERID\nWHERE\nSA.AUDITDATE BETWEEN '01/29/2025 00:00:00' AND '02/03/2025 23:59:59'\nAND\nSA.INFOCLUSTER = 'OVERVIEW'\nAND\nSAV.COLUMNAME = 'NAME' AND (SAV.OLDVALUE != '' AND SAV.NEWVALUE ='' )\n\n\n","IsPrivate":true,"isUser":false},{"Name":"STUFF","Description":null,"QueryString":"\nSELECT STUFF((\nselect ',' + convert(nvarchar(10),styleid) from <%SCHEMA_NAME%>.STYLEextra FOR XML PATH(''))\n,1,1,'') AS AAA\n","IsPrivate":false,"isUser":false},{"Name":"generate archive query","Description":"","QueryString":"USE [DEV_TST_test]\nGO\n/****** Object:  StoredProcedure [FSH1].[P_GENERATE_ARCHIVE_QUERY]    Script Date: 5/14/2025 11:03:51 AM ******/\nSET ANSI_NULLS ON\nGO\nSET QUOTED_IDENTIFIER ON\nGO\nALTER   PROCEDURE [FSH1].[P_GENERATE_ARCHIVE_QUERY] \n\t@SCHEMA NVARCHAR(10)\nAS\nBEGIN\n\t\n\tDECLARE @RETURNTABLE TABLE (TABLENAME NVARCHAR(50), QUERYSTRING NVARCHAR(MAX))\n\t\n\t\n\t\n\tDECLARE @TABLENAME NVARCHAR(50)\n\tDECLARE @TABLES NVARCHAR(MAX)\n\n\n\tSELECT @TABLES = [VALUE] FROM SCAH.APPSETTINGCE WHERE [KEY]='archived_module_list'\n\n\n\tDECLARE ARCHIVE_CURSOR CURSOR FOR\n\tSELECT value FROM string_split(@TABLES,',')\n\n\tOPEN ARCHIVE_CURSOR\n\tFETCH NEXT FROM ARCHIVE_CURSOR INTO @TABLENAME\n\n\tDECLARE @ARCHIVED_STYLES NVARCHAR(MAX)\n\n\tWHILE @@FETCH_STATUS = 0\n\tBEGIN\n\t\t\n\t\t--style\n\t\tIF UPPER(@TABLENAME) = 'STYLE'\n\t\tBEGIN\n\t\t\tSELECT @ARCHIVED_STYLES = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLEID) FROM FSH1.STYLE WHERE ISARCHIVED = 1 FOR XML PATH('')),1,1,'') \n\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\n\t\t\tEND\n\t\tEND\n\t\t-- dictionarymodule\n\t\tIF UPPER(@TABLENAME) = 'DICTIONARYMODULE'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\t\t\t\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WHERE MODULEID = 1 AND OBJID IN ('+ @ARCHIVED_STYLES +')')\n\t\t\tEND\n\t\tEND\n\t\t--stylecolorrng\n\t\tIF UPPER(@TABLENAME) = 'STYLECOLORRNG'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\n\n\t\t\t\tDECLARE @STYLECOLORRNGID NVARCHAR(MAX)\n\n\t\t\t\tSELECT @STYLECOLORRNGID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLECOLORRNGID) FROM FSH1.STYLECOLORRNG WHERE STYLEID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) FOR XML PATH('')),1,1,'')\n\n\t\t\t\tIF ISNULL(@STYLECOLORRNGID,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLECOLORRNGVAL','SELECT * FROM ' + @SCHEMA + '.STYLECOLORRNGVAL WHERE STYLECOLORRNGID IN (' + @STYLECOLORRNGID + ')')\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLECOLORRNGCHANNEL','SELECT * FROM ' + @SCHEMA + '.STYLECOLORRNGCHANNEL WHERE STYLECOLORRNGID IN (' + @STYLECOLORRNGID + ')')\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLECOLORDELIVERY','SELECT * FROM ' + @SCHEMA + '.STYLECOLORDELIVERY WHERE STYLECOLORRNGID IN (' + @STYLECOLORRNGID + ')')\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLECOLORRNGUDF12','SELECT * FROM ' + @SCHEMA + '.STYLECOLORRNGUDF12 WHERE STYLECOLORRNGID IN (' + @STYLECOLORRNGID + ')')\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLECOLORRNGUDF13','SELECT * FROM ' + @SCHEMA + '.STYLECOLORRNGUDF13 WHERE STYLECOLORRNGID IN (' + @STYLECOLORRNGID + ')')\n\t\t\t\tEND\n\t\t\tEND\n\t\tEND\n\t\t--attafilelist\n\t\tIF UPPER(@TABLENAME) = 'ATTAFILELIST'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE REFERENCEID IN (' + @ARCHIVED_STYLES + ') AND CODE IN (''E0012'', ''E0036'',''E0043'')')\n\n\t\t\t\tDECLARE @ATTAFILELISTIDS NVARCHAR(MAX)\n\n\t\t\t\tSELECT @ATTAFILELISTIDS = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),ATTAFILELISTID) FROM FSH1.ATTAFILELIST WHERE REFERENCEID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) AND CODE IN ('E0012','E0036','E0043') FOR XML PATH('')),1,1,'')\n\t\t\t\t\n\t\t\t\tIF ISNULL(@ATTAFILELISTIDS,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('ATTADETAILS','SELECT * FROM ' + @SCHEMA + '.ATTADETAILS WITH (NOLOCK) WHERE ATTAFILELISTID IN (' + @ATTAFILELISTIDS + ')')\n\t\t\t\tEND\n\t\t\tEND\n\t\tEND\n\t\t--stylesizecatrng\n\t\tIF UPPER(@TABLENAME) = 'STYLESIZECATRNG'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\n\n\t\t\t\tDECLARE @STYLESIZECATRNGID NVARCHAR(MAX)\n\n\t\t\t\tSELECT @STYLESIZECATRNGID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),@STYLESIZECATRNGID) FROM FSH1.STYLESIZECATRNG WHERE STYLEID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\n\t\t\t\tIF ISNULL(@STYLESIZECATRNGID,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLESIZE','SELECT * FROM ' + @SCHEMA + '.STYLESIZE WITH (NOLOCK) WHERE STYLESIZECATRNGID IN (' + @STYLESIZECATRNGID + ')')\n\t\t\t\tEND\n\t\t\tEND\n\t\tEND\n\t\t--stylemeas\n\t\tIF UPPER(@TABLENAME) = 'STYLEMEAS'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\t\n\t\n\t\t\t\tDECLARE @STYLEMEASID NVARCHAR(MAX)\n\n\t\t\t\tSELECT @STYLEMEASID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLEMEASID) FROM FSH1.STYLEMEAS WHERE STYLEID IN (SELECT VALUE FROM string_split(@ARCHIVED_STYLES,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\n\t\t\t\tIF ISNULL(@STYLEMEASID,'0') != '0'\n\t\t\t\tBEGIN\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLEMEASGR','SELECT * FROM ' + @SCHEMA + '.STYLEMEASGR WITH (NOLOCK) WHERE STYLEMEASID IN (' + @STYLEMEASID + ')')\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLEMEASSIZE','SELECT * FROM ' + @SCHEMA + '.STYLEMEASSIZE WITH (NOLOCK) WHERE STYLEMEASID IN (' + @STYLEMEASID + ')')\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLEMEASPOM','SELECT * FROM ' + @SCHEMA + '.STYLEMEASPOM WITH (NOLOCK) WHERE STYLEMEASID IN (' + @STYLEMEASID + ')')\n\n\t\t\t\t\tDECLARE @STYLEMEASPOMID NVARCHAR(MAX)\n\n\t\t\t\t\tSELECT @STYLEMEASPOMID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLEMEASPOMID) FROM FSH1.STYLEMEASPOM WHERE STYLEMEASID IN (SELECT VALUE FROM string_split(@STYLEMEASID,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\t\n\n\t\t\t\t\tIF ISNULL(@STYLEMEASPOMID,'0') != '0'\n\t\t\t\t\tBEGIN\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('STYLEMEASPOMSIZE','SELECT * FROM ' + @SCHEMA + '.STYLEMEASPOMSIZE WITH (NOLOCK) WHERE STYLEMEASPOMID IN (' + @STYLEMEASPOMID + ')')\n\n\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('STYLEMEASUREMENTPOMCULTUREINFO','SELECT * FROM ' + @SCHEMA + '.STYLEMEASUREMENTPOMCULTUREINFO WITH (NOLOCK) WHERE REFID IN (' + @STYLEMEASPOMID + ')')\n\t\t\t\t\tEND\n\n\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\tVALUES\n\t\t\t\t\t('STYLESAMP','SELECT * FROM ' + @SCHEMA + '.STYLESAMP WITH (NOLOCK) WHERE STYLEMEASID IN (' + @STYLEMEASID + ')')\n\n\t\t\t\t\tDECLARE @STYLESAMPID NVARCHAR(MAX)\n\n\t\t\t\t\tSELECT @STYLESAMPID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLESAMPID) FROM FSH1.STYLESAMP WHERE STYLEMEASID IN (SELECT VALUE FROM string_split(@STYLEMEASID,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\t\n\t\t\t\t\tIF ISNULL(@STYLESAMPID,'0') != '0'\n\t\t\t\t\tBEGIN\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('STYLESAMPPOMDETAILS','SELECT * FROM ' + @SCHEMA + '.STYLESAMPPOMDETAILS WITH (NOLOCK) WHERE STYLESAMPID IN (' + @STYLESAMPID + ')')\n\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('STYLESAMPPOMSIZE','SELECT * FROM ' + @SCHEMA + '.STYLESAMPPOMSIZE WITH (NOLOCK) WHERE STYLESAMPID IN (' + @STYLESAMPID + ')')\n\n\n\t\t\t\t\t\tDECLARE @STYLESAMPPOMSIZEID NVARCHAR(MAX)\n\n\t\t\t\t\t\tSELECT @STYLESAMPPOMSIZEID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),STYLESAMPPOMSIZEID) FROM FSH1.STYLESAMPPOMSIZE WHERE STYLESAMPID IN (SELECT VALUE FROM string_split(@STYLESAMPID,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\t\t\n\t\t\t\t\t\tIF ISNULL(@STYLESAMPPOMSIZEID,'0') != '0'\n\t\t\t\t\t\tBEGIN\n\t\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t\t('STYLESAMPPOMSIZEVALUES','SELECT * FROM ' + @SCHEMA + '.STYLESAMPPOMSIZEVALUES WITH (NOLOCK) WHERE STYLESAMPPOMSIZEID IN (' + @STYLESAMPPOMSIZEID + ')')\t\n\t\t\t\t\t\tEND\n\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('STYLESAMPSIZECOLOR','SELECT * FROM ' + @SCHEMA + '.STYLESAMPSIZECOLOR WITH (NOLOCK) WHERE STYLESAMPID IN (' + @STYLESAMPID + ')')\n\n\n\t\t\t\t\tEND\n\n\t\t\t\t\t\n\t\t\t\tEND\n\t\t\tEND\n\n\t\tEND\n\t\t--stylebom\n\t\tIF UPPER(@TABLENAME) = 'STYLEBOM'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTR