ocalhost:5000/api/provision/tenants/dbupgrade","RegionClientId":"fplminternal","RegionClientSecret":"mlpnoihsafrofni","RegionUpgradePath":null,"RegionUpgradeBody":null,"Headers":[],"HeaderEnvironmentId":66},{"Id":13,"RegionName":"Pen Test Environment","RegionEndPoint":"https://pentest.fplm.dev.inforcloudsuite.com/api/provision/tenants/dbupgrade","RegionClientId":"fplminternal","RegionClientSecret":"mlpnoihsafrofni","RegionUpgradePath":null,"RegionUpgradeBody":null,"Headers":[],"HeaderEnvironmentId":67}],"CustomerDataGrowths":[{"Name":"LCWAIKIKI_PRD","Description":"LCW Data Growth","FolderPath":"C:\\FashionPLMCE\\DBTool\\DBTool\\DBTool\\bin\\Debug\\net8.0-windows7.0\\Datagrowth\\LCWAIKIKI_PRD","Day":15},{"Name":"VOICE_PRD","Description":null,"FolderPath":"C:\\FashionPLMCE\\DBTool\\DBTool\\DBTool\\bin\\Debug\\net6.0-windows\\Datagrowth\\VOICE_PRD","Day":15}],"EmailSettings":{"Host":"smtp-mail.outlook.com","Port":587,"Username":"script-run-alert@outlook.com","Password":"phasatbzrnjzhstf","UseSSL":true,"Recipients":"christiandaniel.martin@infor.com,jeremy.edwards@infor.com,kylejohannes.almendo@infor.com,florecylmae.castillo@infor.com,almerjay.uy@infor.com","SendEmail":true},"SQLTypes":[{"Id":1,"Name":"SQL int nullable to C#","SQLDataType":"int","CSharpDataType":"int?","IsNullable":true},{"Id":2,"Name":"SQL int not nullable to C#","SQLDataType":"int","CSharpDataType":"int","IsNullable":false},{"Id":3,"Name":"SQL nvarchar to c#","SQLDataType":"nvarchar","CSharpDataType":"string","IsNullable":false},{"Id":4,"Name":"SQL varchar to C#","SQLDataType":"varchar","CSharpDataType":"string","IsNullable":false},{"Id":5,"Name":"SQL datetime nullable to C#","SQLDataType":"datetime","CSharpDataType":"datetime?","IsNullable":true},{"Id":6,"Name":"SQL datetime not nullable to C#","SQLDataType":"datetime","CSharpDataType":"datetime","IsNullable":false},{"Id":7,"Name":"SQL bit nullable to C#","SQLDataType":"bit","CSharpDataType":"bool?","IsNullable":true},{"Id":8,"Name":"SQL bit not nullable to C#","SQLDataType":"bit","CSharpDataType":"bit","IsNullable":false},{"Id":9,"Name":"SQL tinyint not nullable to C#","SQLDataType":"byte","CSharpDataType":"byte","IsNullable":false},{"Id":10,"Name":"SQL tinyint nullable to C#","SQLDataType":"byte","CSharpDataType":"byte?","IsNullable":true},{"Id":11,"Name":"SQL timestamp to C#","SQLDataType":"timestamp","CSharpDataType":"byte[]","IsNullable":false}]}