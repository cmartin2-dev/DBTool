)),1,1,'')\n\t\t\t\t\t\n\t\t\t\t\t\tIF ISNULL(@BOMLINECOLORRNGID,'0') != '0'\n\t\t\t\t\t\tBEGIN\n\t\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t\t('BOMLINECOLORRNG','SELECT * FROM ' + @SCHEMA + '.BOMLINECOLORRNG WITH (NOLOCK) WHERE BOMLINECOLORRNGID IN (' + @BOMLINECOLORRNGID + ')')\n\n\t\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t\t('BOMLINECOLORRNGVAL','SELECT * FROM ' + @SCHEMA + '.BOMLINECOLORRNGVAL WITH (NOLOCK) WHERE BOMLINECOLORRNGID IN (' + @BOMLINECOLORRNGID + ')')\n\n\n\t\t\t\t\t\tEND\n\n\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t('BOMLINESIZECATRNG','SELECT * FROM ' + @SCHEMA + '.BOMLINESIZECATRNG WITH (NOLOCK) WHERE BOMLINEID IN (' + @BOMLINEID + ')')\t\n\n\t\t\t\t\t\tDECLARE @BOMLINESIZECATRNGID NVARCHAR(MAX)\n\n\t\t\t\t\t\tSELECT @BOMLINESIZECATRNGID = STUFF((SELECT ',' + CONVERT(NVARCHAR(10),BOMLINESIZECATRNGID) FROM FSH1.BOMLINESIZECATRNG WHERE BOMLINEID IN (SELECT VALUE FROM string_split(@BOMLINEID,',')) FOR XML PATH('')),1,1,'')\n\t\t\t\t\t\n\t\t\t\t\t\tIF ISNULL(@BOMLINESIZECATRNGID,'0') != '0'\n\t\t\t\t\t\tBEGIN\n\t\t\t\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\t\t\t\tVALUES\n\t\t\t\t\t\t\t('BOMLINESIZE','SELECT * FROM ' + @SCHEMA + '.BOMLINESIZE WITH (NOLOCK) WHERE BOMLINESIZECATRNGID IN (' + @BOMLINESIZECATRNGID + ')')\t\n\n\t\t\t\t\t\tEND\n\n\t\t\t\t\tEND\n\t\t\t\tEND\n\n\t\t\tEND\n\t\tEND\n\t\t--stylebol\n\t\tIF UPPER(@TABLENAME) = 'STYLEBOL'\n\t\tBEGIN\n\t\t\tIF ISNULL(@ARCHIVED_STYLES,'0') != '0'\n\t\t\tBEGIN\n\t\t\t\tINSERT INTO @RETURNTABLE\n\t\t\t\t(TABLENAME,QUERYSTRING)\n\t\t\t\tVALUES\n\t\t\t\t(@TABLENAME,'SELECT * FROM ' + @SCHEMA + '.' + @TABLENAME +' WITH (NOLOCK) WHERE STYLEID IN (' + @ARCHIVED_STYLES + ')')\t\t\n\n\t\t\t\tDECLARE @STYLEBOLID NVARCHAR(MAX)\n\n\t\t\t\tSELECT @STYLEBOLID = STUFF((SELECT