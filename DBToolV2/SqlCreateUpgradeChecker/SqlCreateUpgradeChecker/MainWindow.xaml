<Window x:Class="SqlCreateUpgradeChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL Create/Upgrade Consistency Checker" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="90"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Folder picker (shared) -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <Label Content="Root Folder:" DockPanel.Dock="Left"/>
            <Button Content="Browse..." DockPanel.Dock="Right" Click="BrowseFolder_Click"/>
            <TextBox x:Name="txtRootFolder" IsReadOnly="True" VerticalContentAlignment="Center" Margin="4"/>
        </DockPanel>

        <!-- Row 1: Tabs -->
        <TabControl Grid.Row="1">
            <!-- TAB 1: Consistency Check -->
            <TabItem Header="Consistency Check" Padding="10,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,6,0,6">
                        <Label Content="Version:"/>
                        <ComboBox x:Name="cboVersion" Width="160"/>
                        <Label Content="Schema:" Margin="16,0,0,0"/>
                        <ComboBox x:Name="cboSchema" Width="100">
                            <ComboBoxItem Content="FSH"/>
                            <ComboBoxItem Content="SCAH"/>
                        </ComboBox>
                        <Button Content="Analyze" Click="Analyze_Click" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <TextBlock x:Name="txtSummary" Text="Select a folder, version, and schema to begin." TextWrapping="Wrap"/>
                    </Border>

                    <DataGrid Grid.Row="2" x:Name="dgResults" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" AlternatingRowBackground="#F9F9F9"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                              SelectionChanged="DgResults_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File Type" Binding="{Binding FileType}" Width="160"/>
                            <DataGridTextColumn Header="Change Type" Binding="{Binding ChangeType}" Width="130"/>
                            <DataGridTextColumn Header="Object Name" Binding="{Binding ObjectName}" Width="200"/>
                            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Changeset ID" Binding="{Binding ChangesetId}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="#CCCCCC" Margin="0,2"/>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DockPanel Grid.Column="0">
                            <Border DockPanel.Dock="Top" Background="#E8EEF4" Padding="8,4" CornerRadius="4,4,0,0">
                                <TextBlock x:Name="txtUpgradeHeader" Text="UPGRADE Script" FontWeight="SemiBold" FontSize="12"/>
                            </Border>
                            <TextBox x:Name="txtUpgradeScript" IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                                     Background="#FAFAFA" AcceptsReturn="True"/>
                        </DockPanel>
                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>
                        <DockPanel Grid.Column="2">
                            <Border DockPanel.Dock="Top" Background="#E8F4E8" Padding="8,4" CornerRadius="4,4,0,0">
                                <TextBlock x:Name="txtCreateHeader" Text="CREATE Script" FontWeight="SemiBold" FontSize="12"/>
                            </Border>
                            <TextBox x:Name="txtCreateScript" IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                                     Background="#FAFAFA" AcceptsReturn="True"/>
                        </DockPanel>
                    </Grid>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <TextBlock x:Name="txtResultCount" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="Export CSV" Click="ExportCsv_Click"/>
                        <Button Content="Export Excel" Click="ExportExcel_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 2: Compare CREATE Versions -->
            <TabItem Header="Compare CREATE Versions" Padding="10,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,6,0,6">
                        <Label Content="Version A:"/>
                        <ComboBox x:Name="cboCompareVersionA" Width="160"/>
                        <Label Content="Version B:" Margin="16,0,0,0"/>
                        <ComboBox x:Name="cboCompareVersionB" Width="160"/>
                        <Label Content="Schema:" Margin="16,0,0,0"/>
                        <ComboBox x:Name="cboCompareSchema" Width="100">
                            <ComboBoxItem Content="FSH"/>
                            <ComboBoxItem Content="SCAH"/>
                        </ComboBox>
                        <Label Content="File:" Margin="16,0,0,0"/>
                        <ComboBox x:Name="cboCompareFile" Width="220"/>
                        <Button Content="Compare" Click="Compare_Click" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Summary -->
                    <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <TextBlock x:Name="txtCompareSummary" Text="Select two versions, a schema, and a file to compare." TextWrapping="Wrap"/>
                    </Border>

                    <!-- Diff navigation bar -->
                    <DockPanel Grid.Row="2" Margin="0,0,0,4">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="◀ Prev Diff" Click="PrevDiff_Click" MinWidth="80" Padding="8,4"/>
                            <TextBlock x:Name="txtDiffPosition" VerticalAlignment="Center" Margin="8,0" Text=""/>
                            <Button Content="Next Diff ▶" Click="NextDiff_Click" MinWidth="80" Padding="8,4"/>
                        </StackPanel>
                        <ComboBox x:Name="cboDiffList" DockPanel.Dock="Left" Margin="0,0,8,0"
                                  SelectionChanged="CboDiffList_SelectionChanged"/>
                    </DockPanel>

                    <!-- Side-by-side scripts -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0">
                            <Border DockPanel.Dock="Top" Background="#E8EEF4" Padding="8,4" CornerRadius="4,4,0,0">
                                <TextBlock x:Name="txtCompareHeaderA" Text="Version A" FontWeight="SemiBold" FontSize="12"/>
                            </Border>
                            <RichTextBox x:Name="rtbCompareScriptA" IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12"
                                     Background="#FAFAFA" IsDocumentEnabled="True"/>
                        </DockPanel>

                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

                        <DockPanel Grid.Column="2">
                            <Border DockPanel.Dock="Top" Background="#E8F4E8" Padding="8,4" CornerRadius="4,4,0,0">
                                <TextBlock x:Name="txtCompareHeaderB" Text="Version B" FontWeight="SemiBold" FontSize="12"/>
                            </Border>
                            <RichTextBox x:Name="rtbCompareScriptB" IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12"
                                     Background="#FAFAFA" IsDocumentEnabled="True"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 3: Apply Fix -->
            <TabItem Header="Apply Fix" Padding="10,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,6,0,6">
                        <Label Content="Version:"/>
                        <ComboBox x:Name="cboFixVersion" Width="160"/>
                        <Label Content="Schema:" Margin="16,0,0,0"/>
                        <ComboBox x:Name="cboFixSchema" Width="100">
                            <ComboBoxItem Content="FSH"/>
                            <ComboBoxItem Content="SCAH"/>
                        </ComboBox>
                        <Button Content="Scan" Click="FixScan_Click" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <TextBlock x:Name="txtFixSummary" Text="Select a version and schema, then click Scan to find missing scripts." TextWrapping="Wrap"/>
                    </Border>

                    <DataGrid Grid.Row="2" x:Name="dgFixItems" AutoGenerateColumns="False"
                              CanUserSortColumns="True" AlternatingRowBackground="#F9F9F9"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                              SelectionChanged="DgFixItems_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Source File" Binding="{Binding SourceFile}" Width="250" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Target File" Binding="{Binding TargetFile}" Width="200" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Script" Binding="{Binding Label}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="#CCCCCC" Margin="0,2"/>

                    <DockPanel Grid.Row="4">
                        <Border DockPanel.Dock="Top" Background="#FFF8E1" Padding="8,4" CornerRadius="4,4,0,0">
                            <TextBlock x:Name="txtFixPreviewHeader" Text="Preview" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                        <TextBox x:Name="txtFixPreview" IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                                 Background="#FAFAFA" AcceptsReturn="True"/>
                    </DockPanel>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Select All" Click="FixSelectAll_Click"/>
                        <Button Content="Deselect All" Click="FixDeselectAll_Click"/>
                        <Button Content="Apply Selected" Click="FixApply_Click" FontWeight="SemiBold"
                                Background="#4CAF50" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 4: Compress FDB -->
            <TabItem Header="Compress FDB" Padding="10,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Compress controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,6,0,6">
                        <Label Content="Version:"/>
                        <ComboBox x:Name="cboFdbVersion" Width="160"/>
                        <CheckBox x:Name="chkFdbCreate" Content="CREATE" IsChecked="True" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <CheckBox x:Name="chkFdbUpgrade" Content="UPGRADE" IsChecked="True" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <Button Content="Compress" Click="CompressFdb_Click" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- S3 config -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <Label Content="AWS Profile:"/>
                        <ComboBox x:Name="cboAwsProfile" Width="140"/>
                        <Label Content="Region:" Margin="12,0,0,0"/>
                        <TextBox x:Name="txtAwsRegion" Width="120" VerticalContentAlignment="Center" Margin="4" Text="ap-southeast-1"/>
                        <Label Content="Bucket:" Margin="12,0,0,0"/>
                        <TextBox x:Name="txtS3Bucket" Width="200" VerticalContentAlignment="Center" Margin="4"/>
                        <Label Content="Prefix:" Margin="12,0,0,0"/>
                        <TextBox x:Name="txtS3Prefix" Width="200" VerticalContentAlignment="Center" Margin="4" Text="SQLSERVER/"/>
                    </StackPanel>

                    <Border Grid.Row="2" Background="#F0F0F0" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <TextBlock x:Name="txtFdbSummary" Text="Select a version and click Compress to generate .FDB files." TextWrapping="Wrap"/>
                    </Border>

                    <DataGrid Grid.Row="3" x:Name="dgFdbResults" AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#F9F9F9"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folder" Binding="{Binding Folder}" Width="100"/>
                            <DataGridTextColumn Header="Schema" Binding="{Binding Schema}" Width="80"/>
                            <DataGridTextColumn Header="Output File" Binding="{Binding OutputPath}" Width="250"/>
                            <DataGridTextColumn Header="S3 Path" Binding="{Binding S3Path}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" Width="80"/>
                            <DataGridTextColumn Header="S3 Status" Binding="{Binding S3Status}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Console log -->
                    <GridSplitter Grid.Row="4" Height="5" HorizontalAlignment="Stretch" Background="#CCCCCC" Margin="0,2"/>

                    <DockPanel Grid.Row="5">
                        <Border DockPanel.Dock="Top" Background="#263238" Padding="8,4" CornerRadius="4,4,0,0">
                            <TextBlock Text="Console" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                        <TextBox x:Name="txtConsoleLog" IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 AcceptsReturn="True"/>
                    </DockPanel>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Upload to S3" Click="UploadS3_Click" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
